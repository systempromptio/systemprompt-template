{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    <div class="dashboard-stats">
        <div class="stat-card" id="stat-ranked">
            <div class="label">Ranked Users</div>
            <div class="value">-</div>
        </div>
        <div class="stat-card" id="stat-avg-xp">
            <div class="label">Avg XP</div>
            <div class="value">-</div>
        </div>
        <div class="stat-card" id="stat-achievements">
            <div class="label">Achievements Unlocked</div>
            <div class="value">-</div>
        </div>
        <div class="stat-card" id="stat-streaks">
            <div class="label">Active Streaks</div>
            <div class="value">-</div>
        </div>
    </div>

    <div class="tab-bar">
        <a href="/admin/leaderboard/?tab=individual" class="tab-btn{{#if tab_individual}} active{{/if}}">All Users</a>
        <a href="/admin/leaderboard/?tab=department" class="tab-btn{{#if tab_department}} active{{/if}}">By Department</a>
    </div>

    {{#if tab_individual}}
    <div id="leaderboard-content" aria-live="polite">
        {{#if leaderboard}}
        {{#> components/data-table}}
            <thead><tr><th>#</th><th>User</th><th>Department</th><th>XP</th><th>Streak</th><th>Achievements</th><th>Last Active</th></tr></thead>
            <tbody>
            {{#each leaderboard}}
            <tr class="clickable-row" data-user-href="/admin/user/?id={{user_id}}" data-xp="{{default total_xp 0}}" data-achievements="{{default achievement_count 0}}" data-streak="{{default current_streak 0}}">
                <td><span class="leaderboard-rank{{#if (eq @index 0)}} leaderboard-rank-1{{else if (eq @index 1)}} leaderboard-rank-2{{else if (eq @index 2)}} leaderboard-rank-3{{/if}}">{{add @index 1}}</span></td>
                <td><div class="user-cell"><div class="user-avatar">{{initials (default display_name "A")}}</div><div class="user-info"><span class="user-name">{{default display_name "Anonymous"}}</span></div></div></td>
                <td>{{#if department}}<span class="badge badge-blue">{{department}}</span>{{else}}<span class="text-tertiary">-</span>{{/if}}</td>
                <td class="numeric">{{default total_xp 0}}</td>
                <td class="numeric">{{#if current_streak}}{{current_streak}}d{{else}}-{{/if}}</td>
                <td class="numeric">{{default achievement_count 0}}</td>
                <td>{{#if last_active_date}}<span title="{{formatDate last_active_date}}">{{relativeTime last_active_date}}</span>{{else}}Never{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No leaderboard data yet."}}
        {{/if}}
    </div>
    {{/if}}

    {{#if tab_department}}
    <div id="department-content" aria-live="polite">
        {{#if departments}}
        <div class="dept-grid">
            {{#each departments}}
            <div class="card p-5">
                <div class="card-title dept-card-title">{{department}}</div>
                <div class="stats-grid-3col">
                    <div><div class="stat-label">Total XP</div><div class="stat-value">{{total_xp}}</div></div>
                    <div><div class="stat-label">Avg XP</div><div class="stat-value">{{avg_xp}}</div></div>
                    <div><div class="stat-label">Users</div><div class="stat-value">{{user_count}}</div></div>
                </div>
                {{#if top_user}}
                <div class="dept-top-user">Top: <strong>{{default top_user.display_name top_user.user_id}}</strong> ({{default top_user.xp 0}} XP)</div>
                {{/if}}
            </div>
            {{/each}}
        </div>
        {{else}}
        {{> components/empty-state message="No department data available."}}
        {{/if}}
    </div>
    {{/if}}
    {{/inline}}
    {{#*inline "scripts"}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            // Update stats from table data
            var rows = document.querySelectorAll('.data-table tbody tr');
            var ranked = rows.length;
            var totalXp = 0, totalAch = 0, activeStreaks = 0;
            rows.forEach(function(row) {
                var xp = parseInt(row.getAttribute('data-xp') || '0', 10);
                var ach = parseInt(row.getAttribute('data-achievements') || '0', 10);
                var streak = parseInt(row.getAttribute('data-streak') || '0', 10);
                totalXp += xp;
                totalAch += ach;
                if (streak > 0) activeStreaks++;
            });
            var avgXp = ranked > 0 ? Math.round(totalXp / ranked) : 0;
            var el;
            el = document.querySelector('#stat-ranked .value'); if (el) el.textContent = ranked;
            el = document.querySelector('#stat-avg-xp .value'); if (el) el.textContent = avgXp;
            el = document.querySelector('#stat-achievements .value'); if (el) el.textContent = totalAch;
            el = document.querySelector('#stat-streaks .value'); if (el) el.textContent = activeStreaks;
            // Clickable rows
            document.addEventListener('click', function(e) {
                var tr = e.target.closest('[data-user-href]');
                if (tr) window.location.href = tr.getAttribute('data-user-href');
            });
        });
    </script>
    {{/inline}}
{{/layout}}
