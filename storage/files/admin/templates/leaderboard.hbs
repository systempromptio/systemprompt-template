{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    {{> components/page-hero}}

    <section aria-label="Leaderboard">
    <div class="leaderboard-tabs" role="tablist" aria-label="Sort leaderboard by">
        <a href="?sort=xp" class="leaderboard-tab{{#if (eq current_sort "xp")}} leaderboard-tab--active{{/if}}">XP</a>
        <a href="?sort=sessions" class="leaderboard-tab{{#if (eq current_sort "sessions")}} leaderboard-tab--active{{/if}}">Sessions</a>
        <a href="?sort=prompts" class="leaderboard-tab{{#if (eq current_sort "prompts")}} leaderboard-tab--active{{/if}}">Prompts</a>
        <a href="?sort=tools" class="leaderboard-tab{{#if (eq current_sort "tools")}} leaderboard-tab--active{{/if}}">Tools</a>
        <a href="?sort=subagents" class="leaderboard-tab{{#if (eq current_sort "subagents")}} leaderboard-tab--active{{/if}}">Subagents</a>
        <a href="?sort=streak" class="leaderboard-tab{{#if (eq current_sort "streak")}} leaderboard-tab--active{{/if}}">Streak</a>
        <a href="?sort=achievements" class="leaderboard-tab{{#if (eq current_sort "achievements")}} leaderboard-tab--active{{/if}}">Achievements</a>
    </div>

    {{#if podium}}
    <div class="leaderboard-podium" role="list" aria-label="Top 3 users">
        {{#each podium}}
        <div class="leaderboard-podium__card leaderboard-podium__card--{{medal}}" role="listitem">
            <span class="leaderboard-podium__position" aria-label="Position {{position}}">{{position}}</span>
            <div class="leaderboard-podium__badge rank-ladder__step-badge rank-tier-{{rank_level}}">{{rank_level}}</div>
            <span class="leaderboard-podium__name">{{display_name}}</span>
            <span class="leaderboard-podium__level-label">Lv. {{rank_level}}</span>
            <span class="rank-badge rank-tier-{{rank_level}}">{{rank_name}}</span>
            <span class="leaderboard-podium__xp"><span class="metric-value">{{total_xp}}</span> XP</span>
            <div class="leaderboard-podium__metrics">
                <span class="leaderboard-podium__metric" title="Total Sessions"><span class="metric-value">{{total_sessions}}</span> sess</span>
                <span class="leaderboard-podium__metric" title="Total Tool Uses"><span class="metric-value">{{total_tool_uses}}</span> tools</span>
            </div>
            {{#if (gt current_streak 0)}}
            <span class="leaderboard-streak{{#if (gt current_streak 3)}} leaderboard-streak--hot{{/if}}">&#128293; {{current_streak}}d</span>
            {{/if}}
        </div>
        {{/each}}
    </div>
    {{/if}}

    {{#if entries}}
    <div class="card">
        <div class="leaderboard-table-note">
            <small>Cumulative lifetime activity metrics</small>
        </div>
        {{#> components/data-table}}
            <thead>
                <tr>
                    <th class="col-rank">#</th>
                    <th>User</th>
                    <th class="col-number">Level</th>
                    <th>Rank</th>
                    <th class="col-number">XP</th>
                    <th class="col-number" title="Total sessions">Sessions</th>
                    <th class="col-number" title="Total prompts sent">Prompts</th>
                    <th class="col-number" title="Total tool uses">Tools</th>
                    <th class="col-number" title="Total subagent spawns">Subagents</th>
                    <th class="col-number">Streak</th>
                    <th class="col-number">Achievements</th>
                    <th class="col-number" title="Skills created">Skills</th>
                    <th class="col-number" title="Total days active">Days</th>
                </tr>
            </thead>
            <tbody>
            {{#each entries}}
            <tr{{#if is_self}} class="leaderboard-table__self" aria-current="true"{{/if}}>
                <td><strong>{{position}}</strong></td>
                <td>
                    <div class="user-cell">
                        <span class="user-level-badge rank-tier-{{rank_level}} user-level-badge--sm">
                            <span class="user-level-number">{{rank_level}}</span>
                        </span>
                        {{#if display_name}}{{display_name}}{{else}}<span class="text-tertiary">Anonymous</span>{{/if}}
                    </div>
                </td>
                <td class="text-right"><span class="level-number-badge rank-tier-{{rank_level}}">{{rank_level}}</span></td>
                <td><span class="rank-badge rank-tier-{{rank_level}}">{{rank_name}}</span></td>
                <td class="text-right"><span class="xp-value">{{total_xp}}</span></td>
                <td class="text-right"><span class="metric-value">{{total_sessions}}</span></td>
                <td class="text-right"><span class="metric-value">{{total_prompts}}</span></td>
                <td class="text-right"><span class="metric-value">{{total_tool_uses}}</span></td>
                <td class="text-right"><span class="metric-value">{{total_subagents}}</span></td>
                <td class="text-right">
                    {{#if (gt longest_streak 0)}}
                    <span class="leaderboard-streak{{#if (gt longest_streak 3)}} leaderboard-streak--hot{{/if}}">{{longest_streak}}d</span>
                    {{else}}
                    <span class="text-tertiary">-</span>
                    {{/if}}
                </td>
                <td class="text-right">{{achievement_count}}</td>
                <td class="text-right"><span class="metric-value">{{unique_skills_count}}</span></td>
                <td class="text-right"><span class="metric-value">{{total_days_active}}</span></td>
            </tr>
            {{/each}}
            </tbody>
            {{#if ../averages}}
            <tfoot>
            <tr class="leaderboard-table__averages">
                <td></td>
                <td><em>Platform Average</em></td>
                <td></td>
                <td></td>
                <td class="text-right">{{../averages.avg_xp}}</td>
                <td class="text-right">{{../averages.avg_sessions}}</td>
                <td class="text-right">{{../averages.avg_prompts}}</td>
                <td class="text-right">{{../averages.avg_tool_uses}}</td>
                <td class="text-right">{{../averages.avg_subagents}}</td>
                <td class="text-right">{{../averages.avg_streak}}</td>
                <td class="text-right">{{../averages.avg_achievements}}</td>
                <td class="text-right"></td>
                <td class="text-right">{{../averages.avg_days_active}}</td>
            </tr>
            </tfoot>
            {{/if}}
        {{/components/data-table}}
    </div>
    {{else}}
    <div class="empty-state">
        <p>No leaderboard data yet. Start using the platform to earn XP!</p>
    </div>
    {{/if}}
    </section>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-leaderboard.js"></script>
    {{/inline}}
{{/layout}}
