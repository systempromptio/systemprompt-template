{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{#if not_found}}
    {{> components/empty-state message="User not found."}}
    {{else if user}}

    <div class="dashboard-grid stats-grid-3col mb-6">
        {{> components/stat-card label="User" value=(default user.display_name user.user_id) subtitle=user.user_id}}
        {{> components/stat-card label="Total Events" value=(default user.total_events 0)}}
        {{#if user.last_active}}
        {{> components/stat-card label="Last Active" value=(relativeTime user.last_active)}}
        {{else}}
        {{> components/stat-card label="Last Active" value="Never"}}
        {{/if}}
    </div>

    <div class="card mb-6">
        <div class="card-header">
            <h3>Profile</h3>
            <span class="text-muted">Edit display name, email, roles, department, and status.</span>
        </div>
        <form id="user-edit-form" class="user-edit-form" data-user-id="{{user.user_id}}" novalidate>
            <div class="form-grid">
                <label class="form-field">
                    <span class="form-label">User ID</span>
                    <input type="text" value="{{user.user_id}}" disabled>
                </label>
                <label class="form-field">
                    <span class="form-label">Display Name</span>
                    <input type="text" name="display_name" value="{{default user.display_name ""}}">
                </label>
                <label class="form-field">
                    <span class="form-label">Email</span>
                    <input type="email" name="email" value="{{default user.email ""}}">
                </label>
                <label class="form-field">
                    <span class="form-label">Department</span>
                    <select name="department">
                        <option value=""{{#unless user_department}} selected{{/unless}}>Unassigned</option>
                        {{#each departments}}
                        <option value="{{this}}"{{#if (eq this ../user_department)}} selected{{/if}}>{{this}}</option>
                        {{/each}}
                    </select>
                </label>
                <label class="form-field">
                    <span class="form-label">Roles</span>
                    <input type="text" name="roles" value="{{#each user.roles}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}" placeholder="comma-separated">
                </label>
                <label class="form-field form-field--inline">
                    <input type="checkbox" name="is_active"{{#if user.is_active}} checked{{/if}}>
                    <span class="form-label">Active</span>
                </label>
                <div class="form-field form-field--readonly">
                    <span class="form-label">Member Since</span>
                    <div>{{formatDate user.created_at}}</div>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <button type="reset" class="btn btn-outline">Reset</button>
                <span class="form-status" id="user-edit-status" aria-live="polite"></span>
            </div>
        </form>
    </div>

    {{#if runtime}}
    <div class="card mb-6">
        <h3>Runtime</h3>
        <div class="dashboard-grid stats-grid-4col">
            {{> components/stat-card label="Connected agents" value=(concat runtime.connected_agents "/" runtime.total_agents)}}
            {{> components/stat-card label="Tokens in" value=(formatNumber runtime.tokens_in)}}
            {{> components/stat-card label="Tokens out" value=(formatNumber runtime.tokens_out)}}
            {{#if runtime.last_heartbeat_at}}
            {{> components/stat-card label="Last heartbeat" value=(relativeTime runtime.last_heartbeat_at)}}
            {{else}}
            {{> components/stat-card label="Last heartbeat" value="Never"}}
            {{/if}}
        </div>
        {{#if runtime.last_bridge_version}}
        <p class="text-muted runtime-meta">
            Most recent bridge: <code class="code-inline">{{runtime.last_bridge_version}}</code>
            on <code class="code-inline">{{runtime.last_os}}</code>
            {{#if runtime.last_hostname}}({{runtime.last_hostname}}){{/if}}
        </p>
        {{/if}}
    </div>
    {{/if}}

    {{#if user.activity_summary}}
    <div class="card mb-6">
        <h3>Activity Breakdown</h3>
        <div class="dashboard-grid stats-grid-3col">
            {{#each user.activity_summary}}
            {{> components/stat-card label=category value=(default count 0)}}
            {{/each}}
        </div>
    </div>
    {{/if}}

    <div class="card mb-6">
        <h3>Custom Skills</h3>
        {{#if user.skills}}
        <div class="table-container"><div class="table-scroll">
            <table class="data-table">
                <thead><tr><th>Name</th><th class="col-multiline">Description</th><th class="col-status">Status</th><th>Tags</th><th class="col-date">Updated</th></tr></thead>
                <tbody>
                {{#each user.skills}}
                <tr>
                    <td>{{name}}</td>
                    <td class="col-multiline">{{default description "-"}}</td>
                    <td class="col-status">{{#if enabled}}<span class="badge badge-green">Enabled</span>{{else}}<span class="badge badge-gray">Disabled</span>{{/if}}</td>
                    <td>{{#if tags}}{{#each tags}}<span class="badge badge-blue">{{this}}</span> {{/each}}{{else}}-{{/if}}</td>
                    <td class="col-date">{{relativeTime updated_at}}</td>
                </tr>
                {{/each}}
                </tbody>
            </table>
        </div></div>
        {{else}}
        {{> components/empty-state message="No custom skills."}}
        {{/if}}
    </div>

    <div class="card mb-6">
        <h3>Department &amp; assignments</h3>
        <div class="dashboard-grid stats-grid-4col">
            {{#if user_department}}
            {{> components/stat-card label="Department" value=user_department}}
            {{else}}
            {{> components/stat-card label="Department" value="Unassigned"}}
            {{/if}}
            {{> components/stat-card label="Effective skills" value=(default user_assignments.skills_count 0)}}
            {{> components/stat-card label="Marketplaces" value=(default user_assignments.marketplaces_count 0)}}
            {{> components/stat-card label="Active devices" value=(default user_devices_count 0)}}
        </div>
        <p class="text-muted runtime-meta">
            Assignments are stored in <code class="code-inline">access_control_rules</code>. Manage in the
            <a href="/admin/access-control?user_id={{user.user_id}}">access matrix</a>.
        </p>
    </div>

    {{#if has_effective_permissions}}
    <div class="card mb-6">
        <h3>Effective permissions — Gateway routes</h3>
        <p class="text-muted">Computed live by the authz resolver against this user's roles and department.</p>
        {{#if effective_permissions.gateway_routes}}
        <table class="data-table">
            <thead><tr><th>Route</th><th class="col-status">Decision</th><th>Decided by</th></tr></thead>
            <tbody>
            {{#each effective_permissions.gateway_routes}}
              <tr>
                <td><code class="code-inline">{{this.entity_id}}</code></td>
                <td class="col-status">
                  {{#if (eq this.decision "allow")}}
                    <span class="badge badge-green">ALLOW</span>
                  {{else}}
                    <span class="badge badge-red">DENY</span>
                  {{/if}}
                </td>
                <td><a href="{{this.matrix_url}}">{{this.reason}}</a></td>
              </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No gateway routes configured."}}
        {{/if}}
    </div>

    <div class="card mb-6">
        <h3>Effective permissions — MCP servers</h3>
        {{#if effective_permissions.mcp_servers}}
        <table class="data-table">
            <thead><tr><th>Server</th><th class="col-status">Decision</th><th>Decided by</th></tr></thead>
            <tbody>
            {{#each effective_permissions.mcp_servers}}
              <tr>
                <td><code class="code-inline">{{this.entity_id}}</code></td>
                <td class="col-status">
                  {{#if (eq this.decision "allow")}}
                    <span class="badge badge-green">ALLOW</span>
                  {{else}}
                    <span class="badge badge-red">DENY</span>
                  {{/if}}
                </td>
                <td><a href="{{this.matrix_url}}">{{this.reason}}</a></td>
              </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No MCP servers configured."}}
        {{/if}}
    </div>
    {{/if}}

    <div class="card mb-6">
        <h3>Devices</h3>
        {{#if user_devices}}
        <table class="data-table">
            <thead><tr><th>Name</th><th>Prefix</th><th>Platform</th><th class="col-date">Last seen</th><th class="col-status">Status</th></tr></thead>
            <tbody>
            {{#each user_devices}}
            <tr>
                <td><code class="code-inline">{{name}}</code></td>
                <td><code class="code-inline">{{key_prefix}}</code></td>
                <td>{{#if platform}}<span class="badge badge-blue">{{platform}}{{#if app_version}} {{app_version}}{{/if}}</span>{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
                <td class="col-date">{{#if last_seen_at}}<span title="{{formatDate last_seen_at}}">{{relativeTime last_seen_at}}</span>{{else}}<span class="text-tertiary">Never</span>{{/if}}</td>
                <td class="col-status">{{#if revoked}}<span class="badge badge-gray">Revoked</span>{{else}}<span class="badge badge-green">Active</span>{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No devices linked."}}
        {{/if}}
        <div class="toolbar toolbar--compact">
            <a class="btn btn-sm btn-primary" href="/admin/devices">Issue PAT</a>
            <a class="btn btn-sm btn-outline" href="/cowork-auth/device-link?prefill_user={{user.user_id}}">Link desktop app</a>
        </div>
    </div>

    <div class="card">
        <h3>Recent Activity</h3>
        {{#if user.recent_activity}}
        <div class="live-feed">
            {{#each user.recent_activity}}
            <div class="feed-item">
                <div class="feed-icon {{#if (eq category "login")}}feed-blue{{else if (eq category "skill_usage")}}feed-orange{{else if (eq category "marketplace_edit")}}feed-green{{else if (eq category "marketplace_connect")}}feed-purple{{else if (eq category "claude_code")}}feed-cyan{{else if (eq category "session")}}feed-cyan{{else}}feed-blue{{/if}}"></div>
                <div class="feed-content">
                    <span class="feed-text">{{description}}</span>
                    <span class="feed-time" title="{{formatDate created_at}}">{{relativeTime created_at}}</span>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        {{> components/empty-state message="No activity recorded."}}
        {{/if}}
    </div>

    {{else}}
    {{> components/empty-state message="No user ID provided."}}
    {{/if}}
    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-user-detail.js"></script>
    {{/inline}}
{{/layout}}
