{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{#if not_found}}
    {{> components/empty-state message="User not found."}}
    {{else if user}}

    <div class="dashboard-grid stats-grid-3col mb-6">
        {{> components/stat-card label="User" value=(default user.display_name user.user_id) subtitle=user.user_id}}
        {{> components/stat-card label="Total Events" value=(default user.total_events 0)}}
        {{#if user.last_active}}
        {{> components/stat-card label="Last Active" value=(relativeTime user.last_active)}}
        {{else}}
        {{> components/stat-card label="Last Active" value="Never"}}
        {{/if}}
    </div>

    <div class="card mb-6">
        <h3>Profile</h3>
        <table class="data-table"><tbody>
            <tr><td><strong>User ID</strong></td><td>{{user.user_id}}</td></tr>
            {{#if user.display_name}}<tr><td><strong>Display Name</strong></td><td>{{user.display_name}}</td></tr>{{/if}}
            {{#if user.email}}<tr><td><strong>Email</strong></td><td>{{user.email}}</td></tr>{{/if}}
            {{#if user.roles}}<tr><td><strong>Roles</strong></td><td>{{#each user.roles}}<span class="badge badge-blue">{{this}}</span> {{/each}}</td></tr>{{/if}}
            <tr><td><strong>Status</strong></td><td>{{#if user.is_active}}<span class="badge badge-green">Active</span>{{else}}<span class="badge badge-gray">Inactive</span>{{/if}}</td></tr>
            <tr><td><strong>Member Since</strong></td><td>{{formatDate user.created_at}}</td></tr>
        </tbody></table>
    </div>

    <div class="card mb-6 text-center">
        <a href="/admin/my/activity" class="btn btn-primary">View Full Activity Dashboard</a>
    </div>

    {{#if user.activity_summary}}
    <div class="card mb-6">
        <h3>Activity Breakdown</h3>
        <div class="dashboard-grid stats-grid-3col">
            {{#each user.activity_summary}}
            {{> components/stat-card label=category value=(default count 0)}}
            {{/each}}
        </div>
    </div>
    {{/if}}

    <div class="card mb-6">
        <h3>Custom Skills</h3>
        {{#if user.skills}}
        <div class="table-container"><div class="table-scroll">
            <table class="data-table">
                <thead><tr><th>Name</th><th class="col-multiline">Description</th><th class="col-status">Status</th><th>Tags</th><th class="col-date">Updated</th></tr></thead>
                <tbody>
                {{#each user.skills}}
                <tr>
                    <td>{{name}}</td>
                    <td class="col-multiline">{{default description "-"}}</td>
                    <td class="col-status">{{#if enabled}}<span class="badge badge-green">Enabled</span>{{else}}<span class="badge badge-gray">Disabled</span>{{/if}}</td>
                    <td>{{#if tags}}{{#each tags}}<span class="badge badge-blue">{{this}}</span> {{/each}}{{else}}-{{/if}}</td>
                    <td class="col-date">{{relativeTime updated_at}}</td>
                </tr>
                {{/each}}
                </tbody>
            </table>
        </div></div>
        {{else}}
        {{> components/empty-state message="No custom skills."}}
        {{/if}}
    </div>

    {{#if has_effective_permissions}}
    <div class="card">
        <h3>Effective Permissions</h3>
        <p class="text-muted">Computed live by the authz resolver against this user's roles and department. Click any decision to jump to the matrix cell that controls it.</p>

        <h4>Gateway Routes</h4>
        {{#if effective_permissions.gateway_routes}}
        <table class="table table-compact">
            <thead><tr><th>Route</th><th>Decision</th><th>Decided by</th></tr></thead>
            <tbody>
            {{#each effective_permissions.gateway_routes}}
              <tr>
                <td><code>{{this.entity_id}}</code></td>
                <td>
                  {{#if (eq this.decision "allow")}}
                    <span class="badge badge-green">ALLOW</span>
                  {{else}}
                    <span class="badge badge-red">DENY</span>
                  {{/if}}
                </td>
                <td><a href="{{this.matrix_url}}">{{this.reason}}</a></td>
              </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No gateway routes configured."}}
        {{/if}}

        <h4>MCP Servers</h4>
        {{#if effective_permissions.mcp_servers}}
        <table class="table table-compact">
            <thead><tr><th>Server</th><th>Decision</th><th>Decided by</th></tr></thead>
            <tbody>
            {{#each effective_permissions.mcp_servers}}
              <tr>
                <td><code>{{this.entity_id}}</code></td>
                <td>
                  {{#if (eq this.decision "allow")}}
                    <span class="badge badge-green">ALLOW</span>
                  {{else}}
                    <span class="badge badge-red">DENY</span>
                  {{/if}}
                </td>
                <td><a href="{{this.matrix_url}}">{{this.reason}}</a></td>
              </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No MCP servers configured."}}
        {{/if}}
    </div>
    {{/if}}

    <div class="card">
        <h3>Department &amp; assignments</h3>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;">
            <div>
                <span class="kpi-label">Department</span>
                <div style="margin-top:.25rem;">
                    {{#if user_department}}
                        <a href="/admin/access-control?department={{user_department}}" class="badge badge-blue">{{user_department}}</a>
                    {{else}}<span class="text-tertiary">Unassigned</span>{{/if}}
                </div>
            </div>
            <div>
                <span class="kpi-label">Effective skills</span>
                <div style="margin-top:.25rem;font-size:1.25rem;">{{default user_assignments.skills_count 0}}</div>
            </div>
            <div>
                <span class="kpi-label">Marketplaces</span>
                <div style="margin-top:.25rem;font-size:1.25rem;">{{default user_assignments.marketplaces_count 0}}</div>
            </div>
            <div>
                <span class="kpi-label">Active devices</span>
                <div style="margin-top:.25rem;font-size:1.25rem;">{{default user_devices_count 0}}</div>
            </div>
        </div>
        <p class="text-muted" style="font-size:.875rem;margin-top:.75rem;">
            Assignments are stored in <code>access_control_rules</code>. Manage in the
            <a href="/admin/access-control?user_id={{user.user_id}}">access matrix</a>.
        </p>
    </div>

    <div class="card">
        <h3>Devices</h3>
        {{#if user_devices}}
        <table class="table table-compact">
            <thead><tr><th>Name</th><th>Prefix</th><th>Platform</th><th>Last seen</th><th></th></tr></thead>
            <tbody>
            {{#each user_devices}}
            <tr>
                <td><code>{{name}}</code></td>
                <td><code class="code-inline">{{key_prefix}}</code></td>
                <td>{{#if platform}}<span class="badge">{{platform}}{{#if app_version}} {{app_version}}{{/if}}</span>{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
                <td>{{#if last_seen_at}}<span title="{{formatDate last_seen_at}}">{{relativeTime last_seen_at}}</span>{{else}}<span class="text-tertiary">Never</span>{{/if}}</td>
                <td>{{#if revoked}}<span class="badge badge-gray">Revoked</span>{{else}}<span class="badge badge-green">Active</span>{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        </table>
        {{else}}
        {{> components/empty-state message="No devices linked."}}
        {{/if}}
        <div style="margin-top:.75rem;display:flex;gap:.5rem;">
            <a class="btn btn-sm btn-primary" href="/admin/devices">Issue PAT</a>
            <a class="btn btn-sm btn-outline" href="/cowork-auth/device-link?prefill_user={{user.user_id}}">Link desktop app</a>
        </div>
    </div>

    <div class="card">
        <h3>Recent Activity</h3>
        {{#if user.recent_activity}}
        <div class="live-feed">
            {{#each user.recent_activity}}
            <div class="feed-item">
                <div class="feed-icon {{#if (eq category "login")}}feed-blue{{else if (eq category "skill_usage")}}feed-orange{{else if (eq category "marketplace_edit")}}feed-green{{else if (eq category "marketplace_connect")}}feed-purple{{else if (eq category "claude_code")}}feed-cyan{{else if (eq category "session")}}feed-cyan{{else}}feed-blue{{/if}}"></div>
                <div class="feed-content">
                    <span class="feed-text">{{description}}</span>
                    <span class="feed-time" title="{{formatDate created_at}}">{{relativeTime created_at}}</span>
                </div>
            </div>
            {{/each}}
        </div>
        {{else}}
        {{> components/empty-state message="No activity recorded."}}
        {{/if}}
    </div>

    {{else}}
    {{> components/empty-state message="No user ID provided."}}
    {{/if}}
    {{/inline}}
    {{#*inline "scripts"}}
    {{/inline}}
{{/layout}}
