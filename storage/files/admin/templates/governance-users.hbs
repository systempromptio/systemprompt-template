{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title="Users & Departments" subtitle="AI usage and activity by user and department."}}

    <nav class="tab-nav" aria-label="Governance sections">
        <a href="/admin/governance" class="tab-nav__item">Policies</a>
        <a href="/admin/governance/decisions" class="tab-nav__item">Decisions</a>
        <a href="/admin/governance/identity" class="tab-nav__item">Identity</a>
        <a href="/admin/governance/users" class="tab-nav__item tab-nav__item--active">Users</a>
        <a href="/admin/governance/hooks" class="tab-nav__item">Hooks</a>
    </nav>

    <div class="metric-ribbon">
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{total_users}}</span>
            <span class="metric-ribbon-label">Total Users</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-success">
            <span class="metric-ribbon-value">{{active_24h}}</span>
            <span class="metric-ribbon-label">Active (24h)</span>
        </div>
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{total_tokens}}</span>
            <span class="metric-ribbon-label">Total Tokens</span>
        </div>
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{total_prompts}}</span>
            <span class="metric-ribbon-label">Total Prompts</span>
        </div>
    </div>

    <div class="gf-grid">

        {{#> components/panel title="By Department" span="12"}}
            {{#if has_departments}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>Department</th>
                    <th class="col-numeric">Users</th>
                    <th class="col-numeric">Active (24h)</th>
                    <th class="col-numeric">Tokens</th>
                    <th class="col-numeric">Prompts</th>
                    <th class="col-numeric">Sessions (7d)</th>
                </tr></thead>
                <tbody>
                {{#each departments}}
                <tr>
                    <td><strong>{{department}}</strong></td>
                    <td class="col-numeric numeric">{{user_count}}</td>
                    <td class="col-numeric numeric">{{active_24h}}</td>
                    <td class="col-numeric numeric">{{total_tokens}}</td>
                    <td class="col-numeric numeric">{{total_prompts}}</td>
                    <td class="col-numeric numeric">{{sessions_this_week}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No department data available."}}
            {{/if}}
        {{/components/panel}}

        {{#> components/panel title="Users" href="/admin/users" span="12"}}
            {{#if has_users}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>User</th>
                    <th>Department</th>
                    <th class="col-numeric">Tokens</th>
                    <th class="col-numeric">Prompts</th>
                    <th class="col-numeric">Sessions</th>
                </tr></thead>
                <tbody>
                {{#each users}}
                <tr>
                    <td>
                        <a href="/admin/user?id={{user_id}}" class="user-cell">
                            <span class="avatar avatar-sm">{{initials display_name}}</span>
                            <span>{{display_name}}</span>
                        </a>
                    </td>
                    <td>{{department}}</td>
                    <td class="col-numeric numeric">{{total_tokens}}</td>
                    <td class="col-numeric numeric">{{total_prompts}}</td>
                    <td class="col-numeric numeric">{{total_sessions}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No users found."}}
            {{/if}}
        {{/components/panel}}

    </div>

    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
