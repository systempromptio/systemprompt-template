{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/page-hero}}

    {{#if category_summary}}
    <div class="card mb-6 p-4">
        <div class="d-flex align-center flex-wrap gap-2">
            <span class="font-semibold text-sm text-primary mr-2">Activity Summary</span>
            {{#each category_summary}}
                <span class="badge badge-blue">{{category}} <strong>{{count}}</strong></span>
            {{/each}}
        </div>
    </div>
    {{/if}}

    {{#if achievements_by_category}}
    <section aria-label="Achievement collection">
    <h3 class="mb-4">Achievements <span class="text-tertiary text-sm font-normal">{{unlocked_achievements}} of {{total_achievements}} unlocked</span></h3>
    {{#each achievements_by_category}}
    <details class="achievement-category" {{#if (gt unlocked_count 0)}}open{{/if}}>
        <summary class="achievement-category__header">
            <span class="achievement-category__icon">{{{icon}}}</span>
            <span class="achievement-category__name">{{category}}</span>
            <span class="achievement-category__count">{{unlocked_count}}/{{total_count}}</span>
            <span class="achievement-category__bar" role="progressbar" aria-valuenow="{{completion_pct}}" aria-valuemin="0" aria-valuemax="100" aria-label="{{category}} completion">
                <span class="achievement-category__bar-fill" style="width: {{completion_pct}}%"></span>
            </span>
            <span class="achievement-category__chevron">&#9654;</span>
        </summary>
        <div class="achievement-grid">
            {{#each achievements}}
            <div class="achievement-card {{#if is_unlocked}}unlocked{{else}}locked{{/if}}">
                <div class="achievement-card__header">
                    <span class="achievement-card__name">{{name}}</span>
                    <span class="achievement-rarity achievement-rarity--{{rarity_label}}">{{rarity_label}}</span>
                </div>
                <div class="achievement-card__desc">{{description}}</div>
                {{#if is_unlocked}}
                <div class="achievement-card__date">Unlocked {{relativeTime unlocked_at}}</div>
                {{else}}
                <div class="achievement-card__status">Locked</div>
                {{/if}}
            </div>
            {{/each}}
        </div>
    </details>
    {{/each}}
    </section>
    {{/if}}

    <section aria-label="Activity stream">
    <h3>Activity Stream</h3>
    <div class="toolbar">
        <input type="text" class="search-input search-narrow" id="events-search" placeholder="Search entities, actions, descriptions..." value="{{default search ""}}" aria-label="Search activity">
        <div class="flex-1"></div>
        <span class="text-tertiary text-sm self-center">
            {{#if (gt total 0)}}{{add offset 1}}{{else}}0{{/if}}-{{#if (gt total (add offset limit))}}{{add offset limit}}{{else}}{{total}}{{/if}} of {{total}}
        </span>
        {{#if has_prev}}
        <a href="/admin/my/activity?offset={{prev_offset}}{{#if search}}&search={{search}}{{/if}}" class="btn btn-secondary btn-sm">Newer</a>
        {{else}}
        <button type="button" class="btn btn-secondary btn-sm" disabled>Newer</button>
        {{/if}}
        {{#if has_next}}
        <a href="/admin/my/activity?offset={{next_offset}}{{#if search}}&search={{search}}{{/if}}" class="btn btn-secondary btn-sm">Older</a>
        {{else}}
        <button type="button" class="btn btn-secondary btn-sm" disabled>Older</button>
        {{/if}}
    </div>
    {{#if events}}
    {{#> components/data-table}}
        <thead><tr><th class="col-date">Timestamp</th><th class="col-status">Action</th><th>Entity Type</th><th>Entity Name</th><th class="col-multiline hide-mobile">Description</th></tr></thead>
        <tbody>
        {{#each events}}
        <tr>
            <td class="col-date"><span class="date">{{formatDate created_at}}</span></td>
            <td class="col-status">
                {{#if (eq action "created")}}<span class="badge badge-green">Created</span>
                {{else if (eq action "updated")}}<span class="badge badge-blue">Updated</span>
                {{else if (eq action "deleted")}}<span class="badge badge-red">Deleted</span>
                {{else if (eq action "imported")}}<span class="badge badge-purple">Imported</span>
                {{else if (eq action "uploaded")}}<span class="badge badge-yellow">Uploaded</span>
                {{else if (eq action "restored")}}<span class="badge badge-green">Restored</span>
                {{else if (eq action "forked")}}<span class="badge badge-blue">Forked</span>
                {{else if (eq action "logged_in")}}<span class="badge badge-green">Login</span>
                {{else if (eq action "logged_out")}}<span class="badge badge-gray">Logout</span>
                {{else}}<span class="badge badge-gray">{{action}}</span>
                {{/if}}
            </td>
            <td>{{#if entity_type}}{{entity_type}}{{else}}<span class="text-tertiary">-</span>{{/if}}</td>
            <td>{{#if entity_name}}{{entity_name}}{{else}}<span class="text-tertiary">-</span>{{/if}}</td>
            <td class="col-multiline hide-mobile">{{description}}</td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No activity yet. Create or edit skills, agents, and plugins to see your activity here."}}
    {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-my-activity.js" defer></script>
    {{/inline}}
{{/layout}}
