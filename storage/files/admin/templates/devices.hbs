{{#> layout title="Devices" page="devices"}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title="Devices"}}

    <section aria-label="Bridge device authentication">
        <div class="card mb-6">
            <div class="card-header">
                <h2 class="card-title">Personal access tokens (PATs)</h2>
                <p class="card-subtitle">Bearer tokens the <code>sp-bridge-auth</code> helper exchanges for a short-lived JWT. The secret is shown once at issue time.</p>
            </div>
            <div class="card-body">
                <form id="pat-issue-form" class="settings-form mb-4" onsubmit="return false;">
                    <div class="settings-form-grid">
                        <div class="settings-field">
                            <label class="settings-label" for="pat-name">Name</label>
                            <input type="text" id="pat-name" class="form-input" placeholder="laptop-m1" required />
                        </div>
                        <div class="settings-field">
                            <label class="settings-label" for="pat-expires">Expires at (optional, ISO-8601)</label>
                            <input type="text" id="pat-expires" class="form-input" placeholder="2026-12-31T23:59:59Z" />
                        </div>
                    </div>
                    <div class="form-actions">
                        <button type="button" id="pat-issue-btn" class="btn btn-primary">Issue PAT</button>
                    </div>
                </form>
                <pre id="pat-issued" class="mb-4" hidden></pre>

                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Name</th><th>Prefix</th><th>Created</th><th>Last used</th><th>Expires</th><th>Status</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each pats}}
                        <tr data-pat-id="{{id}}">
                            <td>{{name}}</td>
                            <td><code>{{key_prefix}}</code></td>
                            <td>{{created_at}}</td>
                            <td>{{last_used_at}}</td>
                            <td>{{expires_at}}</td>
                            <td>{{#if revoked}}<span class="text-error">revoked</span>{{else}}<span class="text-success">active</span>{{/if}}</td>
                            <td>{{#unless revoked}}<button type="button" class="btn btn-sm btn-danger" data-revoke-pat="{{id}}">Revoke</button>{{/unless}}</td>
                        </tr>
                        {{else}}
                        <tr><td colspan="7" class="text-tertiary">No PATs yet.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-6">
            <div class="card-header">
                <h2 class="card-title">Enrolled device certificates</h2>
                <p class="card-subtitle">Device certificates used for mutual TLS authentication.</p>
            </div>
            <div class="card-body">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Label</th><th>Fingerprint</th><th>Enrolled</th><th>Status</th><th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each certs}}
                        <tr data-cert-id="{{id}}">
                            <td>{{label}}</td>
                            <td><code class="cert-fp">{{fingerprint}}</code></td>
                            <td>{{enrolled_at}}</td>
                            <td>{{#if revoked}}<span class="text-error">revoked</span>{{else}}<span class="text-success">active</span>{{/if}}</td>
                            <td>{{#unless revoked}}<button type="button" class="btn btn-sm btn-danger" data-revoke-cert="{{id}}">Revoke</button>{{/unless}}</td>
                        </tr>
                        {{else}}
                        <tr><td colspan="5" class="text-tertiary">No device certificates enrolled.</td></tr>
                        {{/each}}
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <script>
    (function() {
        const issueBtn = document.getElementById('pat-issue-btn');
        const nameInput = document.getElementById('pat-name');
        const expiresInput = document.getElementById('pat-expires');
        const issuedBox = document.getElementById('pat-issued');

        issueBtn.addEventListener('click', async () => {
            const name = nameInput.value.trim();
            if (!name) return;
            const body = { name };
            const exp = expiresInput.value.trim();
            if (exp) body.expires_at = exp;
            const resp = await fetch('/admin/devices/pats', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body),
            });
            if (!resp.ok) {
                issuedBox.hidden = false;
                issuedBox.textContent = 'Error: ' + await AdminApp.errorMessage(resp);
                return;
            }
            const json = await resp.json();
            issuedBox.hidden = false;
            issuedBox.textContent = 'Save this secret NOW — it will not be shown again:\n\n' + json.secret;
        });

        document.querySelectorAll('[data-revoke-pat]').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.getAttribute('data-revoke-pat');
                if (!confirm('Revoke PAT ' + id + '?')) return;
                const resp = await fetch('/admin/devices/pats/' + encodeURIComponent(id), { method: 'DELETE' });
                if (resp.status === 204) location.reload();
            });
        });

        document.querySelectorAll('[data-revoke-cert]').forEach(btn => {
            btn.addEventListener('click', async () => {
                const id = btn.getAttribute('data-revoke-cert');
                if (!confirm('Revoke cert ' + id + '?')) return;
                const resp = await fetch('/admin/devices/certs/' + encodeURIComponent(id), { method: 'DELETE' });
                if (resp.status === 204) location.reload();
            });
        });
    })();
    </script>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
