{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Live Event Stream"
        subtitle="Every governance decision and gateway request, the instant it happens."}}

    <section class="events-controls" aria-label="Stream controls">
      <div class="events-controls__row">
        <div class="events-controls__status" data-stream-status>
          <span class="events-controls__indicator" data-stream-indicator aria-hidden="true"></span>
          <span class="events-controls__indicator-label" data-stream-state>connecting…</span>
        </div>
        <button type="button" class="btn btn-sm" data-stream-toggle>Pause</button>
        <label class="events-controls__check">
          <input type="checkbox" data-stream-autoscroll checked>
          Auto-scroll
        </label>
        <label class="events-controls__check">
          <input type="checkbox" data-stream-notify>
          Desktop notifications
        </label>
        <div class="events-controls__filters">
          <label class="events-controls__check">
            <input type="checkbox" data-severity-filter value="info" checked> info
          </label>
          <label class="events-controls__check">
            <input type="checkbox" data-severity-filter value="warn" checked> warn
          </label>
          <label class="events-controls__check">
            <input type="checkbox" data-severity-filter value="deny" checked> deny
          </label>
          <label class="events-controls__check">
            <input type="checkbox" data-severity-filter value="breach" checked> breach
          </label>
          <label class="events-controls__check">
            <input type="checkbox" data-severity-filter value="error" checked> error
          </label>
        </div>
        <input type="search" class="search-input search-narrow"
               placeholder="Filter by user / tool / policy…"
               data-stream-search aria-label="Filter events by text">
      </div>
    </section>

    <div class="events-layout">
      <section class="events-stream" aria-label="Live event stream"
               data-stream-list role="log" aria-live="polite">
        <div class="events-stream__placeholder" data-stream-empty>
          Waiting for events…
        </div>
      </section>

      <aside class="events-rail" aria-label="Rolling counters">
        <h2 class="events-rail__title">Last 60s</h2>
        <dl class="events-rail__list">
          <div class="events-rail__row">
            <dt>Events / sec</dt>
            <dd data-rail-rate>0.0</dd>
          </div>
          <div class="events-rail__row">
            <dt>Denies / sec</dt>
            <dd data-rail-deny-rate>0.0</dd>
          </div>
          <div class="events-rail__row events-rail__row--breach">
            <dt>Secret-scan hits</dt>
            <dd data-rail-breach>0</dd>
          </div>
          <div class="events-rail__row events-rail__row--error">
            <dt>Errors</dt>
            <dd data-rail-error>0</dd>
          </div>
        </dl>
        <p class="events-rail__hint">Counts roll over the trailing 60 seconds.</p>
      </aside>
    </div>
    {{/inline}}
{{/layout}}
