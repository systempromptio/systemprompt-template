{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-hero}}

    <section aria-label="Event breakdown">
    {{#if event_breakdown}}
    <div class="metric-ribbon align-center flex-wrap gap-2">
        <span class="ribbon-heading" style="font-variant-numeric: tabular-nums;">{{total}} events</span>
        {{#each event_breakdown}}
            {{#if (eq event_type "PostToolUse")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Tool Use <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_PostToolUse")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Tool Use <strong>{{count}}</strong></a>
            {{else if (eq event_type "PostToolUseFailure")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-danger">Tool Failure <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_PostToolUseFailure")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-danger">Tool Failure <strong>{{count}}</strong></a>
            {{else if (eq event_type "SessionStart")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-success">Session Start <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_SessionStart")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-success">Session Start <strong>{{count}}</strong></a>
            {{else if (eq event_type "SessionEnd")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-warning">Session End <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_SessionEnd")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-warning">Session End <strong>{{count}}</strong></a>
            {{else if (eq event_type "Stop")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Turn Complete <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_Stop")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Turn Complete <strong>{{count}}</strong></a>
            {{else if (eq event_type "SubagentStart")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Subagent Start <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_SubagentStart")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-info">Subagent Start <strong>{{count}}</strong></a>
            {{else if (eq event_type "SubagentStop")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-warning">Subagent Stop <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_SubagentStop")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-warning">Subagent Stop <strong>{{count}}</strong></a>
            {{else if (eq event_type "UserPromptSubmit")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-purple">User Prompt <strong>{{count}}</strong></a>
            {{else if (eq event_type "claude_code_UserPromptSubmit")}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-purple">User Prompt <strong>{{count}}</strong></a>
            {{else}}<a href="/admin/events/?event_type={{event_type}}" class="badge badge-secondary">{{event_type}} <strong>{{count}}</strong></a>
            {{/if}}
        {{/each}}
    </div>
    {{/if}}
    </section>
    <div class="toolbar">
        <input type="text" class="search-input search-narrow" id="events-search" placeholder="Search users, tools, sessions..." value="{{default search ""}}" aria-label="Search events">
        <div class="flex-1"></div>
        <span class="text-tertiary text-sm self-center" style="font-variant-numeric: tabular-nums;">
            {{#if (gt total 0)}}{{add offset 1}}{{else}}0{{/if}}-{{#if (gt total (add offset limit))}}{{add offset limit}}{{else}}{{total}}{{/if}} of {{total}}
        </span>
        {{#if has_prev}}
        <a href="/admin/events/?offset={{prev_offset}}{{#if search}}&search={{search}}{{/if}}{{#if event_type}}&event_type={{event_type}}{{/if}}" class="btn btn-secondary btn-sm">Newer</a>
        {{else}}
        <button type="button" class="btn btn-secondary btn-sm" disabled>Newer</button>
        {{/if}}
        {{#if has_next}}
        <a href="/admin/events/?offset={{next_offset}}{{#if search}}&search={{search}}{{/if}}{{#if event_type}}&event_type={{event_type}}{{/if}}" class="btn btn-secondary btn-sm">Older</a>
        {{else}}
        <button type="button" class="btn btn-secondary btn-sm" disabled>Older</button>
        {{/if}}
    </div>
    <section aria-label="Events list">
    {{#if events}}
    {{#> components/data-table}}
        <thead><tr><th>Timestamp</th><th>User</th><th>Event Type</th><th>Tool</th><th>Plugin</th><th>Session</th><th class="col-chevron"><span class="sr-only">Expand</span></th></tr></thead>
        <tbody>
        {{#each events}}
        <tr class="events-row clickable" data-event-id="{{id}}" aria-expanded="false">
            <td><span class="date">{{formatDate created_at}}</span></td>
            <td>{{default display_name user_id}}</td>
            <td>
                {{#if (eq event_type "PostToolUse")}}<span class="badge badge-info">Tool Use</span>
                {{else if (eq event_type "claude_code_PostToolUse")}}<span class="badge badge-info">Tool Use</span>
                {{else if (eq event_type "PostToolUseFailure")}}<span class="badge badge-danger">Tool Failure</span>
                {{else if (eq event_type "claude_code_PostToolUseFailure")}}<span class="badge badge-danger">Tool Failure</span>
                {{else if (eq event_type "SessionStart")}}<span class="badge badge-success">Session Start</span>
                {{else if (eq event_type "claude_code_SessionStart")}}<span class="badge badge-success">Session Start</span>
                {{else if (eq event_type "SessionEnd")}}<span class="badge badge-warning">Session End</span>
                {{else if (eq event_type "claude_code_SessionEnd")}}<span class="badge badge-warning">Session End</span>
                {{else if (eq event_type "Stop")}}<span class="badge badge-info">Turn Complete</span>
                {{else if (eq event_type "claude_code_Stop")}}<span class="badge badge-info">Turn Complete</span>
                {{else if (eq event_type "SubagentStart")}}<span class="badge badge-info">Subagent Start</span>
                {{else if (eq event_type "claude_code_SubagentStart")}}<span class="badge badge-info">Subagent Start</span>
                {{else if (eq event_type "SubagentStop")}}<span class="badge badge-warning">Subagent Stop</span>
                {{else if (eq event_type "claude_code_SubagentStop")}}<span class="badge badge-warning">Subagent Stop</span>
                {{else if (eq event_type "UserPromptSubmit")}}<span class="badge badge-purple">User Prompt</span>
                {{else if (eq event_type "claude_code_UserPromptSubmit")}}<span class="badge badge-purple">User Prompt</span>
                {{else}}<span class="badge badge-secondary">{{event_type}}</span>
                {{/if}}
            </td>
            <td>{{#if tool_name}}<code class="code-inline">{{tool_name}}</code>{{else}}<span class="text-tertiary">-</span>{{/if}}</td>
            <td>{{#if plugin_id}}{{plugin_id}}{{else}}<span class="text-tertiary">-</span>{{/if}}</td>
            <td>{{#if session_id}}<code class="code-inline">{{truncate session_id}}</code>{{else}}-{{/if}}</td>
            <td class="text-center"><span class="expand-chevron" aria-hidden="true">&#9654;</span></td>
        </tr>
        <tr class="events-detail-row" data-detail-for="{{id}}" hidden>
            <td colspan="7" class="cell-no-pad">
                <div class="detail-content">
                    <div class="metadata-grid">
                        <strong>Event ID:</strong><span>{{id}}</span>
                        <strong>Full Type:</strong><span>{{event_type}}</span>
                        <strong>Session ID:</strong><span>{{default session_id "-"}}</span>
                        <strong>User ID:</strong><span>{{user_id}}</span>
                        <strong>Timestamp:</strong><span>{{formatDate created_at}}</span>
                    </div>
                    <details>
                        <summary class="detail-summary">Raw Metadata</summary>
                        <pre class="detail-pre">{{json metadata}}</pre>
                    </details>
                </div>
            </td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No events match the current filters."}}
    {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-events.js" defer></script>
    {{/inline}}
{{/layout}}
