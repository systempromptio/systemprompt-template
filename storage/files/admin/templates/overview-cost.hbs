{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Cost &amp; models — Live"
        subtitle="Spend in motion. Where money is going right now, by provider and model."}}

    <section class="kpi-strip" aria-label="Cost KPIs">
        <div class="kpi-card">
            <span class="kpi-card__label">Spend (last hour)</span>
            <span class="kpi-card__value" data-kpi="spend">{{kpis.spend_display}}</span>
            <span class="kpi-card__sub" data-kpi="spend_per_min">{{kpis.spend_per_min_display}}</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Projected daily</span>
            <span class="kpi-card__value" data-kpi="projected">{{kpis.projected_daily_display}}</span>
            <span class="kpi-card__sub">at current rate</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Tokens</span>
            <span class="kpi-card__value" data-kpi="tokens">{{kpis.tokens_display}}</span>
            <span class="kpi-card__sub" data-kpi="tokens_per_min">{{kpis.tokens_per_min_display}} / min</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Top model</span>
            <span class="kpi-card__value kpi-card__value--text" data-kpi="top_model">{{kpis.top_model}}</span>
            <span class="kpi-card__sub">by spend</span>
        </div>
        <div class="kpi-card{{#if kpis.errors}} kpi-card--danger{{/if}}">
            <span class="kpi-card__label">Errors</span>
            <span class="kpi-card__value" data-kpi="errors">{{kpis.errors}}</span>
            <span class="kpi-card__sub">last hour</span>
        </div>
    </section>

    <section class="overview-pane">
        <h3 class="section-title">Cost over time (last 24h)
            <span class="live-dot" aria-hidden="true"></span>
        </h3>
        <div class="cost-spark" data-cost-max="{{cost_max}}" id="cost-spark"
             aria-label="Cost time series">
            {{#each cost_series}}
            <div class="cost-spark__bar" data-cost="{{this.cost_microdollars}}"
                 title="{{this.bucket_start}}: {{this.cost_display}}"></div>
            {{/each}}
        </div>
    </section>

    {{#if has_providers}}
    <section class="overview-pane">
        <h3 class="section-title">Share of spend by provider</h3>
        <ul class="provider-share-list" id="provider-share-list">
            {{#each providers}}
            <li class="provider-share-row" data-provider="{{this.provider}}">
                <span class="provider-share-row__label">{{this.provider}}</span>
                <div class="provider-share">
                    <div class="provider-share__bar" style="width: {{this.share_pct}}%"></div>
                    <span class="provider-share__label">{{this.share_pct}}%</span>
                </div>
                <span class="provider-share-row__cost">{{this.total_cost_display}}</span>
                <span class="provider-share-row__calls text-muted">{{this.calls}} calls</span>
            </li>
            {{/each}}
        </ul>
    </section>
    {{/if}}

    {{#if has_models}}
    <section class="overview-pane">
        <h3 class="section-title">Top models</h3>
        {{#> components/data-table}}
            <thead><tr>
                <th>Model</th>
                <th>Provider</th>
                <th class="col-num">Calls</th>
                <th class="col-num">Cost</th>
                <th class="col-num">Errors</th>
            </tr></thead>
            <tbody>
            {{#each models}}
            <tr>
                <td><code class="code-inline">{{this.model}}</code></td>
                <td><span class="text-muted">{{this.provider}}</span></td>
                <td class="col-num">{{this.calls}}</td>
                <td class="col-num"><strong>{{this.total_cost_display}}</strong></td>
                <td class="col-num">{{#if this.errors}}<span class="mcp-badge mcp-badge-danger">{{this.errors}}</span>{{else}}—{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
    </section>
    {{/if}}

    <section class="overview-pane">
        <h3 class="section-title">Live cost ticker
            <span class="live-dot" aria-hidden="true"></span>
        </h3>
        <ul class="live-ticker" id="cost-ticker" data-max="50" aria-live="polite">
            {{#each recent_requests}}
            <li>
                <span class="live-ticker__time">{{time}}</span>
                <span class="live-ticker__msg">{{msg}}</span>
                <span class="live-ticker__tag{{#if is_error}} live-ticker__tag--deny{{/if}}">{{#if is_error}}ERROR{{else}}REQ{{/if}}</span>
            </li>
            {{/each}}
        </ul>
    </section>

    <p class="text-tertiary text-sm overview-help">
        Deep-link: <a href="/admin/analytics/costs">Full cost analytics →</a>
    </p>
    {{/inline}}
    {{#*inline "head_extra"}}
    <link rel="stylesheet" href="/css/overview-live.css?v={{css_version}}">
    {{/inline}}
    {{#*inline "scripts"}}
    <script type="module" src="/js/pages/admin-overview-cost.js?v={{css_version}}"
            data-sse-url="{{sse_url}}" defer></script>
    {{/inline}}
{{/layout}}
