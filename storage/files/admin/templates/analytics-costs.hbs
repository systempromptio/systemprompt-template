{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Cost Analytics"
        subtitle="Spend, tokens, and throughput across every gateway request."}}

    {{> components/time-range time_range}}

    <section class="kpi-strip" aria-label="Cost KPIs">
        <div class="kpi-card">
            <span class="kpi-card__label">Total spend</span>
            <span class="kpi-card__value">{{kpis.total_cost_display}}</span>
            <span class="kpi-card__sub">{{kpis.requests}} request{{#unless (eq kpis.requests 1)}}s{{/unless}}</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Avg cost / request</span>
            <span class="kpi-card__value">{{kpis.cost_per_request_display}}</span>
            <span class="kpi-card__sub">max {{kpis.max_cost_display}}</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Total tokens</span>
            <span class="kpi-card__value">{{kpis.total_tokens_display}}</span>
            <span class="kpi-card__sub">in {{kpis.input_tokens_display}} · out {{kpis.output_tokens_display}}</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Throughput</span>
            <span class="kpi-card__value">{{kpis.tokens_per_minute_display}}</span>
            <span class="kpi-card__sub">tokens / minute</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Models in use</span>
            <span class="kpi-card__value">{{kpis.distinct_models}}</span>
            <span class="kpi-card__sub">{{kpis.distinct_providers}} provider{{#unless (eq kpis.distinct_providers 1)}}s{{/unless}}</span>
        </div>
        <div class="kpi-card{{#if kpis.error_count}} kpi-card--danger{{/if}}">
            <span class="kpi-card__label">Errors</span>
            <span class="kpi-card__value">{{kpis.error_count}}</span>
            <span class="kpi-card__sub">in / 1K: {{kpis.cost_per_1k_input_display}} · out / 1K: {{kpis.cost_per_1k_output_display}}</span>
        </div>
    </section>

    <div class="requests-charts">
        <section class="requests-charts__panel">
            <h3 class="requests-charts__title">Cost over time</h3>
            <div class="cost-spark" data-cost-max="{{cost_max}}"
                 aria-label="Cost time series, 24 buckets">
                {{#each cost_series}}
                <div class="cost-spark__bar" data-cost="{{this.cost_microdollars}}"
                     title="{{this.bucket_start}}: {{this.cost_display}}"></div>
                {{/each}}
            </div>
        </section>

        <section class="requests-charts__panel">
            <h3 class="requests-charts__title">Token throughput</h3>
            <div class="cost-spark" data-cost-max="{{throughput_max}}"
                 aria-label="Token throughput time series, 24 buckets">
                {{#each throughput_series}}
                <div class="cost-spark__bar" data-cost="{{this.total_tokens}}"
                     title="{{this.bucket_start}}: {{this.total_tokens}} tokens (in {{this.input_tokens}} / out {{this.output_tokens}})"></div>
                {{/each}}
            </div>
        </section>
    </div>

    {{#if has_models}}
    <section aria-label="Spend by model">
        <h3 class="section-title">Spend by model</h3>
        {{#> components/data-table}}
            <thead><tr>
                <th>Provider</th>
                <th>Model</th>
                <th class="col-num">Calls</th>
                <th class="col-num">Input tokens</th>
                <th class="col-num">Output tokens</th>
                <th class="col-num">Total cost</th>
                <th class="col-num">Avg cost</th>
                <th class="col-num">Avg latency</th>
                <th class="col-num">Errors</th>
            </tr></thead>
            <tbody>
            {{#each models}}
            <tr>
                <td><span class="text-muted">{{this.provider}}</span></td>
                <td><code class="code-inline">{{this.model}}</code></td>
                <td class="col-num">{{this.calls}}</td>
                <td class="col-num">{{this.input_tokens_display}}</td>
                <td class="col-num">{{this.output_tokens_display}}</td>
                <td class="col-num"><strong>{{this.total_cost_display}}</strong></td>
                <td class="col-num">{{this.avg_cost_display}}</td>
                <td class="col-num">{{this.avg_latency_display}}</td>
                <td class="col-num">
                    {{#if this.errors}}
                      <span class="mcp-badge mcp-badge-danger">{{this.errors}}</span>
                    {{else}}—{{/if}}
                </td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
    </section>
    {{/if}}

    {{#if has_providers}}
    <section aria-label="Spend by provider">
        <h3 class="section-title">Spend by provider</h3>
        {{#> components/data-table}}
            <thead><tr>
                <th>Provider</th>
                <th class="col-num">Calls</th>
                <th class="col-num">Models</th>
                <th class="col-num">Input tokens</th>
                <th class="col-num">Output tokens</th>
                <th class="col-num">Spend</th>
                <th>Share</th>
            </tr></thead>
            <tbody>
            {{#each providers}}
            <tr>
                <td><strong>{{this.provider}}</strong></td>
                <td class="col-num">{{this.calls}}</td>
                <td class="col-num">{{this.distinct_models}}</td>
                <td class="col-num">{{this.input_tokens_display}}</td>
                <td class="col-num">{{this.output_tokens_display}}</td>
                <td class="col-num"><strong>{{this.total_cost_display}}</strong></td>
                <td>
                    <div class="provider-share">
                        <div class="provider-share__bar" style="width: {{this.share_pct}}%"></div>
                        <span class="provider-share__label">{{this.share_pct}}%</span>
                    </div>
                </td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
    </section>
    {{/if}}

    {{#unless has_data}}
    {{> components/empty-state
        message="No gateway requests in the current time range. Widen the window or run a demo to populate data."}}
    {{/unless}}

    {{/inline}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
