{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/back-button href="/admin/org/mcp-servers/" label="Back to MCP Servers"}}
    <div class="card" style="max-width:900px">
        {{#if is_edit}}
        {{!-- Edit mode: raw YAML editor for all server types --}}
        <div style="display:flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-3)">
            <strong style="font-size:var(--text-lg)">{{server.id}}</strong>
            {{#if is_internal}}
            <span class="badge badge-purple">Internal</span>
            {{else}}
            <span class="badge badge-blue">External</span>
            {{/if}}
        </div>
        {{#if yaml_file_name}}
        <div style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:var(--space-4)">
            Source: <code class="code-inline">services/mcp/{{yaml_file_name}}</code>
        </div>
        {{/if}}
        <form id="mcp-yaml-form">
            <div class="form-group">
                <label class="field-label">YAML Configuration</label>
                <textarea class="field-input" name="yaml_content"
                    style="font-family:var(--font-mono);font-size:var(--text-sm);line-height:1.6;tab-size:2;white-space:pre;resize:vertical;min-height:360px"
                    rows="20" spellcheck="false">{{raw_yaml}}</textarea>
                <div id="yaml-error" style="color:var(--text-danger);font-size:var(--text-sm);margin-top:var(--space-2);display:none"></div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/org/mcp-servers/" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
        {{else}}
        {{!-- Create mode: structured form for new external servers --}}
        <form id="mcp-form" data-api-path="/mcp-servers/" data-entity="MCP server" data-id-field="id" data-list-path="/mcp-servers/">
            {{> components/form-group label="ID" name="id" type="text" value=server.id placeholder="my-server-id" required=true readonly=is_edit hint="kebab-case"}}
            {{> components/form-group label="Connection String" name="endpoint" type="text" value=server.endpoint placeholder="https://mcp.example.com/mcp" required=true hint="remote MCP endpoint URL"}}
            {{> components/form-group label="Description" name="description" type="text" value=server.description placeholder="Brief description"}}
            {{> components/form-group type="checkbox" name="enabled" checked=true checkboxLabel="Enabled"}}
            <hr style="border:none;border-top:1px solid var(--border-subtle);margin:var(--space-5) 0">
            <h3>OAuth Settings</h3>
            {{> components/form-group type="checkbox" name="oauth_required" checked=server.oauth_required checkboxLabel="OAuth Required"}}
            {{> components/form-group label="OAuth Scopes" name="oauth_scopes" type="text" value=server.oauth_scopes placeholder="scope1, scope2" hint="comma-separated"}}
            {{> components/form-group label="OAuth Audience" name="oauth_audience" type="text" value=server.oauth_audience placeholder="Audience URI"}}
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/admin/org/mcp-servers/" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
        {{/if}}
    </div>
    {{/inline}}
    {{#*inline "scripts"}}
    {{#if is_edit}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            var form = document.getElementById('mcp-yaml-form');
            var errorEl = document.getElementById('yaml-error');
            var serverId = '{{server.id}}';

            form.addEventListener('submit', function(e) {
                e.preventDefault();
                errorEl.style.display = 'none';
                var yamlContent = form.querySelector('[name="yaml_content"]').value;
                var submitBtn = form.querySelector('[type="submit"]');
                submitBtn.disabled = true;
                submitBtn.textContent = 'Saving...';

                AdminApp.api('/mcp-servers/' + encodeURIComponent(serverId) + '/yaml', {
                    method: 'PUT',
                    body: JSON.stringify({ yaml_content: yamlContent })
                }).then(function() {
                    AdminApp.Toast.show('MCP server updated', 'success');
                    window.location.href = AdminApp.BASE + '/mcp-servers/';
                }).catch(function(err) {
                    errorEl.textContent = err.message || 'Failed to save';
                    errorEl.style.display = 'block';
                    submitBtn.disabled = false;
                    submitBtn.textContent = 'Save';
                });
            });

            var textarea = form.querySelector('[name="yaml_content"]');
            textarea.addEventListener('keydown', function(e) {
                if (e.key === 'Tab') {
                    e.preventDefault();
                    var start = this.selectionStart;
                    var end = this.selectionEnd;
                    this.value = this.value.substring(0, start) + '  ' + this.value.substring(end);
                    this.selectionStart = this.selectionEnd = start + 2;
                }
            });
        });
    </script>
    {{else}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            AdminApp.interactions.initEditForm('mcp-form', {
                buildBody: function(form, formData) {
                    return {
                        server_type: 'external',
                        endpoint: formData.get('endpoint') || '',
                        description: formData.get('description') || '',
                        enabled: form.querySelector('[name="enabled"]').checked,
                        oauth_required: form.querySelector('[name="oauth_required"]').checked,
                        oauth_scopes: formData.get('oauth_scopes') || '',
                        oauth_audience: formData.get('oauth_audience') || ''
                    };
                }
            });
        });
    </script>
    {{/if}}
    {{/inline}}
{{/layout}}
