{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    <div id="plugin-create-content">
        <div class="detail-header" style="display:flex;gap:var(--space-3);align-items:center">
            <a href="/admin/org/plugins/" class="btn btn-secondary btn-sm">&larr; Back to Plugins</a>
            <button type="button" class="btn btn-primary btn-sm" id="btn-import-url">Import from URL</button>
        </div>
        <h2 style="margin:var(--space-4) 0 var(--space-5);font-size:var(--text-xl);font-weight:600">Create Plugin</h2>
        <div id="wizard-step-indicator"></div>
        <div class="card" style="max-width:800px;padding:var(--space-5)">
            <div id="wizard-step-content"></div>
            <div id="wizard-nav"></div>
        </div>

        <div id="import-modal" class="confirm-overlay" style="display:none">
            <div class="confirm-dialog" style="max-width:560px">
                <h3 style="margin:0 0 var(--space-3);font-size:var(--text-lg);font-weight:600">Import Plugin from URL</h3>
                <p style="margin:0 0 var(--space-4);color:var(--text-secondary);font-size:var(--text-sm)">Enter the URL of a plugin bundle JSON file (Anthropic marketplace format).</p>
                <input type="text" id="import-url" class="field-input" placeholder="https://example.com/plugin-bundle.json" style="width:100%;box-sizing:border-box">
                <div class="form-group" style="margin-top:var(--space-4)">
                    <label class="field-label">Import target</label>
                    <select id="import-target" class="field-input">
                        <option value="site">Site (shared plugin)</option>
                        <option value="user">Current user only</option>
                    </select>
                </div>
                <div id="import-error" style="display:none;margin-top:var(--space-2);color:var(--danger);font-size:var(--text-sm)"></div>
                <div style="display:flex;gap:var(--space-3);margin-top:var(--space-5);justify-content:flex-end">
                    <button type="button" class="btn btn-secondary btn-sm" id="import-cancel">Cancel</button>
                    <button type="button" class="btn btn-primary btn-sm" id="import-submit">Import</button>
                </div>
            </div>
        </div>
    </div>

    <template id="tpl-step-1">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Basic Info</h3>
        {{> components/form-group label="Plugin ID" name="plugin_id" type="text" placeholder="my-plugin" required=true hint="kebab-case"}}
        {{> components/form-group label="Name" name="name" type="text" placeholder="My Plugin" required=true}}
        {{> components/form-group label="Description" name="description" type="textarea" rows="3" placeholder="What this plugin does..."}}
        <div style="display:flex;gap:var(--space-3)">
            <div style="flex:1">{{> components/form-group label="Version" name="version" type="text" value="0.1.0"}}</div>
            <div style="flex:1">{{> components/form-group label="Category" name="category" type="text" placeholder="productivity"}}</div>
        </div>
    </template>

    <template id="tpl-step-2">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Select Skills</h3>
        <div class="form-group">
            <label class="field-label">Available Skills</label>
            <div style="display:flex;gap:var(--space-2);margin-bottom:var(--space-2)">
                <input type="text" class="field-input" placeholder="Search..." data-filter-list="wizard-skills" style="flex:1">
                <button type="button" class="btn btn-secondary btn-sm" data-select-all="wizard-skills">Select All</button>
                <button type="button" class="btn btn-secondary btn-sm" data-deselect-all="wizard-skills">Deselect All</button>
            </div>
            <div class="checklist-container" data-checklist="wizard-skills" style="max-height:300px;overflow-y:auto;border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-2)">
                {{#each skills_list}}
                <div class="checklist-item" data-item-name="{{toLowerCase value}}">
                    <input type="checkbox" name="wizard-skills" value="{{value}}" id="wizard-skills-chk-{{@index}}">
                    <label for="wizard-skills-chk-{{@index}}">{{default name value}}</label>
                </div>
                {{else}}
                <div class="empty-state" style="padding:var(--space-4)"><p>None available.</p></div>
                {{/each}}
            </div>
        </div>
    </template>

    <template id="tpl-step-3">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Select Agents</h3>
        <div class="form-group">
            <label class="field-label">Available Agents</label>
            <div style="display:flex;gap:var(--space-2);margin-bottom:var(--space-2)">
                <input type="text" class="field-input" placeholder="Search..." data-filter-list="wizard-agents" style="flex:1">
                <button type="button" class="btn btn-secondary btn-sm" data-select-all="wizard-agents">Select All</button>
                <button type="button" class="btn btn-secondary btn-sm" data-deselect-all="wizard-agents">Deselect All</button>
            </div>
            <div class="checklist-container" data-checklist="wizard-agents" style="max-height:300px;overflow-y:auto;border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-2)">
                {{#each agents_list}}
                <div class="checklist-item" data-item-name="{{toLowerCase (default name value)}}">
                    <input type="checkbox" name="wizard-agents" value="{{value}}" id="wizard-agents-chk-{{@index}}">
                    <label for="wizard-agents-chk-{{@index}}">{{default name value}}</label>
                </div>
                {{else}}
                <div class="empty-state" style="padding:var(--space-4)"><p>None available.</p></div>
                {{/each}}
            </div>
        </div>
    </template>

    <template id="tpl-step-4">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">MCP Servers</h3>
        <div class="form-group">
            <label class="field-label">Available MCP Servers</label>
            <div style="display:flex;gap:var(--space-2);margin-bottom:var(--space-2)">
                <input type="text" class="field-input" placeholder="Search..." data-filter-list="wizard-mcp" style="flex:1">
                <button type="button" class="btn btn-secondary btn-sm" data-select-all="wizard-mcp">Select All</button>
                <button type="button" class="btn btn-secondary btn-sm" data-deselect-all="wizard-mcp">Deselect All</button>
            </div>
            <div class="checklist-container" data-checklist="wizard-mcp" style="max-height:300px;overflow-y:auto;border:1px solid var(--border-subtle);border-radius:var(--radius-md);padding:var(--space-2)">
                {{#each mcp_list}}
                <div class="checklist-item" data-item-name="{{toLowerCase (default name value)}}">
                    <input type="checkbox" name="wizard-mcp" value="{{value}}" id="wizard-mcp-chk-{{@index}}">
                    <label for="wizard-mcp-chk-{{@index}}">{{default name value}}</label>
                </div>
                {{else}}
                <div class="empty-state" style="padding:var(--space-4)"><p>None available.</p></div>
                {{/each}}
            </div>
        </div>
    </template>

    <template id="tpl-step-5">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Hooks</h3>
        <p style="font-size:var(--text-sm);color:var(--text-secondary);margin:0 0 var(--space-4)">Configure event hooks that trigger commands during plugin lifecycle.</p>
        <div id="hooks-list"></div>
        <button type="button" class="btn btn-secondary btn-sm" id="btn-add-hook">+ Add Hook</button>
    </template>

    <template id="tpl-hook-entry">
        <div class="hook-entry card" style="padding:var(--space-3);margin-bottom:var(--space-3)">
            <div style="display:flex;gap:var(--space-3);flex-wrap:wrap;align-items:flex-start">
                <div class="form-group" style="flex:1;min-width:150px">
                    <label class="field-label">Event</label>
                    <select class="field-input" name="hook_event">
                        {{#each hook_events}}
                        <option value="{{this}}">{{this}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="form-group" style="flex:1;min-width:150px">
                    <label class="field-label">Matcher</label>
                    <input class="field-input" name="hook_matcher" value="*" placeholder="*">
                </div>
                <div class="form-group" style="flex:2;min-width:200px">
                    <label class="field-label">Command</label>
                    <input class="field-input" name="hook_command" placeholder="do-something">
                </div>
                <div class="form-group" style="display:flex;flex-direction:column;align-items:center">
                    <label class="field-label">Async</label>
                    <input type="checkbox" name="hook_async" style="margin-top:var(--space-2)">
                </div>
                <div style="display:flex;align-items:flex-end;padding-bottom:var(--space-1)">
                    <button type="button" class="btn btn-danger btn-sm" data-remove-hook>Remove</button>
                </div>
            </div>
        </div>
    </template>

    <template id="tpl-step-6">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Roles & Access</h3>
        <div class="form-group">
            <label class="field-label">Roles</label>
            <div style="display:flex;flex-wrap:wrap;gap:var(--space-1);padding:var(--space-2) 0">
                {{#each roles_list}}
                <label style="display:inline-flex;align-items:center;gap:var(--space-1);margin-right:var(--space-3);font-size:var(--text-sm);cursor:pointer">
                    <input type="checkbox" name="wizard-roles" value="{{value}}">
                    {{value}}
                </label>
                {{/each}}
            </div>
        </div>
        {{> components/form-group label="Author Name" name="author_name" type="text" placeholder="Your name"}}
        {{> components/form-group label="Keywords" name="keywords" type="text" placeholder="automation, workflow" hint="comma-separated"}}
    </template>

    <template id="tpl-step-7">
        <h3 style="margin:0 0 var(--space-4);font-size:var(--text-lg);font-weight:600">Review & Create</h3>
        <div class="card" style="padding:var(--space-4)">
            <div id="wizard-review" style="display:grid;grid-template-columns:140px 1fr;gap:var(--space-3);font-size:var(--text-sm)"></div>
        </div>
    </template>

    {{/inline}}
    {{#*inline "scripts"}}
    <script src="/js/admin-plugins.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            AdminApp.initPluginWizard();
        });
    </script>
    {{/inline}}
{{/layout}}
