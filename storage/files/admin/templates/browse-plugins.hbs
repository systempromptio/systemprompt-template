{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-hero}}

    <p class="text-muted mb-4">Add official plugins to your workspace. Once added, you can customize their skills, agents, and connectors in <a href="/admin/my/plugins/">My Plugins</a>.</p>

    <div class="toolbar">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search plugins..." id="browse-plugins-search" aria-label="Search plugins">
        </div>
        <label for="browse-plugins-category-filter" class="sr-only">Filter by category</label>
        <select class="filter-select min-w-filter" id="browse-plugins-category-filter" aria-label="Filter by category">
            <option value="">All Categories</option>
            {{#each categories}}
            <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
    </div>

    <div class="config-stats mb-4">
        <span class="badge badge-info">{{stats.total_available}} available</span>
        <span class="badge badge-success" id="browse-added-count">{{stats.already_added}} added</span>
    </div>

    <section aria-label="Available plugins">
    <div class="plugin-selection-grid" id="browse-plugins-grid">
        {{#each plugins}}
        <div class="plugin-selection-card flex-col cursor-default" data-plugin-id="{{plugin_id}}" data-category="{{category}}">
            <div class="plugin-selection-card-body">
                <div class="plugin-selection-card-header">
                    <strong class="plugin-selection-name">{{name}}</strong>
                    {{#if category}}<span class="badge badge-sm">{{category}}</span>{{/if}}
                </div>
                {{#if description}}<p class="plugin-selection-desc text-muted text-sm">{{description}}</p>{{/if}}
                <div class="plugin-selection-meta text-muted text-xs">
                    {{#if skill_count}}<span>{{skill_count}} skills</span>{{/if}}
                    {{#if agent_count}}<span>{{agent_count}} agents</span>{{/if}}
                    {{#if mcp_count}}<span>{{mcp_count}} connectors</span>{{/if}}
                </div>
                <div class="plugin-card-actions mt-3">
                    {{#if already_added}}
                    <span class="badge badge-success badge-padded">Added</span>
                    <button type="button" class="btn btn-secondary btn-sm ml-2" data-remove-plugin="{{plugin_id}}">Remove</button>
                    {{else}}
                    <button type="button" class="btn btn-primary btn-sm" data-add-plugin="{{plugin_id}}">Add</button>
                    {{/if}}
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    </section>

    {{#unless plugins}}
    {{> components/empty-state message="No plugins available."}}
    {{/unless}}

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-browse-plugins.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
