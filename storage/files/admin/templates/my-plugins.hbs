{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    {{> components/page-hero}}

    <p class="text-muted mb-4">Manage all plugins in your workspace. <a href="/admin/browse/plugins/">Browse the Plugin Directory</a> to add more.</p>

    <div class="toolbar">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search plugins..." id="my-plugins-search" aria-label="Search plugins">
        </div>
        <label for="my-plugins-category-filter" class="sr-only">Filter by category</label>
        <select class="filter-select min-w-filter" id="my-plugins-category-filter" aria-label="Filter by category">
            <option value="">All Categories</option>
            {{#each categories}}
            <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <a href="/api/public/marketplace/{{marketplace.user_id}}/export/cowork.zip" class="btn btn-secondary btn-sm ml-auto" title="Download merged plugin for Cowork import">Export for Cowork</a>
        <a href="/admin/my/plugins/edit/" class="btn btn-primary btn-sm">+ Create Plugin</a>
    </div>

    <div class="config-stats mb-4">
        <span class="badge badge-info">{{stats.plugin_count}} plugins</span>
    </div>

    {{#if has_plugins}}
    <section aria-label="Plugin list">
    <div class="table-container">
        <table class="data-table" id="my-plugins-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Resources</th>
                    <th>Usage</th>
                    <th>Source</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                {{#each plugins}}
                <tr class="clickable-row" data-expandable data-entity-id="{{plugin_id}}" data-name="{{toLowerCase name}}" data-category="{{category}}">
                    <td>
                        <div class="cell-primary"><span class="expand-indicator" data-expand-for="{{plugin_id}}">&#9654;</span> {{name}}</div>
                        {{#if description}}<div class="cell-secondary">{{truncate description 60}}</div>{{/if}}
                    </td>
                    <td>
                        {{#if category}}<span class="badge badge-info">{{category}}</span>{{else}}<span class="text-tertiary">—</span>{{/if}}
                    </td>
                    <td>
                        <div class="cell-badges">
                            {{#if (gt skill_count 0)}}<span class="badge badge-success">{{skill_count}} skill{{#if (not (eq skill_count 1))}}s{{/if}}</span>{{/if}}
                            {{#if (gt agent_count 0)}}<span class="badge badge-info">{{agent_count}} agent{{#if (not (eq agent_count 1))}}s{{/if}}</span>{{/if}}
                            {{#if (gt mcp_count 0)}}<span class="badge badge-warning">{{mcp_count}} MCP</span>{{/if}}
                        </div>
                    </td>
                    <td>
                        {{#if (gt total_uses 0)}}
                            <div class="usage-metric">
                                <span class="badge badge-info">{{total_uses}} uses</span>
                                <span class="text-tertiary text-xs">{{session_count}} sessions</span>
                            </div>
                                {{#if (gt scored_sessions 0)}}
                                <div class="mt-1">
                                    <span class="badge badge-warning">{{avg_quality_score}} quality</span>
                                    <span class="badge badge-purple">{{goal_achievement_pct}}% goals</span>
                                </div>
                                {{/if}}
                        {{else}}
                            <span class="text-tertiary">&mdash;</span>
                        {{/if}}
                    </td>
                    <td>
                        {{#if base_plugin_id}}
                        <span class="badge badge-purple">Official</span>
                        {{else}}
                        <span class="badge badge-success">Custom</span>
                        {{/if}}
                    </td>
                    <td class="col-actions" data-no-row-click>
                        <div class="actions-menu" data-actions-for="{{plugin_id}}">
                            <button type="button" class="actions-trigger" data-action="menu" title="Actions" aria-label="Actions menu">&#8942;</button>
                            <div class="actions-dropdown">
                                <a href="/admin/my/plugins/edit/?id={{plugin_id}}" class="actions-item">Edit</a>
                                <div class="actions-popup-separator"></div>
                                <button type="button" class="actions-item actions-item-danger" data-delete-plugin="{{plugin_id}}">Delete</button>
                            </div>
                        </div>
                    </td>
                </tr>
                <tr class="detail-row" data-detail-for="{{plugin_id}}">
                    <td colspan="6">
                        <div class="detail-row-content">
                            {{#if base_plugin_id}}
                            <div class="detail-section mb-3">
                                <span class="badge badge-purple text-xs">Official</span>
                                <span class="text-sm text-secondary">Added from <code class="text-xs">{{base_plugin_id}}</code></span>
                            </div>
                            {{/if}}

                            <div class="detail-section">
                                <strong>Skills ({{skill_count}})</strong>
                                {{#if skills}}
                                <table class="detail-sub-table mt-2">
                                    {{#each skills}}
                                    <tr>
                                        <td><a href="/admin/my/skills/edit?id={{id}}">{{name}}</a></td>
                                        <td class="text-right">
                                            {{#if (gt uses 0)}}<span class="badge badge-info badge-sm">{{uses}} uses</span>{{/if}}
                                            {{#if (gt scored_sessions 0)}}
                                            <span class="badge badge-warning badge-sm">{{avg_effectiveness}} eff</span>
                                            <span class="badge badge-purple badge-sm">{{goal_pct}}% goals</span>
                                            {{/if}}
                                        </td>
                                    </tr>
                                    {{/each}}
                                </table>
                                {{else}}
                                <p class="text-muted text-sm mt-1">No skills assigned</p>
                                {{/if}}
                            </div>

                            <div class="detail-section">
                                <strong>Agents ({{agent_count}})</strong>
                                {{#if agents}}
                                <table class="detail-sub-table mt-2">
                                    {{#each agents}}
                                    <tr>
                                        <td><a href="/admin/my/agents/edit?id={{id}}">{{name}}</a></td>
                                    </tr>
                                    {{/each}}
                                </table>
                                {{else}}
                                <p class="text-muted text-sm mt-1">No agents assigned</p>
                                {{/if}}
                            </div>

                            <div class="detail-section">
                                <strong>Connectors ({{mcp_count}})</strong>
                                {{#if mcp_servers}}
                                <table class="detail-sub-table mt-2">
                                    {{#each mcp_servers}}
                                    <tr><td>{{name}}</td></tr>
                                    {{/each}}
                                </table>
                                {{else}}
                                <p class="text-muted text-sm mt-1">No connectors assigned</p>
                                {{/if}}
                            </div>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    </section>
    {{else}}
    {{> components/empty-state message="No plugins yet. Browse the Plugin Directory to add plugins, or create a custom plugin."}}
    {{/if}}

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-my-plugins.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
