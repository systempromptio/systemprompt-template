{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/page-hero}}

    <section aria-label="CLI command" class="mb-3">
        <p class="text-tertiary text-sm">This dashboard mirrors <code class="code-inline">{{cli_command}}</code>.</p>
        <p class="text-tertiary text-sm">Add: <code class="code-inline">{{cli_command_add}}</code></p>
        <p class="text-tertiary text-sm">Remove: <code class="code-inline">{{cli_command_remove}}</code></p>
    </section>

    <section aria-label="Banned IPs">
        <h2 class="section-heading">Banned IPs</h2>
        {{#if bans}}
        {{#> components/data-table}}
            <thead><tr><th>IP Address</th><th class="col-multiline">Reason</th><th class="col-date">Created</th></tr></thead>
            <tbody>
            {{#each bans}}
            <tr><td><code class="code-inline">{{ip}}</code></td><td class="col-multiline">{{reason}}</td><td class="col-date">{{formatDate created_at}}</td></tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No IP bans configured. Use the CLI commands above to manage the ban list."}}
        {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
