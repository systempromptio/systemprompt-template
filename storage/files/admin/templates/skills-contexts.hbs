{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    <p class="text-tertiary">Contexts are conversation containers for agent sessions. This page mirrors <code class="code-inline">demo/skills/05-contexts.sh</code>.</p>

    <section aria-label="CLI commands">
    {{#> components/data-table}}
        <thead><tr><th>Step</th><th>Command</th></tr></thead>
        <tbody>
        {{#each cli_commands}}
        <tr>
            <td class="cell-primary">{{label}}</td>
            <td><code class="code-inline">{{cmd}}</code></td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    </section>

    <section aria-label="Contexts list">
        {{> components/empty-state message="Contexts are managed via the CLI. Run the commands above to list, create, show, rename, or delete conversation contexts."}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
