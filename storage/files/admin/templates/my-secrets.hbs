{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/page-hero}}

    <div class="toolbar">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search secrets..." id="my-secrets-search" aria-label="Search secrets">
        </div>
        <button type="button" class="btn btn-primary" id="add-secret-btn">+ Add Secret</button>
    </div>

    <div class="config-stats mb-4" id="stats-my-secrets">
        <span class="badge badge-blue">{{stats.total_count}} variable{{#if (not (eq stats.total_count 1))}}s{{/if}}</span>
        <span class="badge badge-purple">{{stats.secret_count}} encrypted</span>
    </div>

    <div class="entity-batch-bar" id="entity-batch-bar" hidden>
        <span class="entity-batch-count" id="entity-batch-count">0 selected</span>
        <button type="button" class="entity-batch-btn entity-batch-btn--danger" id="entity-batch-delete">Delete Selected</button>
    </div>

    {{#if groups}}
    <div class="table-container">
        <table class="data-table" id="my-secrets-table">
            <thead>
                <tr>
                    <th class="col-checkbox"><input type="checkbox" id="entity-select-all" class="entity-batch-checkbox" aria-label="Select all"></th>
                    <th>Variable Name</th>
                    <th>Plugin</th>
                    <th class="col-status">Type</th>
                    <th>Value</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                {{#each groups}}
                <tr class="group-header-row">
                    <td colspan="6">
                        <strong>{{this.plugin_id}}</strong>
                        <span class="badge badge-gray ml-2">{{this.count}} variable{{#if (not (eq this.count 1))}}s{{/if}}</span>
                    </td>
                </tr>
                {{#each this.variables}}
                <tr class="clickable-row" data-expandable data-entity-id="{{this.plugin_id}}/{{this.var_name}}" data-plugin="{{this.plugin_id}}" data-var="{{this.var_name}}" data-name="{{toLowerCase this.var_name}}" data-secret="{{this.is_secret}}">
                    <td class="col-checkbox" data-no-row-click><input type="checkbox" class="entity-batch-checkbox entity-row-checkbox" data-batch-id="{{this.plugin_id}}/{{this.var_name}}" aria-label="Select {{this.var_name}}"></td>
                    <td><div class="cell-primary"><span class="expand-indicator" data-expand-for="{{this.plugin_id}}/{{this.var_name}}">&#9654;</span> <code>{{this.var_name}}</code></div></td>
                    <td><span class="badge badge-gray">{{this.plugin_id}}</span></td>
                    <td class="col-status">
                        {{#if this.is_secret}}
                        <span class="badge badge-purple">encrypted</span>
                        {{else}}
                        <span class="badge badge-blue">env</span>
                        {{/if}}
                    </td>
                    <td><code class="text-tertiary">{{this.var_value}}</code></td>
                    <td class="col-actions" data-no-row-click>
                        <div class="actions-menu">
                            <button type="button" class="actions-trigger" data-action="menu" title="Actions" aria-label="Actions menu">&#8942;</button>
                            <div class="actions-dropdown">
                                <button type="button" class="actions-item edit-secret-btn" data-plugin="{{this.plugin_id}}" data-var="{{this.var_name}}" data-secret="{{this.is_secret}}">Edit</button>
                                <button type="button" class="actions-item actions-item-danger delete-secret-btn" data-plugin="{{this.plugin_id}}" data-var="{{this.var_name}}">Delete</button>
                            </div>
                        </div>
                    </td>
                </tr>
                <tr class="detail-row" data-detail-for="{{this.plugin_id}}/{{this.var_name}}">
                    <td colspan="6">
                        <div class="detail-row-content">
                            <div class="detail-section">
                                <strong>Plugin</strong>
                                <p class="text-sm text-secondary mt-1"><code>{{this.plugin_id}}</code></p>
                            </div>
                            <div class="detail-section">
                                <strong>Type</strong>
                                <p class="text-sm text-secondary mt-1">{{#if this.is_secret}}Encrypted secret (ChaCha20-Poly1305){{else}}Environment variable (plaintext){{/if}}</p>
                            </div>
                            {{#unless this.is_secret}}
                            {{#if this.var_value}}
                            <div class="detail-section">
                                <strong>Value</strong>
                                <pre class="detail-pre-wrap text-sm text-secondary mt-1">{{this.var_value}}</pre>
                            </div>
                            {{/if}}
                            {{/unless}}
                        </div>
                    </td>
                </tr>
                {{/each}}
                {{/each}}
            </tbody>
        </table>
    </div>
    {{else}}
    <div class="empty-state empty-centered">
        <p>No secrets yet. Add your first secret to get started.</p>
    </div>
    {{/if}}

    <div class="panel-overlay" id="secret-panel-overlay" role="presentation"></div>
    <aside class="side-panel" id="secret-panel" data-overlay="secret-panel-overlay">
        <div class="panel-header">
            <h2 id="secret-panel-title">Add Secret</h2>
            <button type="button" id="secret-panel-close" aria-label="Close panel">&times;</button>
        </div>
        <div class="panel-body">
            <form id="secret-form">
                <div class="form-group">
                    <label for="secret-plugin-id">Plugin</label>
                    <select id="secret-plugin-id" class="form-control" required>
                        <option value="">Select a plugin...</option>
                        {{#each plugins}}
                        <option value="{{this.id}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>
                <div class="form-group">
                    <label for="secret-var-name">Variable Name</label>
                    <input type="text" id="secret-var-name" class="form-control" placeholder="API_KEY" required>
                    <small class="text-tertiary">Use UPPER_SNAKE_CASE by convention</small>
                </div>
                <div class="form-group">
                    <label for="secret-var-value">Value</label>
                    <input type="password" id="secret-var-value" class="form-control" placeholder="Enter secret value..." required>
                </div>
                <div class="form-group">
                    <label class="toggle-label">
                        <input type="checkbox" id="secret-is-secret" checked>
                        Encrypt as secret
                    </label>
                    <small class="text-tertiary">Encrypted secrets are stored using ChaCha20-Poly1305 and never displayed in plaintext</small>
                </div>
                <div class="d-flex gap-3 mt-6">
                    <button type="submit" class="btn btn-primary" id="secret-save-btn">Save</button>
                    <button type="button" class="btn btn-secondary" id="secret-cancel-btn">Cancel</button>
                </div>
            </form>
        </div>
    </aside>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-my-secrets.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
