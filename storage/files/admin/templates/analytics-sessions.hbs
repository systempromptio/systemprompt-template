{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    <section aria-label="CLI command" class="hero-cli">
        <p class="text-tertiary text-sm">Run this on the CLI to see the same data:</p>
        <pre class="detail-pre"><code>{{cli_command}}</code></pre>
        <p class="text-tertiary text-sm">Window: {{window_label}} &middot; {{total_sessions}} sessions</p>
    </section>
    <section aria-label="Sessions">
    {{#if has_sessions}}
    {{#> components/data-table}}
        <thead><tr><th>Session / User</th><th class="col-numeric">Events</th><th class="col-date">First Seen</th><th class="col-date">Last Seen</th></tr></thead>
        <tbody>
        {{#each sessions}}
        <tr>
            <td>{{#> components/table-cell-stacked secondary=user_id}}<code class="code-inline">{{truncate session_id}}</code>{{/components/table-cell-stacked}}</td>
            <td class="numeric">{{events}}</td>
            <td class="col-date"><span class="date">{{first_seen}}</span></td>
            <td class="col-date"><span class="date">{{last_seen}}</span></td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No active sessions. Run the CLI command above to populate this view."}}
    {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
