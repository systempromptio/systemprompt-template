{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Trace Explorer"
        subtitle="Every gateway call, governance decision, and tool invocation grouped into a trace. Click any row to see the full waterfall."}}

    {{> components/entity-view-tabs entity_view_tabs}}

    {{> components/time-range time_range}}
    {{> components/identity-filter-ribbon filter_ribbon}}

    <section class="trace-stats" aria-label="Trace summary">
      <div class="trace-stats__row">
        <div class="trace-stats__cell">
          <span class="trace-stats__label">Traces</span>
          <span class="trace-stats__value">{{stats.total_traces}}</span>
        </div>
        <div class="trace-stats__cell">
          <span class="trace-stats__label">With errors</span>
          <span class="trace-stats__value trace-stats__value--bad">{{stats.error_count}}</span>
        </div>
        <div class="trace-stats__cell">
          <span class="trace-stats__label">With denies</span>
          <span class="trace-stats__value trace-stats__value--bad">{{stats.deny_count}}</span>
        </div>
        <div class="trace-stats__cell">
          <span class="trace-stats__label">p50</span>
          <span class="trace-stats__value">{{stats.p50_ms}} ms</span>
        </div>
        <div class="trace-stats__cell">
          <span class="trace-stats__label">p95</span>
          <span class="trace-stats__value">{{stats.p95_ms}} ms</span>
        </div>
        <div class="trace-stats__cell">
          <span class="trace-stats__label">p99</span>
          <span class="trace-stats__value">{{stats.p99_ms}} ms</span>
        </div>
      </div>
    </section>

    {{#if has_traces}}
      {{#> components/data-table}}
        <thead><tr>
          <th class="col-date">Started</th>
          <th>Trace</th>
          <th>Identity</th>
          <th>Agent</th>
          <th>Model</th>
          <th class="col-num">Reqs</th>
          <th class="col-num">Tools</th>
          <th class="col-num">Tokens</th>
          <th class="col-num">Cost</th>
          <th class="col-num">Duration</th>
          <th class="col-status">Status</th>
          <th class="col-actions"></th>
        </tr></thead>
        <tbody>
        {{#each traces}}
        <tr>
          <td class="col-date" title="{{this.started_at}}">{{this.started_at_local}}</td>
          <td>
            <a href="{{this.detail_url}}" class="trace-row__id" title="{{this.session_id}}">
              <code class="code-inline">{{this.session_id_short}}</code>
            </a>
            {{#if this.trace_id}}<div class="trace-row__trace">trace {{truncate this.trace_id 10}}</div>{{/if}}
          </td>
          <td>
            {{#if this.user_id}}<code class="code-inline" title="{{this.user_id}}">{{truncate this.user_id 12}}</code>{{else}}—{{/if}}
          </td>
          <td>
            {{#if this.agent_id}}
              <code class="code-inline">{{this.agent_id}}</code>
              {{#if this.agent_scope}}<div class="trace-row__agent">{{this.agent_scope}}</div>{{/if}}
            {{else}}—{{/if}}
          </td>
          <td>
            {{#if this.model}}
              <code class="code-inline">{{this.model}}</code>
              {{#if this.provider}}<div class="trace-row__agent">{{this.provider}}</div>{{/if}}
            {{else}}—{{/if}}
          </td>
          <td class="col-num">{{this.request_count}}</td>
          <td class="col-num">
            {{this.tool_call_count}}
            {{#if this.top_tool}}<div class="trace-row__agent" title="Most-frequent tool">{{this.top_tool}}</div>{{/if}}
          </td>
          <td class="col-num" title="Total / input / output">{{this.tokens_display}}</td>
          <td class="col-num">{{this.cost_display}}</td>
          <td class="col-num" title="Wall-clock window or sum of latency_ms">{{this.duration_display}}</td>
          <td class="col-status">
            {{#if this.has_deny}}<span class="mcp-badge mcp-badge-danger" title="{{this.deny_count}} denied decision(s)">DENY {{this.deny_count}}</span>{{/if}}
            {{#if this.has_error}}<span class="mcp-badge mcp-badge-warning">ERROR</span>{{/if}}
            {{#unless this.has_deny}}{{#unless this.has_error}}<span class="mcp-badge mcp-badge-success">OK</span>{{/unless}}{{/unless}}
            {{#if this.cache_hit_any}}<span class="mcp-badge" title="Cache read">CACHE</span>{{/if}}
          </td>
          <td class="col-actions">
            <a href="{{this.detail_url}}" class="btn btn-sm btn-outline">Waterfall</a>
          </td>
        </tr>
        {{/each}}
        </tbody>
      {{/components/data-table}}

      {{#if pagination.has_prev}}
        <a href="{{pagination.prev_url}}" class="btn btn-sm">&larr; Prev</a>
      {{/if}}
      <span class="trace-paginate__info">
        Page {{pagination.current_page}} of {{pagination.total_pages}} &middot; {{total_count}} traces
      </span>
      {{#if pagination.has_next}}
        <a href="{{pagination.next_url}}" class="btn btn-sm">Next &rarr;</a>
      {{/if}}
    {{else}}
      {{> components/empty-state message="No traces in the selected window. Adjust the time range or filters."}}
    {{/if}}
    {{/inline}}
{{/layout}}
