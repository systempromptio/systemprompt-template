{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/back-button href="/admin/my/mcp-servers/" label="Back to My MCP Servers"}}
    <h2>{{title}}</h2>
    {{#if is_forked}}
    <div class="config-stats" style="margin-bottom:var(--space-4)">
        <span class="config-stat"><span class="config-stat-dot yellow"></span> Forked from: <code style="font-size:var(--text-xs)">{{server.base_mcp_server_id}}</code></span>
    </div>
    {{/if}}
    <div class="card" style="max-width:800px">
        <form id="my-mcp-form" data-api-path="/user/mcp-servers/" data-entity="MCP Server" data-id-field="mcp_server_id" data-list-path="/my/mcp-servers/">
            {{> components/form-group label="MCP Server ID" name="mcp_server_id" type="text" value=server.mcp_server_id placeholder="my-mcp-server" required=true readonly=is_edit hint="kebab-case identifier"}}
            {{> components/form-group label="Name" name="name" type="text" value=server.name placeholder="My MCP Server" required=true}}
            {{> components/form-group label="Description" name="description" type="textarea" value=server.description rows="3" placeholder="What this MCP server does..."}}
            <div style="display:flex;gap:var(--space-3)">
                <div style="flex:1">
                    {{> components/form-group label="Binary" name="binary" type="text" value=server.binary placeholder="npx" hint="Command to run"}}
                </div>
                <div style="flex:1">
                    {{> components/form-group label="Package Name" name="package_name" type="text" value=server.package_name placeholder="@scope/package"}}
                </div>
            </div>
            <div style="display:flex;gap:var(--space-3)">
                <div style="flex:1">
                    {{> components/form-group label="Port" name="port" type="number" value=server.port placeholder="0"}}
                </div>
                <div style="flex:1">
                    {{> components/form-group label="Endpoint" name="endpoint" type="text" value=server.endpoint placeholder="https://..." hint="URL endpoint"}}
                </div>
            </div>
            <hr style="border:0;border-top:1px solid var(--border-primary);margin:var(--space-4) 0">
            <div style="display:flex;align-items:center;gap:var(--space-3);margin-bottom:var(--space-3)">
                <label style="display:flex;align-items:center;gap:var(--space-2);cursor:pointer">
                    <input type="checkbox" name="oauth_required" {{#if server.oauth_required}}checked{{/if}}>
                    <span>OAuth Required</span>
                </label>
            </div>
            {{> components/form-group label="OAuth Scopes" name="oauth_scopes" type="text" value=scopes_csv hint="comma-separated"}}
            {{> components/form-group label="OAuth Audience" name="oauth_audience" type="text" value=server.oauth_audience placeholder="https://api.example.com"}}
            <div style="display:flex;gap:var(--space-3);margin-top:var(--space-6)">
                <button type="submit" class="btn btn-primary">{{#if is_edit}}Save Changes{{else}}Create MCP Server{{/if}}</button>
                <a href="/admin/my/mcp-servers/" class="btn btn-secondary">Cancel</a>
                {{#if is_edit}}
                <button type="button" class="btn btn-danger" id="btn-delete-my-mcp" style="margin-left:auto">Delete</button>
                {{/if}}
            </div>
        </form>
    </div>
    {{/inline}}
    {{#*inline "scripts"}}
    <script src="/js/admin-my-workspace.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            AdminApp.interactions.initEditForm('my-mcp-form', {
                buildBody: function(form, formData) {
                    var scopesRaw = formData.get('oauth_scopes') || '';
                    var scopes = scopesRaw.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
                    return {
                        mcp_server_id: formData.get('mcp_server_id'),
                        name: formData.get('name'),
                        description: formData.get('description') || '',
                        binary: formData.get('binary') || '',
                        package_name: formData.get('package_name') || '',
                        port: parseInt(formData.get('port') || '0', 10) || 0,
                        endpoint: formData.get('endpoint') || '',
                        oauth_required: !!form.querySelector('[name="oauth_required"]').checked,
                        oauth_scopes: scopes,
                        oauth_audience: formData.get('oauth_audience') || ''
                    };
                }
            });
            var deleteBtn = document.getElementById('btn-delete-my-mcp');
            if (deleteBtn) {
                deleteBtn.addEventListener('click', function() {
                    var serverId = document.querySelector('[name="mcp_server_id"]').value;
                    if (confirm('Delete this MCP server?')) {
                        AdminApp.api('/user/mcp-servers/' + encodeURIComponent(serverId), { method: 'DELETE' })
                            .then(function() {
                                AdminApp.Toast.show('MCP server deleted', 'success');
                                window.location.href = '/admin/my/mcp-servers/';
                            })
                            .catch(function(err) {
                                AdminApp.Toast.show(err.message || 'Failed to delete', 'error');
                            });
                    }
                });
            }
        });
    </script>
    {{/inline}}
{{/layout}}
