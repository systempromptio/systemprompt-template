{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Services &amp; tools"
        subtitle="Every entity that runs in this Enterprise Demo: are they enabled, are they busy, are they healthy."}}

    <section class="kpi-strip" aria-label="Services KPIs">
        <div class="kpi-card">
            <span class="kpi-card__label">Entities</span>
            <span class="kpi-card__value" data-kpi="total">{{kpis.total_entities}}</span>
            <span class="kpi-card__sub">configured</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Enabled</span>
            <span class="kpi-card__value" data-kpi="enabled">{{kpis.enabled}}</span>
            <span class="kpi-card__sub">running</span>
        </div>
        <div class="kpi-card{{#if kpis.disabled}} kpi-card--muted{{/if}}">
            <span class="kpi-card__label">Disabled</span>
            <span class="kpi-card__value" data-kpi="disabled">{{kpis.disabled}}</span>
            <span class="kpi-card__sub">off</span>
        </div>
        <div class="kpi-card">
            <span class="kpi-card__label">Requests</span>
            <span class="kpi-card__value" data-kpi="rpm">{{kpis.requests_1h}}</span>
            <span class="kpi-card__sub">last 60 min</span>
        </div>
        <div class="kpi-card{{#if kpis.errors_1h}} kpi-card--danger{{/if}}">
            <span class="kpi-card__label">Errors</span>
            <span class="kpi-card__value" data-kpi="errors">{{kpis.errors_1h}}</span>
            <span class="kpi-card__sub">last 60 min</span>
        </div>
    </section>

    {{#each panels}}
    <section class="overview-pane">
        <h3 class="section-title">
            {{this.title}}
            <span class="text-tertiary text-sm">
                · {{this.enabled}} enabled{{#if this.disabled}} · {{this.disabled}} disabled{{/if}}
            </span>
        </h3>
        <p class="text-tertiary text-sm">{{this.subtitle}}</p>

        {{#if this.has_rows}}
        {{#> components/data-table}}
            <thead><tr>
                <th>Name</th>
                <th>Status</th>
                <th class="col-num">Calls (1h)</th>
                <th class="col-num">Errors</th>
                <th class="col-num">Latency</th>
                <th>Last error</th>
                <th></th>
            </tr></thead>
            <tbody>
            {{#each this.rows}}
            <tr>
                <td>
                    <a href="{{this.detail_url}}" class="link-plain">
                        <code class="code-inline">{{this.name}}</code>
                    </a>
                </td>
                <td>
                    <span class="status-pill status-pill--{{this.status}}">{{this.status_label}}</span>
                </td>
                <td class="col-num">{{#if this.calls}}{{this.calls}}{{else}}—{{/if}}</td>
                <td class="col-num">
                    {{#if this.errors}}
                        <a href="{{this.errors_url}}" class="mcp-badge mcp-badge-danger">{{this.errors}} {{this.errors_label}}</a>
                    {{else}}—{{/if}}
                </td>
                <td class="col-num">{{#if this.p95}}{{this.p95}}{{else}}—{{/if}}</td>
                <td><span class="text-muted">{{#if this.last_error}}{{this.last_error}}{{else}}—{{/if}}</span></td>
                <td><a href="{{this.detail_url}}" class="text-sm">Open →</a></td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        <p class="text-tertiary">None configured.</p>
        {{/if}}

        <p class="text-tertiary text-sm overview-help">
            <a href="{{this.list_url}}">Manage {{this.title}} →</a>
        </p>
    </section>
    {{/each}}

    <p class="text-tertiary text-sm overview-help">
        Deep-link: <a href="/admin/analytics/requests">All requests</a> ·
        <a href="/admin/mcp/tools">MCP tools</a> ·
        <a href="/admin/infra/services">Infrastructure</a>
    </p>
    {{/inline}}
    {{#*inline "head_extra"}}
    <link rel="stylesheet" href="/css/overview-live.css?v={{css_version}}">
    {{/inline}}
    {{#*inline "scripts"}}
    <script type="module" src="/js/pages/admin-overview-services.js?v={{css_version}}"
            data-sse-url="{{sse_url}}" defer></script>
    {{/inline}}
{{/layout}}
