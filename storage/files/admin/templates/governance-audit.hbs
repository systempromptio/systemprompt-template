{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header title="Audit Trail" subtitle="Forensic search across every governance decision. Filter, time-bound, click any row to see the full chain of custody."}}

    {{> components/time-range time_range}}

    {{> components/identity-filter-ribbon filter_ribbon}}

    <form method="get" action="/admin/governance/decisions" class="toolbar audit-toolbar">
        {{#each filter_ribbon.preserved}}
            {{#unless (eq this.name "q")}}
              <input type="hidden" name="{{this.name}}" value="{{this.value}}">
            {{/unless}}
        {{/each}}
        <input type="text" name="q" placeholder="Search reason / pattern_name..."
               value="{{search_query}}" class="search-input">
        <button type="submit" class="btn btn-sm">Search</button>
        <a href="{{csv_url}}" class="btn btn-sm btn-outline" download>Export CSV</a>
        <span class="text-muted audit-toolbar__count">
            {{total_count}} decision{{#unless (eq total_count 1)}}s{{/unless}}
        </span>
        <button type="button" class="btn btn-sm btn-primary" id="audit-live-pill" hidden>
            &uarr; <span id="audit-live-pill-count">0</span> new — refresh
        </button>
    </form>

    {{#if has_decisions}}
    {{#> components/data-table}}
        <thead><tr>
            <th class="col-date">Time</th>
            <th>Identity</th>
            <th>Tool</th>
            <th class="col-status">Stage</th>
            <th class="col-status">Decision</th>
            <th class="col-multiline">Rule &amp; evidence</th>
            <th class="col-num">Cost</th>
            <th class="col-num">Latency</th>
            <th>trace_id</th>
            <th class="col-actions"></th>
        </tr></thead>
        <tbody>
        {{#each decisions}}
        <tr data-chain-id="{{this.id}}" class="audit-row" tabindex="0"
            role="button" aria-label="Open chain of custody for {{this.id}}">
            <td class="col-date" title="{{this.created_at}}">{{this.created_at_local}}</td>
            <td>
                <div class="audit-identity">
                    <a href="/admin/user?id={{this.user_id}}">{{truncate this.user_id 16}}</a>
                    {{#if this.agent_id}}
                      <span class="audit-identity__agent">
                        {{this.agent_id}}{{#if this.agent_scope}} ({{this.agent_scope}}){{/if}}
                      </span>
                    {{/if}}
                    <span class="audit-identity__session" title="session {{this.session_id}}">
                      {{truncate this.session_id 12}}
                    </span>
                </div>
            </td>
            <td><code class="code-inline">{{this.tool_name}}</code></td>
            <td class="col-status">
                <span class="pipeline-stage pipeline-stage--{{this.pipeline_stage}}">
                    {{this.pipeline_stage_label}}
                </span>
            </td>
            <td class="col-status">
                {{#if this.is_denied}}
                  <span class="mcp-badge mcp-badge-danger">DENY</span>
                {{else}}
                  <span class="mcp-badge mcp-badge-success">ALLOW</span>
                {{/if}}
            </td>
            <td class="col-multiline">
                <div class="audit-evidence">
                    {{#if this.rule_name}}
                        <code class="code-inline">{{this.rule_name}}</code>
                    {{else}}
                        <code class="code-inline">{{this.policy}}</code>
                    {{/if}}
                    {{#if this.pattern_name}}
                        <span class="audit-evidence__pattern">{{this.pattern_name}}</span>
                    {{/if}}
                    {{#if this.evidence_redacted}}
                        <div class="audit-evidence__detail" title="{{this.reason}}">
                            {{truncate this.evidence_redacted 80}}
                        </div>
                    {{else}}
                        <div class="audit-evidence__detail" title="{{this.reason}}">
                            {{truncate this.reason 80}}
                        </div>
                    {{/if}}
                    {{#if this.risk_score}}
                        <span class="audit-evidence__risk">risk {{this.risk_score}}</span>
                    {{/if}}
                </div>
            </td>
            <td class="col-num">{{this.cost_display}}</td>
            <td class="col-num">{{#if this.latency_ms}}{{this.latency_ms}} ms{{else}}—{{/if}}</td>
            <td>
                {{#if this.trace_id}}
                    <code class="code-inline">{{truncate this.trace_id 8}}</code>
                    <button type="button" class="btn-icon" data-copy="{{this.trace_id}}"
                            aria-label="Copy trace id">⧉</button>
                {{else}}—{{/if}}
            </td>
            <td class="col-actions">
                <a href="/admin/governance/decisions/{{this.id}}"
                   class="btn-icon"
                   title="Open audit detail"
                   aria-label="Open audit detail for decision {{this.id}}"
                   onclick="event.stopPropagation();">↗</a>
            </td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}

    <nav class="audit-pagination" aria-label="Decisions pagination">
        {{#if pagination.has_prev}}
            <a href="{{pagination.prev_url}}" class="btn btn-sm btn-outline">&larr; Previous</a>
        {{else}}
            <span class="btn btn-sm btn-outline is-disabled">&larr; Previous</span>
        {{/if}}
        <span class="audit-pagination__pos">
            Page {{pagination.current_page}} of {{pagination.total_pages}}
        </span>
        {{#if pagination.has_next}}
            <a href="{{pagination.next_url}}" class="btn btn-sm btn-outline">Next &rarr;</a>
        {{else}}
            <span class="btn btn-sm btn-outline is-disabled">Next &rarr;</span>
        {{/if}}
    </nav>
    {{else}}
    {{> components/empty-state message="No decisions match the current filters. Try widening the time range or clearing filters."}}
    {{/if}}

    <script data-cfasync="false" type="module">
      import { initAuditLiveIndicator } from '/js/pages/admin-governance-audit.js';
      initAuditLiveIndicator();
    </script>

    {{/inline}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
