{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    {{> components/page-header title=hero_title subtitle=hero_subtitle}}
    <pre class="code-block"><code>{{cli_command}}</code></pre>

    <section class="stat-card-grid">
        {{> components/stat-card label="Total" value=total}}
        {{> components/stat-card label="Allowed" value=allowed variant="success"}}
        {{> components/stat-card label="Denied" value=denied variant="error"}}
        {{> components/stat-card label="Secret Breaches" value=secret_breaches variant="error"}}
    </section>

    {{#if has_entries}}
    {{#> components/data-table}}
        <thead><tr>
            <th class="col-date">Time</th><th>User</th><th>Agent</th><th class="col-status">Scope</th><th>Tool</th><th class="col-status">Decision</th><th>Policy</th><th class="col-multiline">Reason</th>
        </tr></thead>
        <tbody>
        {{#each entries}}
        <tr>
            <td class="col-date">{{created_at}}</td>
            <td>{{truncate user_id 12}}</td>
            <td>{{agent_id}}</td>
            <td class="col-status">{{#if agent_scope}}<span class="badge">{{agent_scope}}</span>{{/if}}</td>
            <td><code class="code-inline">{{tool_name}}</code></td>
            <td class="col-status">
                {{#if is_denied}}
                    <span class="mcp-badge mcp-badge-danger">DENY</span>
                {{else}}
                    <span class="mcp-badge mcp-badge-success">ALLOW</span>
                {{/if}}
            </td>
            <td><code class="code-inline">{{policy}}</code></td>
            <td class="col-multiline" title="{{reason}}">{{truncate reason 80}}</td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No audit entries yet. Run demo/governance/03-audit-trail.sh to generate data."}}
    {{/if}}

    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
