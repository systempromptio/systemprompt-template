{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title subtitle="Org marketplaces and the departments / users they reach."}}

    <div class="toolbar" role="toolbar">
        <div class="search-group"><input type="text" class="search-input" placeholder="Search marketplaces..." id="market-search"></div>
        <a class="btn btn-primary" href="/admin/org-marketplace">+ New marketplace</a>
    </div>

    {{#if items}}
    {{#> components/data-table}}
        <thead><tr><th>Marketplace</th><th>Description</th><th class="numeric col-numeric">Departments</th><th class="numeric col-numeric">Users</th><th>Coverage</th><th class="col-actions"></th></tr></thead>
        <tbody>
        {{#each items}}
        <tr data-search="{{toLowerCase name}} {{toLowerCase id}}">
            <td><a href="/admin/org-marketplace?id={{id}}"><strong>{{name}}</strong></a><br><code class="code-inline">{{id}}</code></td>
            <td>{{#if description}}{{description}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
            <td class="numeric col-numeric">{{departments}}</td>
            <td class="numeric col-numeric">{{users}}</td>
            <td><span class="text-muted" style="font-size:.875rem;">{{coverage_label}}</span></td>
            <td class="col-actions"><a class="btn btn-sm btn-outline" href="/admin/access-control?entity_type=marketplace&entity_id={{id}}">Assign</a></td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    <div class="empty-state" style="padding:3rem;text-align:center;">
        <h3>No marketplaces yet</h3>
        <p class="text-muted">Bundle your skills, agents, and MCP servers into a marketplace your team can install.</p>
        <a class="btn btn-primary" href="/admin/org-marketplace">Create marketplace</a>
    </div>
    {{/if}}

    <script>
    document.getElementById('market-search')?.addEventListener('input', (ev) => {
        const q = ev.target.value.toLowerCase();
        document.querySelectorAll('tr[data-search]').forEach(r => {
            r.style.display = !q || r.getAttribute('data-search').includes(q) ? '' : 'none';
        });
    });
    </script>
    {{/inline}}
{{/layout}}
