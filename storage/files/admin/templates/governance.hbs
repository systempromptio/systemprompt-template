{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title="Governance Policies" subtitle="The modular policy chain that gates every tool call. Each policy is a Rust impl registered via inventory; their order and config live in services/governance/config.yaml."}}

    <nav class="tab-nav" aria-label="Governance sections">
        <a href="/admin/governance" class="tab-nav__item tab-nav__item--active">Policies</a>
        <a href="/admin/governance/decisions" class="tab-nav__item">Decisions</a>
        <a href="/admin/governance/identity" class="tab-nav__item">Identity</a>
        <a href="/admin/governance/users" class="tab-nav__item">Users</a>
        <a href="/admin/governance/hooks" class="tab-nav__item">Hooks</a>
    </nav>

    <div class="metric-ribbon">
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{total}}</span>
            <span class="metric-ribbon-label">Total Decisions</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-success">
            <span class="metric-ribbon-value">{{allowed}}</span>
            <span class="metric-ribbon-label">Allowed</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-danger">
            <span class="metric-ribbon-value">{{denied}}</span>
            <span class="metric-ribbon-label">Denied</span>
        </div>
        {{#if secret_breaches}}
        <div class="metric-ribbon-item metric-ribbon-danger">
            <span class="metric-ribbon-value">{{secret_breaches}}</span>
            <span class="metric-ribbon-label">Secret Breaches</span>
        </div>
        {{/if}}
    </div>

    <div class="governance-section">
        <p class="text-muted" style="margin-bottom: var(--space-4);">
            Policies execute top-to-bottom; first deny short-circuits the rest. To add a policy:
            create a new file under <code>extensions/web/admin/src/handlers/webhook/governance/policies/</code>,
            implement the <code>Policy</code> trait, submit a <code>PolicyRegistration</code>, then list its id in
            <code>{{config_path}}</code>.
        </p>

        {{#if has_policies}}
        {{#> components/data-table}}
            <thead><tr>
                <th>Order</th>
                <th>Policy</th>
                <th class="col-multiline">Description</th>
                <th class="col-status">State</th>
                <th>Allowed</th>
                <th>Denied</th>
                <th class="col-date">Last seen</th>
                <th class="col-status">Actions</th>
            </tr></thead>
            <tbody>
            {{#each policies}}
            <tr>
                <td>{{add @index 1}}</td>
                <td>
                    <a href="{{edit_url}}"><strong>{{name}}</strong></a><br>
                    <code class="code-inline">{{id}}</code>
                </td>
                <td class="col-multiline text-muted">{{description}}</td>
                <td class="col-status">
                    {{#if enabled}}
                    <span class="mcp-badge mcp-badge-success">ENABLED</span>
                    {{else}}
                    <span class="mcp-badge">DISABLED</span>
                    {{/if}}
                </td>
                <td class="text-success">{{allowed}}</td>
                <td>
                    {{#if has_recent_denies}}
                    <a href="/admin/governance/decisions?policy={{id}}&outcome=deny" class="text-danger"><strong>{{denied}}</strong></a>
                    {{else}}
                    {{denied}}
                    {{/if}}
                </td>
                <td class="col-date">{{last_at}}</td>
                <td class="col-status">
                    <a href="{{edit_url}}" class="btn btn-sm btn-outline">Open</a>
                </td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No policies registered. Build the workspace and check that extensions/web/admin/src/handlers/webhook/governance/policies/ submits at least one PolicyRegistration."}}
        {{/if}}

        {{#if has_orphans}}
        <h2 style="margin-top: var(--space-6);">Historical (no longer registered)</h2>
        <p class="text-muted">These policy ids appear in <code>governance_decisions</code> but no Rust impl is currently registered for them — likely renamed or removed.</p>
        {{#> components/data-table}}
            <thead><tr><th>Policy id</th><th>Allowed</th><th>Denied</th><th class="col-date">Last seen</th></tr></thead>
            <tbody>
            {{#each orphans}}
            <tr>
                <td><code class="code-inline">{{id}}</code></td>
                <td>{{allowed}}</td>
                <td>{{denied}}</td>
                <td class="col-date">{{last_at}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{/if}}
    </div>

    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
