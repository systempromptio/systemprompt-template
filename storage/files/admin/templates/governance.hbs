{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    <div class="metric-ribbon">
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{total}}</span>
            <span class="metric-ribbon-label">Total Decisions</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-success">
            <span class="metric-ribbon-value">{{allowed}}</span>
            <span class="metric-ribbon-label">Allowed</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-danger">
            <span class="metric-ribbon-value">{{denied}}</span>
            <span class="metric-ribbon-label">Denied</span>
        </div>
        {{#if secret_breaches}}
        <div class="metric-ribbon-item metric-ribbon-danger">
            <span class="metric-ribbon-value">{{secret_breaches}}</span>
            <span class="metric-ribbon-label">Secret Breaches</span>
        </div>
        {{/if}}
    </div>

    <div class="governance-section">
        <form method="get" action="/admin/governance/" class="toolbar">
            <div class="search-box">
                <input type="text" name="q" id="governance-search" placeholder="Search by user, tool, decision, policy..." value="{{search_query}}" class="search-input" />
            </div>
            <button type="submit" class="btn btn-sm">Search</button>
            {{#if search_query}}
            <a href="/admin/governance/" class="btn btn-sm btn-outline">Clear</a>
            {{/if}}
        </form>

        {{#if has_decisions}}
        {{#> components/data-table}}
            <thead><tr>
                <th>User</th>
                <th>Tool</th>
                <th>Decision</th>
                <th>Policy</th>
                <th>Reason</th>
                <th>Scope</th>
                <th>Time</th>
            </tr></thead>
            <tbody>
            {{#each decisions}}
            <tr data-name="{{toLowerCase user_id}} {{toLowerCase tool_name}} {{toLowerCase decision}} {{toLowerCase reason}}">
                <td>
                    <div class="cell-primary">
                        <a href="/admin/user?id={{user_id}}">{{truncate user_id 12}}</a>
                    </div>
                    {{#if agent_id}}<div class="cell-secondary">via {{agent_id}}</div>{{/if}}
                </td>
                <td><code class="code-inline">{{tool_name}}</code></td>
                <td>
                    {{#if is_denied}}
                        {{#if is_secret_breach}}
                            <span class="mcp-badge mcp-badge-danger">SECRET BREACH</span>
                        {{else}}
                            <span class="mcp-badge mcp-badge-danger">DENIED</span>
                        {{/if}}
                    {{else}}
                        <span class="mcp-badge mcp-badge-success">ALLOWED</span>
                    {{/if}}
                </td>
                <td><code class="code-inline">{{policy}}</code></td>
                <td title="{{reason}}">{{truncate reason 50}}</td>
                <td>
                    {{#if agent_scope}}
                        <span class="badge {{#if (eq agent_scope "admin")}}badge-purple{{else}}badge-blue{{/if}}">{{agent_scope}}</span>
                    {{/if}}
                </td>
                <td class="text-sm text-tertiary">{{created_at}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No governance decisions recorded yet."}}
        {{/if}}
    </div>

    {{/inline}}
    {{#*inline "scripts"}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var searchInput = document.getElementById('governance-search');
            if (searchInput) {
                searchInput.addEventListener('input', function() {
                    var filter = this.value.toLowerCase();
                    var rows = document.querySelectorAll('tbody tr[data-name]');
                    rows.forEach(function(row) {
                        var name = row.getAttribute('data-name') || '';
                        row.style.display = name.includes(filter) ? '' : 'none';
                    });
                });
            }
        });
    </script>
    {{/inline}}
{{/layout}}