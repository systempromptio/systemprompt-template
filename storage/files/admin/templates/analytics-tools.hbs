{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    <section aria-label="Tool rankings">
    {{#if has_tools}}
    {{#> components/data-table}}
        <thead><tr><th>Tool</th><th class="col-numeric">Calls</th><th class="col-numeric">Errors</th><th class="col-numeric">Sessions</th><th class="col-numeric">Success Rate</th></tr></thead>
        <tbody>
        {{#each tools}}
        <tr>
            <td><code class="code-inline">{{tool_name}}</code></td>
            <td class="numeric">{{calls}}</td>
            <td class="numeric">{{errors}}</td>
            <td class="numeric">{{sessions}}</td>
            <td class="numeric">{{success_rate}}%</td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No tool usage in the window."}}
    {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
