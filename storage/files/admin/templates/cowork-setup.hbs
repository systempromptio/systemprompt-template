{{#> layout title="Connect your workstation" page="cowork-setup"}}
    {{#*inline "head_extra"}}
    <style>
      .setup-step { display: grid; grid-template-columns: 3rem 1fr; gap: 1rem; align-items: start; padding: 1.25rem 0; border-bottom: 1px solid var(--border, #e5e7eb); }
      .setup-step:last-child { border-bottom: none; }
      .setup-step .step-num { display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 999px; background: var(--brand-accent, #2a75f3); color: #fff; font-weight: 700; font-size: 1.125rem; }
      .setup-step h2 { margin: 0 0 0.5rem; font-size: 1.125rem; }
      .setup-step p { margin: 0.25rem 0; }
      .download-cta { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.625rem 1rem; border-radius: 6px; background: var(--brand-accent, #2a75f3); color: #fff; font-weight: 600; text-decoration: none; }
      .download-cta:hover { filter: brightness(1.05); }
      .download-other { margin-top: 0.5rem; font-size: 0.875rem; }
      .download-other summary { cursor: pointer; color: var(--text-secondary, #555); }
      .download-other ul { margin: 0.5rem 0 0; padding-left: 1.25rem; }
      .pill { display: inline-flex; align-items: center; gap: 0.375rem; padding: 0.125rem 0.625rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
      .pill.ok { background: #d4f5e0; color: #0f5132; }
      .pill.err { background: #f5d4d4; color: #5a1f1f; }
      .pill.pending { background: #f0f0f0; color: #555; }
      .tabs { display: flex; gap: 0.25rem; margin: 0.75rem 0 0; border-bottom: 1px solid var(--border, #e5e7eb); }
      .tabs button { background: none; border: none; padding: 0.5rem 0.875rem; cursor: pointer; font: inherit; color: var(--text-secondary, #555); border-bottom: 2px solid transparent; margin-bottom: -1px; }
      .tabs button.active { color: var(--brand-accent, #2a75f3); border-bottom-color: var(--brand-accent, #2a75f3); }
      .tab-panel { padding: 0.75rem 0; }
      .tab-panel[hidden] { display: none; }
      .snippet { position: relative; }
      .snippet pre { margin: 0; }
      .snippet .copy-btn { position: absolute; top: 0.5rem; right: 0.5rem; }
      .advanced { margin-top: 2rem; }
      .advanced summary { cursor: pointer; font-weight: 600; padding: 0.5rem 0; }
      .advanced > div { padding: 0.75rem 0; }
    </style>
    {{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title="Connect your workstation"}}

    <div class="card mb-6">
        <div class="card-body">
            <p>Three steps. About a minute. Signed in as <strong>{{user_email}}</strong>.
               <span id="gateway-pill" class="pill pending">Checking gateway&hellip;</span>
            </p>

            <div class="setup-step">
                <div class="step-num">1</div>
                <div>
                    <h2>Download the bridge</h2>
                    <p class="text-tertiary">Double-click to launch. A tray icon appears in your menu bar.</p>
                    <p>
                        <a id="download-cta" class="download-cta" href="#" rel="noopener">Download&hellip;</a>
                    </p>
                    <details class="download-other">
                        <summary>Other platforms</summary>
                        <ul>
                            <li><a href="{{download_base_url}}/systemprompt-bridge-macos.dmg">macOS (.dmg)</a></li>
                            <li><a href="{{download_base_url}}/systemprompt-bridge-windows.exe">Windows (.exe)</a></li>
                            <li><a href="{{download_base_url}}/systemprompt-bridge-linux.tar.gz">Linux (.tar.gz)</a></li>
                        </ul>
                    </details>
                </div>
            </div>

            <div class="setup-step">
                <div class="step-num">2</div>
                <div>
                    <h2>Get your access token</h2>
                    <p>Open <a href="/admin/devices" class="download-cta" style="background:var(--surface-2,#f5f7ff);color:var(--brand-accent,#2a75f3);">/admin/devices &rarr;</a></p>
                    <p class="text-tertiary">Click <strong>Issue PAT</strong>, copy the <code>sp-live-&hellip;</code> token. It is shown once.</p>
                </div>
            </div>

            <div class="setup-step">
                <div class="step-num">3</div>
                <div>
                    <h2>Paste it into the bridge</h2>
                    <div class="tabs" role="tablist">
                        <button type="button" class="active" role="tab" data-tab="tray">Tray app (macOS / Windows)</button>
                        <button type="button" role="tab" data-tab="terminal">Terminal (any OS)</button>
                    </div>
                    <div class="tab-panel" id="tab-tray" role="tabpanel">
                        <ol>
                            <li>Click the systemprompt tray icon.</li>
                            <li>Paste your <code>sp-live-&hellip;</code> token.</li>
                            <li>Click <strong>Sign in</strong>. The icon turns green.</li>
                        </ol>
                    </div>
                    <div class="tab-panel" id="tab-terminal" role="tabpanel" hidden>
                        <div class="snippet">
                            <button type="button" class="btn btn-sm copy-btn" id="cli-copy-btn">Copy</button>
                            <pre><code id="cli-snippet">systemprompt-bridge login sp-live-YOUR_TOKEN --gateway {{gateway_url}}</code></pre>
                        </div>
                        <p class="text-tertiary text-sm">Replace <code>sp-live-YOUR_TOKEN</code> with the token from step 2.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <details class="advanced card">
        <summary class="card-header">Advanced &mdash; manual config, session &amp; mTLS modes, revoke</summary>
        <div class="card-body">
            <h3>Revoke a token</h3>
            <p>On <a href="/admin/devices">/admin/devices</a> click <strong>Revoke</strong> on the device row. Locally, run <code>systemprompt-bridge logout</code> to wipe the on-disk credential.</p>

            <h3>Hand-edit the config</h3>
            <p>The bridge writes its own config; only edit by hand if you need session or mTLS mode.</p>
            <div class="snippet">
                <button type="button" class="btn btn-sm copy-btn" id="toml-copy-btn">Copy</button>
                <pre><code id="toml-snippet">gateway_url = "{{gateway_url}}"

# Pick one section. Providers probe in order: mtls -> session -> pat.

[session]
enabled = true

# [pat]
# file = "/abs/path/to/pat.txt"  # contents = the sp-live-... secret

# [mtls]
# cert_path = "/etc/systemprompt/device.pem"  # Linux
# cert_label = "systemprompt-device"          # macOS keystore
# cert_sha256 = "&lt;64-hex&gt;"                   # Windows cert store</code></pre>
            </div>
            <p class="text-tertiary text-sm">
                Stored at <code>$XDG_CONFIG_HOME/systemprompt/</code> on Linux,
                <code>~/Library/Application Support/systemprompt/</code> on macOS,
                <code>%APPDATA%\systemprompt\</code> on Windows.
            </p>

            <h3>Session &amp; mTLS modes</h3>
            <p>See <code>systemprompt-core/bin/bridge/README.md</code> for browser-consent (session) and OS-keystore-certificate (mTLS) flows, including the <code>systemprompt admin cowork enroll-cert</code> step required for mTLS.</p>
        </div>
    </details>

    <script>
    (function () {
        const GATEWAY = {{{json gateway_url}}};
        const DOWNLOAD_BASE = {{{json download_base_url}}};

        const ua = navigator.userAgent;
        const platform = /Mac/i.test(ua) ? "macos"
                       : /Win/i.test(ua) ? "windows"
                       : /Linux/i.test(ua) ? "linux"
                       : "macos";
        const ARTIFACTS = {
            macos:   { label: "Download for macOS",   file: "systemprompt-bridge-macos.dmg" },
            windows: { label: "Download for Windows", file: "systemprompt-bridge-windows.exe" },
            linux:   { label: "Download for Linux",   file: "systemprompt-bridge-linux.tar.gz" },
        };
        const cta = document.getElementById("download-cta");
        cta.href = DOWNLOAD_BASE + "/" + ARTIFACTS[platform].file;
        cta.textContent = ARTIFACTS[platform].label;

        const pill = document.getElementById("gateway-pill");
        fetch(GATEWAY + "/v1/auth/cowork/capabilities")
            .then(r => {
                if (r.ok) {
                    pill.className = "pill ok";
                    pill.textContent = "Gateway reachable";
                } else {
                    pill.className = "pill err";
                    pill.textContent = "Gateway error " + r.status;
                }
            })
            .catch(() => {
                pill.className = "pill err";
                pill.textContent = "Gateway unreachable";
            });

        const tabs = document.querySelectorAll(".tabs button");
        tabs.forEach(btn => btn.addEventListener("click", () => {
            tabs.forEach(b => b.classList.toggle("active", b === btn));
            const target = btn.dataset.tab;
            document.getElementById("tab-tray").hidden = target !== "tray";
            document.getElementById("tab-terminal").hidden = target !== "terminal";
        }));

        function wireCopy(btnId, srcId) {
            const btn = document.getElementById(btnId);
            const src = document.getElementById(srcId);
            if (!btn || !src) return;
            btn.addEventListener("click", () => {
                navigator.clipboard.writeText(src.innerText).then(() => {
                    btn.textContent = "Copied";
                    setTimeout(() => { btn.textContent = "Copy"; }, 1500);
                });
            });
        }
        wireCopy("cli-copy-btn", "cli-snippet");
        wireCopy("toml-copy-btn", "toml-snippet");
    })();
    </script>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
