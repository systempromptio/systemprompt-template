{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/toolbar searchId="agent-search" searchPlaceholder="Search agents..." newHref="/admin/org/agents/edit/" newLabel="+ New Agent"}}
    <div class="filter-toolbar">
        <select class="filter-select" id="plugin-filter">
            <option value="">All Plugins</option>
            {{#each filter_plugins}}<option value="{{this}}">{{this}}</option>{{/each}}
        </select>
    </div>
    <div class="bulk-actions-bar" id="bulk-bar" style="display:none">
        <span><strong data-bulk-count>0</strong> selected</span>
        <button class="btn btn-sm btn-secondary" id="bulk-assign-btn">Assign to Plugin</button>
        <button class="btn btn-sm btn-danger" id="bulk-delete-btn">Delete Selected</button>
    </div>
    {{#if agents}}
    {{#> components/data-table}}
        <thead>
            <tr>
                <th style="width:40px"><input type="checkbox" class="bulk-select-all"></th>
                <th>Name</th>
                <th>Agent ID</th>
                <th>Assigned Plugins</th>
                <th>MCP Servers</th>
                <th>Skills</th>
                <th>Usage</th>
                <th>Updated</th>
                <th class="col-actions"></th>
            </tr>
        </thead>
        <tbody>
        {{#each agents}}
        <tr class="clickable-row" data-name="{{toLowerCase name}}" data-agent-id="{{id}}" data-description="{{toLowerCase description}}" data-plugins="{{#each assigned_plugins}}{{name}},{{/each}}">
            <td data-no-row-click><input type="checkbox" class="bulk-checkbox" data-entity-id="{{id}}"></td>
            <td>
                <div class="cell-primary">
                    {{name}}
                    {{#if is_primary}}<span class="badge badge-blue">Primary</span>{{/if}}
                </div>
                {{#if description}}<div class="cell-secondary">{{truncate description 80}}</div>{{/if}}
            </td>
            <td><code class="code-inline">{{id}}</code></td>
            <td>
                <div class="badge-row">
                {{#if (gt plugin_count 0)}}
                    {{#each assigned_plugins}}
                    <span class="badge badge-purple">{{name}}</span>
                    {{/each}}
                {{else}}
                    <span style="color:var(--text-tertiary)">—</span>
                {{/if}}
                </div>
            </td>
            <td>
                {{#if (gt mcp_count 0)}}
                <span class="badge badge-yellow">{{mcp_count}}</span>
                {{else}}
                <span style="color:var(--text-tertiary)">—</span>
                {{/if}}
            </td>
            <td>
                {{#if (gt skill_count 0)}}
                <span class="badge badge-green">{{skill_count}}</span>
                {{else}}
                <span style="color:var(--text-tertiary)">—</span>
                {{/if}}
            </td>
            <td>{{#if usage_count}}<span class="usage-badge">{{usage_count}}</span>{{else}}<span class="text-muted">--</span>{{/if}}</td>
            <td><span class="metadata-timestamp" title="{{updated_at}}">{{updated_at}}</span></td>
            <td class="col-actions" data-no-row-click>
                <div class="actions-menu" data-actions-for="{{id}}">
                    <button class="actions-trigger" data-action="menu" title="Actions">&#8942;</button>
                    <div class="actions-dropdown">
                        <button class="actions-item" data-edit-agent="{{id}}">Edit</button>
                        <button class="actions-item" data-fork-agent="{{id}}">Customize</button>
                        <button class="actions-item" data-assign-agent="{{id}}" data-agent-name="{{name}}">Assign to Plugin</button>
                        <div class="actions-popup-separator"></div>
                        <button class="actions-item actions-item-danger" data-delete-agent="{{id}}">Delete</button>
                    </div>
                </div>
            </td>
        </tr>
        <tr class="detail-row">
            <td colspan="9">
                <div class="detail-row-content" data-agent-expand="{{id}}"></div>
            </td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No agents found."}}
    {{/if}}

    {{#each agents}}
    <script type="application/json" data-agent-detail="{{id}}">
        {{{json this}}}
    </script>
    {{/each}}

    <!-- Assign to Plugin side panel -->
    <div class="panel-overlay" id="assign-overlay"></div>
    <div class="assign-panel" id="assign-panel" data-overlay="assign-overlay">
        <div class="assign-panel-header">
            <h3 data-panel-title style="margin:0;font-size:var(--text-lg)">Assign Agent</h3>
            <button class="btn btn-icon" data-panel-close style="font-size:var(--text-lg)">&times;</button>
        </div>
        <div class="assign-panel-body" data-panel-body></div>
        <div class="assign-panel-footer" data-panel-footer></div>
    </div>

    <!-- Edit side panel -->
    <div class="panel-overlay" id="edit-overlay"></div>
    <div class="edit-panel" id="edit-panel" data-overlay="edit-overlay">
        <div class="edit-panel-header">
            <h3 data-panel-title style="margin:0;font-size:var(--text-lg)">Edit</h3>
            <button class="btn btn-icon" data-panel-close style="font-size:var(--text-lg)">&times;</button>
        </div>
        <div class="edit-panel-body" data-panel-body></div>
        <div class="edit-panel-footer" data-panel-footer></div>
    </div>

    <!-- All plugins data for assign panel -->
    <script type="application/json" id="all-plugins-data">
        {{{json all_plugins}}}
    </script>

    {{/inline}}
    {{#*inline "scripts"}}
    <script src="/js/admin-org.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            AdminApp.initOrgAgents();
        });
    </script>
    {{/inline}}
{{/layout}}
