{{#> layout title=title page=page}}
    {{#*inline "content"}}
    {{> components/page-header
        title="Policy Decisions"
        subtitle="Are policies firing as expected? What changed since yesterday? Click any number to dig into the audit trail."}}

    {{> components/time-range time_range}}

    <div class="portfolio-page">

      {{!-- 6 KPI sparkline cards --}}
      <section aria-labelledby="portfolio-kpis-title">
        <div class="portfolio-section__header">
          <h2 class="portfolio-section__title" id="portfolio-kpis-title">Headline metrics</h2>
          <span class="portfolio-section__hint">vs. prior {{prior_window_label}}</span>
        </div>
        <div class="portfolio-kpis">
          {{#each kpis}}
            {{> components/sparkline-card
                label=this.label
                value=this.value
                subtitle=this.subtitle
                variant=this.variant
                delta=this.delta
                sparkline=this.sparkline
                sparkline_color=this.sparkline_color
                href=this.href}}
          {{/each}}
        </div>
      </section>

      {{!-- Anomalies right now --}}
      <section aria-labelledby="portfolio-anomalies-title">
        <div class="portfolio-section__header">
          <h2 class="portfolio-section__title" id="portfolio-anomalies-title">Anomalies right now</h2>
          <span class="portfolio-section__hint">policies firing &gt; 2&sigma; above 7-day baseline</span>
        </div>
        <div class="portfolio-anomalies{{#if anomalies}} portfolio-anomalies--alert{{/if}}">
          {{#if anomalies}}
            <ul class="portfolio-anomalies__list">
              {{#each anomalies}}
                <li>
                  <a class="portfolio-anomaly" href="{{this.audit_url}}"
                     aria-label="Investigate {{this.policy}} {{this.decision}} anomaly in audit trail">
                    <div class="portfolio-anomaly__main">
                      <span class="portfolio-anomaly__title">
                        <code>{{this.policy}}</code> &middot; {{this.decision}}
                      </span>
                      <span class="portfolio-anomaly__meta">
                        {{this.window_count}} hits &middot;
                        {{this.affected_user_count}} user{{#unless (eq this.affected_user_count 1)}}s{{/unless}} &middot;
                        {{this.affected_agent_count}} agent{{#unless (eq this.affected_agent_count 1)}}s{{/unless}} &middot;
                        baseline {{this.baseline_mean_display}}/day
                      </span>
                    </div>
                    <span class="portfolio-anomaly__zscore" title="z-score">
                      {{this.z_score_display}}&sigma;
                    </span>
                    <span class="portfolio-anomaly__chevron" aria-hidden="true">&rsaquo;</span>
                  </a>
                </li>
              {{/each}}
            </ul>
          {{else}}
            <div class="portfolio-anomalies__empty">
              No anomalies detected. All policies firing within expected ranges.
            </div>
          {{/if}}
        </div>
      </section>

      {{!-- Stacked-area chart --}}
      <section aria-labelledby="portfolio-chart-title">
        <div class="portfolio-section__header">
          <h2 class="portfolio-section__title" id="portfolio-chart-title">Decisions over time</h2>
          <span class="portfolio-section__hint">{{chart_bucket_count}} buckets across the selected range</span>
        </div>
        <div class="portfolio-chart">
          <div class="portfolio-chart__legend" aria-hidden="true">
            <span class="portfolio-chart__legend-item">
              <span class="portfolio-chart__legend-swatch portfolio-chart__legend-swatch--allow"></span>
              Allow
            </span>
            <span class="portfolio-chart__legend-item">
              <span class="portfolio-chart__legend-swatch portfolio-chart__legend-swatch--deny"></span>
              Deny
            </span>
          </div>
          {{#if has_chart_data}}
            <canvas id="portfolio-area-canvas" class="portfolio-chart__canvas"
                    role="img" aria-label="Stacked area chart of allow vs deny decisions over time"></canvas>
            <script type="application/json" id="portfolio-area-data">{{{chart_data_json}}}</script>
          {{else}}
            <div class="portfolio-chart__empty">No decisions in this range.</div>
          {{/if}}
        </div>
      </section>

      {{!-- Side-by-side ranked lists --}}
      <section aria-labelledby="portfolio-rankings-title" class="portfolio-rankings-section">
        <div class="portfolio-section__header">
          <h2 class="portfolio-section__title" id="portfolio-rankings-title">Top denies</h2>
          <span class="portfolio-section__hint">click any row to filter the audit trail</span>
        </div>
        <div class="portfolio-rankings">
          <div class="portfolio-ranking" aria-labelledby="ranking-tools-title">
            <div class="portfolio-section__header">
              <h3 class="portfolio-section__title" id="ranking-tools-title">By tool</h3>
            </div>
            {{#if top_denies_by_tool}}
              <ul class="portfolio-ranking__list">
                {{#each top_denies_by_tool}}
                  <li>
                    <a class="portfolio-ranking__row" href="{{this.audit_url}}"
                       aria-label="Filter audit trail to tool {{this.label}} denies">
                      <span class="portfolio-ranking__bar"
                            style="transform: scaleX({{this.bar_scale}})"></span>
                      <span class="portfolio-ranking__label">
                        <code>{{this.label}}</code>
                      </span>
                      <span class="portfolio-ranking__count">{{this.deny_count}}</span>
                    </a>
                  </li>
                {{/each}}
              </ul>
            {{else}}
              <div class="portfolio-ranking__empty">No denies in this range.</div>
            {{/if}}
          </div>
          <div class="portfolio-ranking" aria-labelledby="ranking-scopes-title">
            <div class="portfolio-section__header">
              <h3 class="portfolio-section__title" id="ranking-scopes-title">By agent scope</h3>
            </div>
            {{#if top_denies_by_scope}}
              <ul class="portfolio-ranking__list">
                {{#each top_denies_by_scope}}
                  <li>
                    <a class="portfolio-ranking__row" href="{{this.audit_url}}"
                       aria-label="Filter audit trail to scope {{this.label}} denies">
                      <span class="portfolio-ranking__bar"
                            style="transform: scaleX({{this.bar_scale}})"></span>
                      <span class="portfolio-ranking__label">{{this.label}}</span>
                      <span class="portfolio-ranking__count">{{this.deny_count}}</span>
                    </a>
                  </li>
                {{/each}}
              </ul>
            {{else}}
              <div class="portfolio-ranking__empty">No denies in this range.</div>
            {{/if}}
          </div>
        </div>
      </section>

    </div>
    {{/inline}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
