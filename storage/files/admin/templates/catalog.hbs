{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title subtitle="Read-only view of all skills, plugins, MCP servers, and agents loaded from services/*.yaml. Edit YAML on disk and restart to change."}}

    <div class="toolbar" role="toolbar" aria-label="Catalog filters">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search catalog…" id="catalog-search" aria-label="Search catalog">
        </div>
        <div class="filter-chips" role="group" aria-label="Filter by type">
            <button type="button" class="chip active" data-filter="all">All ({{total}})</button>
            <button type="button" class="chip" data-filter="skill">Skills ({{skills_count}})</button>
            <button type="button" class="chip" data-filter="plugin">Plugins ({{plugins_count}})</button>
            <button type="button" class="chip" data-filter="mcp_server">MCP servers ({{mcp_servers_count}})</button>
            <button type="button" class="chip" data-filter="agent">Agents ({{agents_count}})</button>
        </div>
    </div>

    {{#if total}}
    {{#> components/data-table}}
        <thead><tr>
            <th>Type</th>
            <th>ID</th>
            <th>Name</th>
            <th>Description</th>
            <th>Enabled</th>
            <th>Source</th>
            <th class="numeric col-numeric">Assignments</th>
            <th class="col-actions"></th>
        </tr></thead>
        <tbody>
        {{#each skills}}
        <tr data-type="skill" data-search="skill {{toLowerCase name}} {{toLowerCase id}} {{toLowerCase source_path}}">
            <td><span class="badge">skill</span></td>
            <td><code class="code-inline">{{id}}</code></td>
            <td>{{name}}</td>
            <td>{{#if description}}{{description}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
            <td>{{#if enabled}}<span class="badge badge-success">enabled</span>{{else}}<span class="badge badge-muted">disabled</span>{{/if}}</td>
            <td><code class="code-inline">{{source_path}}</code></td>
            <td class="numeric col-numeric">{{assignment_count}}</td>
            <td class="col-actions"><a class="btn btn-sm btn-outline" href="{{matrix_url}}">Access →</a></td>
        </tr>
        {{/each}}
        {{#each plugins}}
        <tr data-type="plugin" data-search="plugin {{toLowerCase name}} {{toLowerCase id}} {{toLowerCase source_path}}">
            <td><span class="badge">plugin</span></td>
            <td><code class="code-inline">{{id}}</code></td>
            <td>{{name}}</td>
            <td>{{#if description}}{{description}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
            <td>{{#if enabled}}<span class="badge badge-success">enabled</span>{{else}}<span class="badge badge-muted">disabled</span>{{/if}}</td>
            <td><code class="code-inline">{{source_path}}</code></td>
            <td class="numeric col-numeric">{{assignment_count}}</td>
            <td class="col-actions"><a class="btn btn-sm btn-outline" href="{{matrix_url}}">Access →</a></td>
        </tr>
        {{/each}}
        {{#each mcp_servers}}
        <tr data-type="mcp_server" data-search="mcp_server {{toLowerCase name}} {{toLowerCase id}} {{toLowerCase source_path}}">
            <td><span class="badge">mcp server</span></td>
            <td><code class="code-inline">{{id}}</code></td>
            <td>{{name}}</td>
            <td>{{#if description}}{{description}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
            <td>{{#if enabled}}<span class="badge badge-success">enabled</span>{{else}}<span class="badge badge-muted">disabled</span>{{/if}}</td>
            <td><code class="code-inline">{{source_path}}</code></td>
            <td class="numeric col-numeric">{{assignment_count}}</td>
            <td class="col-actions"><a class="btn btn-sm btn-outline" href="{{matrix_url}}">Access →</a></td>
        </tr>
        {{/each}}
        {{#each agents}}
        <tr data-type="agent" data-search="agent {{toLowerCase name}} {{toLowerCase id}} {{toLowerCase source_path}}">
            <td><span class="badge">agent</span></td>
            <td><code class="code-inline">{{id}}</code></td>
            <td>{{name}}</td>
            <td>{{#if description}}{{description}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
            <td>{{#if enabled}}<span class="badge badge-success">enabled</span>{{else}}<span class="badge badge-muted">disabled</span>{{/if}}</td>
            <td><code class="code-inline">{{source_path}}</code></td>
            <td class="numeric col-numeric">{{assignment_count}}</td>
            <td class="col-actions"><a class="btn btn-sm btn-outline" href="{{matrix_url}}">Access →</a></td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    <div class="empty-state" style="padding:3rem;text-align:center;">
        <h3>Catalog is empty</h3>
        <p class="text-muted">No skills, plugins, MCP servers, or agents are configured. Add YAML under <code>services/</code> and restart.</p>
    </div>
    {{/if}}

    <script>
    (function(){
      const search = document.getElementById('catalog-search');
      const chips = document.querySelectorAll('.filter-chips .chip');
      let currentFilter = 'all';
      function apply(){
        const q = (search?.value || '').toLowerCase();
        document.querySelectorAll('tr[data-type]').forEach(function(row){
          const t = row.getAttribute('data-type');
          const s = row.getAttribute('data-search') || '';
          const okType = currentFilter === 'all' || currentFilter === t;
          const okSearch = !q || s.includes(q);
          row.style.display = okType && okSearch ? '' : 'none';
        });
      }
      search?.addEventListener('input', apply);
      chips.forEach(function(c){
        c.addEventListener('click', function(){
          chips.forEach(function(x){ x.classList.remove('active'); });
          c.classList.add('active');
          currentFilter = c.getAttribute('data-filter');
          apply();
        });
      });
    })();
    </script>
    {{/inline}}
{{/layout}}
