{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/page-hero}}

    {{> components/toolbar searchId="job-search" searchPlaceholder="Search jobs..."}}
    <section aria-label="Background jobs">
    {{#if jobs}}
    {{#> components/data-table}}
        <thead><tr><th class="col-multiline">Job</th><th class="col-multiline">Schedule</th><th class="col-status">Enabled</th><th class="col-date">Last Run</th><th class="col-status">Status</th><th class="col-date">Next Run</th><th class="numeric">Runs</th></tr></thead>
        <tbody>
        {{#each jobs}}
        <tr data-name="{{toLowerCase job_name}}">
            <td class="col-multiline cell-primary" style="font-family: var(--sp-font-mono);">{{#> components/table-cell-stacked primary=job_name secondary=schedule}}{{/components/table-cell-stacked}}</td>
            <td><code class="code-inline">{{schedule}}</code></td>
            <td class="col-status">{{#if enabled}}<span class="badge badge-success">Enabled</span>{{else}}<span class="badge badge-secondary">Disabled</span>{{/if}}</td>
            <td class="col-date">{{#if last_run}}{{#> components/table-cell-stacked primary=(relativeTime last_run) secondary=(formatDate last_run)}}{{/components/table-cell-stacked}}{{else}}Never{{/if}}</td>
            <td class="col-status"{{#if last_error}} title="{{last_error}}"{{/if}}>
                {{#if (eq last_status "success")}}<span class="badge badge-success">Success</span>
                {{else if (eq last_status "failed")}}<span class="badge badge-danger">Failed</span>
                {{else if (eq last_status "running")}}<span class="badge badge-info">Running</span>
                {{else if last_status}}<span class="badge badge-secondary">{{last_status}}</span>
                {{else}}<span class="badge badge-secondary">Never run</span>
                {{/if}}
            </td>
            <td class="col-date">{{#if next_run}}{{#> components/table-cell-stacked primary=(relativeTime next_run) secondary=(formatDate next_run)}}{{/components/table-cell-stacked}}{{else}}&mdash;{{/if}}</td>
            <td class="numeric" style="font-variant-numeric: tabular-nums;">{{run_count}}</td>
        </tr>
        {{/each}}
        </tbody>
    {{/components/data-table}}
    {{else}}
    {{> components/empty-state message="No jobs found."}}
    {{/if}}
    </section>
    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-jobs.js" defer></script>
    {{/inline}}
{{/layout}}
