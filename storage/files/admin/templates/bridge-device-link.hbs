<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <title>{{branding.domain}} — Authorise device</title>
    <link rel="stylesheet" href="/css/core/fonts.css?v={{css_version}}">
    <link rel="stylesheet" href="/css/admin-bundle.css?v={{css_version}}">
</head>
<body>
    <div class="login-container">
        <div class="card">
            <div class="login-logo"><img src="/files/images/logo.svg" alt="{{branding.domain}}" height="40"></div>
            <h1 class="text-xl mb-2">Authorise a device</h1>
            <p class="text-sm text-tertiary mb-3">
                A local helper at <strong class="text-primary">{{redirect_host}}</strong> is asking to sign in as
                <strong class="text-primary">{{user_email}}</strong>.
            </p>
            <p class="text-sm text-tertiary mb-4">
                Only approve if you started <code>sp-cowork-auth</code> yourself on this machine. The helper will receive a one-time code (valid for 120&nbsp;seconds) and exchange it for a short-lived JWT.
            </p>

            <div class="form-actions" style="display: flex; gap: 0.75rem;">
                <form method="POST" action="/cowork-auth/device-link/approve" style="flex: 1;">
                    <input type="hidden" name="redirect" value="{{redirect}}">
                    <button type="submit" class="btn btn-primary w-full">Allow</button>
                </form>
                <form method="POST" action="/cowork-auth/device-link/deny" style="flex: 1;">
                    <input type="hidden" name="redirect" value="{{redirect}}">
                    <button type="submit" class="btn btn-secondary w-full">Deny</button>
                </form>
            </div>

            <p class="text-xs text-tertiary mt-3" style="text-align: center;">
                Didn't start this? Click Deny and review your active sessions in
                <a href="/admin/devices">Devices</a>.
            </p>
        </div>
    </div>
</body>
</html>
