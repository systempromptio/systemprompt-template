{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}

    {{#if has_session}}
    <div class="metric-ribbon">
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{summary.total_events}}</span>
            <span class="metric-ribbon-label">Events</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-info">
            <span class="metric-ribbon-value">{{summary.tool_uses}}</span>
            <span class="metric-ribbon-label">Tool Uses</span>
        </div>
        <div class="metric-ribbon-item metric-ribbon-success">
            <span class="metric-ribbon-value">{{summary.prompts}}</span>
            <span class="metric-ribbon-label">Prompts</span>
        </div>
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{summary.governance_decisions}}</span>
            <span class="metric-ribbon-label">Governance</span>
        </div>
        {{#if summary.errors}}
        <div class="metric-ribbon-item metric-ribbon-danger">
            <span class="metric-ribbon-value">{{summary.errors}}</span>
            <span class="metric-ribbon-label">Errors</span>
        </div>
        {{/if}}
        <div class="metric-ribbon-item">
            <span class="metric-ribbon-value">{{summary.duration_ms}}ms</span>
            <span class="metric-ribbon-label">Duration</span>
        </div>
    </div>

    <div class="trace-session-id" style="margin-bottom: var(--space-4); font-size: var(--text-sm); color: var(--color-text-tertiary);">
        Session: <code class="code-inline">{{session_id}}</code>
    </div>

    {{#if has_entities}}
    <div class="trace-entities" style="margin-bottom: var(--space-6);">
        <h3 style="font-size: var(--text-base); margin-bottom: var(--space-2);">Entities Used</h3>
        <div style="display: flex; flex-wrap: wrap; gap: var(--space-2);">
            {{#each entities}}
            <span class="mcp-badge {{badge_class}}">{{entity_type}}: {{entity_name}} ({{usage_count}})</span>
            {{/each}}
        </div>
    </div>
    {{/if}}

    {{#if has_governance}}
    <div class="trace-governance" style="margin-bottom: var(--space-6);">
        <h3 style="font-size: var(--text-base); margin-bottom: var(--space-2);">Governance Decisions</h3>
        {{#> components/data-table}}
            <thead><tr>
                <th>Tool</th>
                <th class="col-status">Decision</th>
                <th>Policy</th>
                <th class="col-multiline">Reason</th>
                <th>Scope</th>
                <th class="col-date">Time</th>
            </tr></thead>
            <tbody>
            {{#each governance}}
            <tr>
                <td><code class="code-inline">{{tool_name}}</code></td>
                <td class="col-status">
                    {{#if is_denied}}
                        {{#if is_secret_breach}}
                            <span class="mcp-badge mcp-badge-danger">SECRET BREACH</span>
                        {{else}}
                            <span class="mcp-badge mcp-badge-danger">DENIED</span>
                        {{/if}}
                    {{else}}
                        <span class="mcp-badge mcp-badge-success">ALLOWED</span>
                    {{/if}}
                </td>
                <td><code class="code-inline">{{policy}}</code></td>
                <td class="col-multiline" title="{{reason}}">{{truncate reason 60}}</td>
                <td>
                    {{#if agent_scope}}
                    <span class="badge {{#if (eq agent_scope "admin")}}badge-purple{{else}}badge-blue{{/if}}">{{agent_scope}}</span>
                    {{/if}}
                </td>
                <td class="col-date text-sm text-tertiary">{{created_at}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
    </div>
    {{/if}}

    {{#if has_ai_conversations}}
    <div class="trace-ai-conversations" style="margin-bottom: var(--space-6);">
        <h3 style="font-size: var(--text-base); margin-bottom: var(--space-3);">AI Conversations ({{summary.ai_calls}})</h3>
        {{#each ai_conversations}}
        <details class="ai-call" style="margin-bottom: var(--space-4); border: 1px solid var(--color-border); border-radius: var(--radius-md); padding: var(--space-3); background: var(--color-bg-secondary);">
            <summary style="cursor: pointer; display: flex; flex-wrap: wrap; gap: var(--space-3); align-items: center;">
                <span style="font-weight: 600;">#{{index}}</span>
                <span class="mcp-badge {{status_badge_class}}">{{status}}</span>
                <code class="code-inline">{{provider}}/{{model}}</code>
                <span class="text-sm text-tertiary">{{created_at}}</span>
                {{#if latency_ms}}<span class="text-sm text-tertiary">{{latency_ms}}ms</span>{{/if}}
                <span class="text-sm text-tertiary">{{total_tokens}} tok (in {{input_tokens}} / out {{output_tokens}})</span>
                <span class="text-sm text-tertiary">{{cost_display}}</span>
                <span class="text-sm text-tertiary">{{message_count}} msgs · {{tool_call_count}} tools</span>
                {{#if trace_id_short}}<span class="text-sm text-tertiary">trace <code class="code-inline">{{trace_id_short}}</code></span>{{/if}}
            </summary>
            <div style="margin-top: var(--space-3);">
                {{#if message_count}}
                <h4 style="font-size: var(--text-sm); margin: var(--space-3) 0 var(--space-2);">Messages</h4>
                <div class="ai-messages" style="display: flex; flex-direction: column; gap: var(--space-2);">
                    {{#each messages}}
                    <div class="ai-message" style="border-left: 3px solid var(--color-border); padding: var(--space-2) var(--space-3);">
                        <div style="display: flex; gap: var(--space-2); align-items: center; margin-bottom: var(--space-1);">
                            <span class="mcp-badge {{role_badge_class}}">{{role}}</span>
                            <span class="text-sm text-tertiary">#{{sequence_number}} · {{content_length}} chars</span>
                        </div>
                        <pre style="font-size: var(--text-xs); white-space: pre-wrap; word-break: break-word; max-height: 240px; overflow: auto; margin: 0; padding: var(--space-2); background: var(--color-bg-primary); border-radius: var(--radius-sm);">{{content_preview}}{{#if is_truncated}}

… [truncated]{{/if}}</pre>
                    </div>
                    {{/each}}
                </div>
                {{/if}}
                {{#if tool_call_count}}
                <h4 style="font-size: var(--text-sm); margin: var(--space-4) 0 var(--space-2);">Tool Calls</h4>
                <div class="ai-tool-calls" style="display: flex; flex-direction: column; gap: var(--space-2);">
                    {{#each tool_calls}}
                    <div class="ai-tool-call" style="border-left: 3px solid var(--color-accent); padding: var(--space-2) var(--space-3);">
                        <div style="display: flex; gap: var(--space-2); align-items: center; margin-bottom: var(--space-1);">
                            <span class="mcp-badge mcp-badge-info">{{tool_name}}</span>
                            <span class="text-sm text-tertiary">#{{sequence_number}}{{#if mcp_execution_id}} · exec <code class="code-inline">{{mcp_execution_id}}</code>{{/if}}</span>
                        </div>
                        <pre style="font-size: var(--text-xs); white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow: auto; margin: 0; padding: var(--space-2); background: var(--color-bg-primary); border-radius: var(--radius-sm);">{{tool_input_preview}}{{#if is_input_truncated}}

… [truncated]{{/if}}</pre>
                        {{#if has_result}}
                        <div class="text-sm text-tertiary" style="margin-top: var(--space-1);">Result:</div>
                        <pre style="font-size: var(--text-xs); white-space: pre-wrap; word-break: break-word; max-height: 200px; overflow: auto; margin: 0; padding: var(--space-2); background: var(--color-bg-primary); border-radius: var(--radius-sm);">{{json tool_result_payload}}</pre>
                        {{/if}}
                    </div>
                    {{/each}}
                </div>
                {{/if}}
            </div>
        </details>
        {{/each}}
    </div>
    {{/if}}

    {{#if has_events}}
    <div class="trace-timeline">
        <h3 style="font-size: var(--text-base); margin-bottom: var(--space-2);">Event Timeline</h3>
        {{#> components/data-table}}
            <thead><tr>
                <th style="width: 70px;">+ms</th>
                <th class="col-status">Event</th>
                <th>Tool</th>
                <th class="col-date">Time</th>
                <th class="col-actions" style="width: 30px;"></th>
            </tr></thead>
            <tbody>
            {{#each events}}
            <tr data-detail-for="trace-{{id}}" style="cursor: pointer;">
                <td class="text-sm" style="font-variant-numeric: tabular-nums;">
                    {{#if @first}}
                        <span class="text-tertiary">0</span>
                    {{else}}
                        +{{delta_ms}}
                    {{/if}}
                </td>
                <td class="col-status"><span class="mcp-badge {{badge_class}}">{{event_type_short}}</span></td>
                <td>{{#if has_tool}}<code class="code-inline">{{tool_name}}</code>{{/if}}</td>
                <td class="col-date text-sm text-tertiary">{{created_at}}</td>
                <td class="col-actions text-sm text-tertiary">{{#if has_metadata}}<span class="expand-indicator">+</span>{{/if}}</td>
            </tr>
            {{#if has_metadata}}
            <tr class="detail-row" id="trace-{{id}}" style="display: none;">
                <td colspan="5">
                    <pre style="font-size: var(--text-xs); max-height: 200px; overflow: auto; margin: 0; padding: var(--space-2); background: var(--color-bg-secondary); border-radius: var(--radius-sm);">{{json metadata}}</pre>
                </td>
            </tr>
            {{/if}}
            {{/each}}
            </tbody>
        {{/components/data-table}}
    </div>
    {{else}}
    {{> components/empty-state message="No events found for this session."}}
    {{/if}}

    {{else}}

    <div class="trace-empty" style="text-align: center; padding: var(--space-12) var(--space-4);">
        <h2 style="font-size: var(--text-xl); margin-bottom: var(--space-4);">Trace Detail</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: var(--space-6);">
            View a session trace by providing a <code class="code-inline">session_id</code> parameter.
        </p>
        <p style="color: var(--color-text-tertiary); font-size: var(--text-sm);">
            Example: <code class="code-inline">/admin/traces?session_id=abc-123</code>
        </p>
    </div>

    {{/if}}

    {{/inline}}
    {{#*inline "scripts"}}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('tr[data-detail-for]').forEach(function(row) {
                row.addEventListener('click', function() {
                    var id = this.getAttribute('data-detail-for');
                    var detail = document.getElementById(id);
                    if (detail) {
                        var isHidden = detail.style.display === 'none';
                        detail.style.display = isHidden ? '' : 'none';
                        var indicator = this.querySelector('.expand-indicator');
                        if (indicator) indicator.textContent = isHidden ? '-' : '+';
                    }
                });
            });
        });
    </script>
    {{/inline}}
{{/layout}}
