{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    <!-- Toolbar -->
    <div class="toolbar">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search marketplace..." id="my-marketplace-search">
        </div>
        <select class="filter-select" id="my-marketplace-source-filter" style="min-width:140px">
            <option value="">All Sources</option>
            <option value="inherited">Inherited</option>
            <option value="customized">Customized</option>
            <option value="custom">Custom</option>
        </select>
        <select class="filter-select" id="my-marketplace-category-filter" style="min-width:140px">
            <option value="">All Categories</option>
            {{#each categories}}
            <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
    </div>

    <!-- Stats bar -->
    <div class="config-stats" id="stats-my-marketplace">
        <span class="config-stat"><span class="config-stat-dot blue"></span> <span class="config-stat-value">{{stats.total_count}}</span> total plugins</span>
        <span class="config-stat"><span class="config-stat-dot purple"></span> <span class="config-stat-value">{{stats.inherited_count}}</span> inherited</span>
        <span class="config-stat"><span class="config-stat-dot yellow"></span> <span class="config-stat-value">{{stats.customized_count}}</span> customized</span>
        <span class="config-stat"><span class="config-stat-dot green"></span> <span class="config-stat-value">{{stats.custom_count}}</span> custom</span>
    </div>

    {{#if plugins}}
    <div class="table-container">
        <table class="data-table" id="my-marketplace-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Source</th>
                    <th>Resources</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                {{#each plugins}}
                <tr class="clickable-row" data-entity-type="my-marketplace-plugin" data-entity-id="{{plugin_id}}" data-name="{{toLowerCase name}}" data-category="{{category}}" data-source="{{source}}">
                    <td>
                        <div class="cell-primary"><span class="expand-indicator" data-expand-for="{{plugin_id}}">&#9654;</span> {{name}}</div>
                        {{#if description}}<div class="cell-secondary">{{truncate description 80}}</div>{{/if}}
                    </td>
                    <td>
                        {{#if category}}<span class="badge badge-blue">{{category}}</span>{{else}}<span style="color:var(--text-tertiary)">—</span>{{/if}}
                    </td>
                    <td>
                        {{#if (eq source "inherited")}}<span class="badge badge-purple">inherited</span>{{/if}}
                        {{#if (eq source "customized")}}<span class="badge badge-yellow">customized</span>{{/if}}
                        {{#if (eq source "custom")}}<span class="badge badge-green">custom</span>{{/if}}
                    </td>
                    <td>
                        <div class="cell-badges">
                            {{#if (gt skill_count 0)}}<span class="badge badge-green">{{skill_count}} skill{{#if (not (eq skill_count 1))}}s{{/if}}</span>{{/if}}
                            {{#if (gt agent_count 0)}}<span class="badge badge-blue">{{agent_count}} agent{{#if (not (eq agent_count 1))}}s{{/if}}</span>{{/if}}
                            {{#if (gt mcp_count 0)}}<span class="badge badge-yellow">{{mcp_count}} MCP</span>{{/if}}
                            {{#if (gt hook_count 0)}}<span class="badge badge-gray">{{hook_count}} hook{{#if (not (eq hook_count 1))}}s{{/if}}</span>{{/if}}
                        </div>
                    </td>
                    <td class="col-actions" data-no-row-click>
                        {{#if (eq source "inherited")}}
                        <button class="btn btn-secondary btn-sm" data-customize-plugin="{{plugin_id}}">Customize</button>
                        {{else}}
                        <div class="actions-menu" data-actions-for="{{plugin_id}}">
                            <button class="actions-trigger" data-action="menu" title="Actions">&#8942;</button>
                            <div class="actions-dropdown">
                                <a href="/admin/my/plugins/edit/?id={{plugin_id}}" class="actions-item">Edit</a>
                                <div class="actions-popup-separator"></div>
                                <button class="actions-item actions-item-danger" data-delete-plugin="{{plugin_id}}">Delete</button>
                            </div>
                        </div>
                        {{/if}}
                    </td>
                </tr>
                <!-- Detail expand row -->
                <tr class="detail-row" data-detail-for="{{plugin_id}}">
                    <td colspan="5">
                        <div class="detail-row-content">
                            {{#if base_plugin_id}}
                            <div class="detail-section" style="margin-bottom:var(--space-3)">
                                <span style="font-size:var(--text-sm);color:var(--text-secondary)">Forked from: <code style="font-size:var(--text-xs)">{{base_plugin_id}}</code></span>
                            </div>
                            {{/if}}

                            {{#if (gt skill_count 0)}}
                            <div class="detail-section">
                                <strong>Skills ({{skill_count}})</strong>
                                {{#if skills}}
                                <table class="detail-sub-table" style="margin-top:var(--space-2)">
                                    {{#each skills}}
                                    <tr><td>{{name}}</td></tr>
                                    {{/each}}
                                </table>
                                {{/if}}
                            </div>
                            {{/if}}

                            {{#if (gt agent_count 0)}}
                            <div class="detail-section">
                                <strong>Agents ({{agent_count}})</strong>
                                {{#if agents}}
                                <table class="detail-sub-table" style="margin-top:var(--space-2)">
                                    {{#each agents}}
                                    <tr><td>{{name}}</td></tr>
                                    {{/each}}
                                </table>
                                {{/if}}
                            </div>
                            {{/if}}

                            {{#if (gt mcp_count 0)}}
                            <div class="detail-section">
                                <strong>MCP Servers ({{mcp_count}})</strong>
                                {{#if mcp_servers}}
                                <table class="detail-sub-table" style="margin-top:var(--space-2)">
                                    {{#each mcp_servers}}
                                    <tr><td>{{name}}</td></tr>
                                    {{/each}}
                                </table>
                                {{/if}}
                            </div>
                            {{/if}}

                            {{#if (gt hook_count 0)}}
                            <div class="detail-section">
                                <strong>Hooks ({{hook_count}})</strong>
                                {{#if hooks}}
                                <table class="detail-sub-table" style="margin-top:var(--space-2)">
                                    {{#each hooks}}
                                    <tr><td><span class="badge badge-blue">{{event}}</span> <code style="font-size:var(--text-xs)">{{matcher}}</code>{{#if is_async}} <span class="badge badge-gray">async</span>{{/if}}</td></tr>
                                    {{/each}}
                                </table>
                                {{/if}}
                            </div>
                            {{/if}}

                            <!-- JSON view -->
                            <div class="detail-section">
                                <button class="btn btn-secondary btn-sm" data-toggle-json="{{plugin_id}}" style="font-size:var(--text-xs);padding:2px 8px;margin-bottom:var(--space-2)">Show JSON</button>
                                <div class="json-view" data-json-for="{{plugin_id}}" style="display:none"></div>
                            </div>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{else}}
    {{> components/empty-state message="No plugins available in your marketplace."}}
    {{/if}}

    <!-- Hidden plugin detail data -->
    {{#each plugins}}
    <script type="application/json" data-my-marketplace-detail="{{plugin_id}}">
        {{{json this}}}
    </script>
    {{/each}}

    {{/inline}}
    {{#*inline "scripts"}}
    <script src="/js/admin-my-workspace.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AdminApp.Toast.init();
            if (AdminApp.initMyMarketplace) {
                AdminApp.initMyMarketplace();
            }
        });
    </script>
    {{/inline}}
{{/layout}}
