{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}

    <div class="card" style="margin-bottom: 1rem;">
        <nav class="tab-nav" aria-label="Access scope">
            <a href="/admin/access?tab=gateway" class="tab-nav__item{{#if (eq tab "gateway")}} tab-nav__item--active{{/if}}" {{#if (eq tab "gateway")}}aria-current="page"{{/if}}>Gateway Routes</a>
            <a href="/admin/access?tab=mcp" class="tab-nav__item{{#if (eq tab "mcp")}} tab-nav__item--active{{/if}}" {{#if (eq tab "mcp")}}aria-current="page"{{/if}}>MCP Servers</a>
            <span style="margin-left:auto;">
              <button type="button" class="btn btn-sm btn-outline" id="apply-template-btn">Apply department template</button>
            </span>
        </nav>
        <p class="text-muted" style="font-size: 0.875rem; margin: 0.75rem 0 0;">
            Click any cell to cycle <code class="code-inline">blank → allow → deny → blank</code>.
            Use the column headers to bulk-assign across all rows in this tab.
            {{#if (eq tab "gateway")}}Inline panel: <a href="/admin/gateway">/admin/gateway</a>.{{/if}}
            {{#if (eq tab "mcp")}}Per-server panel available on each MCP detail row.{{/if}}
        </p>
    </div>

    <dialog id="apply-template-dialog" class="dialog">
        <form method="dialog" class="dialog-form">
            <h3>Apply template</h3>
            <p class="text-muted">Bulk-apply a single rule across every {{#if (eq tab "mcp")}}MCP server{{else}}gateway route{{/if}} in this tab.</p>
            <label>Subject type
              <select id="apply-template-subject-type">
                <option value="department">department</option>
                <option value="role">role</option>
                <option value="user">user</option>
              </select>
            </label>
            <label>Subject value
              <input type="text" id="apply-template-subject-value" placeholder="e.g. eng" required>
            </label>
            <label>Action
              <select id="apply-template-action">
                <option value="allow">allow all</option>
                <option value="deny">deny all</option>
                <option value="clear">clear</option>
              </select>
            </label>
            <div id="apply-template-preview" class="text-muted" style="margin-top:.5rem;"></div>
            <menu>
              <button type="button" id="apply-template-cancel" class="btn btn-sm btn-outline">Cancel</button>
              <button type="button" id="apply-template-confirm" class="btn btn-sm btn-primary">Apply</button>
            </menu>
        </form>
    </dialog>

    {{#if row_count}}
    <div class="card" style="padding: 0;">
        <div class="gw-matrix-wrap">
            <table class="gw-matrix" id="gw-matrix" data-entity-type="{{entity_type}}">
                <thead>
                    <tr>
                        <th rowspan="2" class="gw-matrix__route-cell">{{#if (eq tab "mcp")}}Server{{else}}Route{{/if}}</th>
                        <th rowspan="2">{{#if (eq tab "mcp")}}Type{{else}}Provider{{/if}}</th>
                        <th rowspan="2">Default</th>
                        {{#if department_count}}<th class="gw-matrix__group" colspan="{{department_count}}">Departments</th>{{/if}}
                        {{#if role_count}}<th class="gw-matrix__group" colspan="{{role_count}}">Roles</th>{{/if}}
                        {{#if user_count}}<th class="gw-matrix__group" colspan="{{user_count}}">Users</th>{{/if}}
                    </tr>
                    <tr id="gw-matrix-subject-header">
                        {{#each departments}}<th data-subject-kind="department" data-subject-value="{{this}}" title="Bulk-assign all rows">{{this}}<div class="gw-matrix__bulk"><button type="button" class="btn btn-small" data-bulk-kind="department" data-bulk-value="{{this}}" data-bulk-access="allow">Allow all</button><button type="button" class="btn btn-small" data-bulk-kind="department" data-bulk-value="{{this}}" data-bulk-access="deny">Deny all</button></div></th>{{/each}}
                        {{#each roles}}<th data-subject-kind="role" data-subject-value="{{this}}" title="Bulk-assign all rows">{{this}}<div class="gw-matrix__bulk"><button type="button" class="btn btn-small" data-bulk-kind="role" data-bulk-value="{{this}}" data-bulk-access="allow">Allow all</button><button type="button" class="btn btn-small" data-bulk-kind="role" data-bulk-value="{{this}}" data-bulk-access="deny">Deny all</button></div></th>{{/each}}
                        {{#each users}}<th data-subject-kind="user" data-subject-value="{{this}}" title="Bulk-assign all rows">{{this}}<div class="gw-matrix__bulk"><button type="button" class="btn btn-small" data-bulk-kind="user" data-bulk-value="{{this}}" data-bulk-access="allow">Allow all</button><button type="button" class="btn btn-small" data-bulk-kind="user" data-bulk-value="{{this}}" data-bulk-access="deny">Deny all</button></div></th>{{/each}}
                    </tr>
                </thead>
                <tbody>
                    {{#each rows}}
                    <tr data-row-id="{{id}}">
                        <th scope="row" class="gw-matrix__route-cell">
                            <code class="code-inline">{{label}}</code>
                        </th>
                        <td>{{#if sublabel}}{{sublabel}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
                        <td>
                            <input type="checkbox" data-default-toggle="{{id}}" {{#if default_included}}checked{{/if}} />
                        </td>
                        {{#each cells.departments}}<td class="gw-matrix__cell gw-matrix__cell--{{state}}" data-cell="1" data-row-id="{{../id}}" data-kind="department" data-value="{{value}}" data-state="{{state}}" data-rule-id="{{rule_id}}">{{#if (eq state "allow")}}✓{{else if (eq state "deny")}}✕{{else}}·{{/if}}</td>{{/each}}
                        {{#each cells.roles}}<td class="gw-matrix__cell gw-matrix__cell--{{state}}" data-cell="1" data-row-id="{{../id}}" data-kind="role" data-value="{{value}}" data-state="{{state}}" data-rule-id="{{rule_id}}">{{#if (eq state "allow")}}✓{{else if (eq state "deny")}}✕{{else}}·{{/if}}</td>{{/each}}
                        {{#each cells.users}}<td class="gw-matrix__cell gw-matrix__cell--{{state}}" data-cell="1" data-row-id="{{../id}}" data-kind="user" data-value="{{value}}" data-state="{{state}}" data-rule-id="{{rule_id}}">{{#if (eq state "allow")}}✓{{else if (eq state "deny")}}✕{{else}}·{{/if}}</td>{{/each}}
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
    {{else}}
    {{#if (eq tab "mcp")}}
    {{> components/empty-state title="No MCP servers" body="Define MCP servers in services/mcp/*.yaml to manage access here."}}
    {{else}}
    {{> components/empty-state title="No gateway routes" body="Configure routes on /admin/gateway first."}}
    {{/if}}
    {{/if}}
    {{/inline}}

    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module">
        import { initEntityAccessMatrix } from '/js/pages/admin-access-matrix.js';
        initEntityAccessMatrix();
    </script>
    {{/inline}}
{{/layout}}
