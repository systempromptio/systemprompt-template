{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="/admin/access/departments">Departments</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{{department.name}}</span>
    </nav>

    {{> components/page-header title=department.name subtitle=department.description}}

    <section aria-label="Department usage" class="card" style="padding:1.25rem;margin-bottom:1rem;">
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;">
            <div><div class="text-muted" style="font-size:.8rem;">Members</div><div style="font-size:1.5rem;font-weight:600;">{{member_count}}</div></div>
            <div><div class="text-muted" style="font-size:.8rem;">Requests (30d)</div><div style="font-size:1.5rem;font-weight:600;">{{total_requests}}</div></div>
            <div><div class="text-muted" style="font-size:.8rem;">Tokens in (30d)</div><div style="font-size:1.5rem;font-weight:600;">{{total_input_tokens}}</div></div>
            <div><div class="text-muted" style="font-size:.8rem;">Tokens out (30d)</div><div style="font-size:1.5rem;font-weight:600;">{{total_output_tokens}}</div></div>
            <div><div class="text-muted" style="font-size:.8rem;">Cost (30d)</div><div style="font-size:1.5rem;font-weight:600;">{{total_cost_microdollars}} µ$</div></div>
        </div>
    </section>

    <section aria-label="Permission matrix" class="card" style="padding:1.25rem;margin-bottom:1rem;">
        <h2 style="margin-top:0;">Permission matrix</h2>
        <p>Skills, marketplaces, plugins, MCP servers, and gateway routes assigned to <strong>{{department.name}}</strong>. Members inherit everything assigned here. Direct user-level overrides take precedence.</p>
        <p>
            <a class="btn btn-primary" href="{{assignments_url}}">Open access matrix filtered to this department →</a>
        </p>
        <p class="text-muted" style="font-size:.875rem;">
            Stored in <code>access_control_rules</code> with <code>rule_type='department'</code> and <code>rule_value='{{department.name}}'</code>. Renaming this department updates those rules automatically.
        </p>
    </section>

    {{#if top_tools}}
    <section aria-label="Top tools" class="card" style="padding:1.25rem;margin-bottom:1rem;">
        <h2 style="margin-top:0;">Top tools (30d)</h2>
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
            {{#each top_tools}}
            <span class="badge badge-blue">{{tool_name}} · {{invocations}}</span>
            {{/each}}
        </div>
    </section>
    {{/if}}

    <section aria-label="Department members">
        <div class="toolbar">
            <div class="search-group">
                <input type="text" class="search-input" placeholder="Search members..." id="member-search">
            </div>
            <button type="button" class="btn btn-primary" id="btn-add-member">+ Add member</button>
        </div>
        {{#if members}}
        {{#> components/data-table}}
            <thead><tr>
                <th>Email</th>
                <th>Display name</th>
                <th>Status</th>
                <th class="numeric col-numeric">Requests (30d)</th>
                <th class="numeric col-numeric">Tokens (30d)</th>
                <th class="numeric col-numeric">Cost (30d)</th>
                <th>Last active</th>
                <th class="col-actions"></th>
            </tr></thead>
            <tbody>
            {{#each members}}
            <tr data-member-email="{{toLowerCase email}}">
                <td><a href="/admin/access/user?id={{id}}">{{email}}</a></td>
                <td>{{#if display_name}}{{display_name}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
                <td><span class="badge {{#if (eq status "active")}}badge-green{{else}}badge-gray{{/if}}">{{status}}</span></td>
                <td class="numeric col-numeric">{{requests}}</td>
                <td class="numeric col-numeric">{{add input_tokens output_tokens}}</td>
                <td class="numeric col-numeric">{{cost_microdollars}} µ$</td>
                <td>{{#if last_active}}{{relativeTime last_active}}{{else}}<span class="text-tertiary">—</span>{{/if}}</td>
                <td class="col-actions">
                    <button type="button" class="btn btn-sm btn-outline" data-unassign-user="{{id}}">Move to Default</button>
                </td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        <div class="empty-state" style="padding:2rem;text-align:center;">
            <p class="text-muted">No members in this department yet.</p>
            <button type="button" class="btn btn-primary" id="btn-add-member-empty">+ Add member</button>
        </div>
        {{/if}}
    </section>

    <dialog id="member-add-dialog" class="dialog">
        <form id="member-add-form" class="dialog-form">
            <h3>Add member to {{department.name}}</h3>
            <label>User ID<input type="text" name="user_id" required placeholder="usr_…"></label>
            <p class="text-muted" style="font-size:.875rem;">The user's <code>users.department</code> field will be set to <code>{{department.name}}</code>.</p>
            <menu>
                <button type="button" class="btn btn-sm btn-outline" id="member-add-cancel">Cancel</button>
                <button type="submit" class="btn btn-sm btn-primary">Add</button>
            </menu>
            <p id="member-add-error" class="text-danger" style="display:none;"></p>
        </form>
    </dialog>

    {{#unless (eq department.name "Default")}}
    <section aria-label="Department settings" style="margin-top:2rem;">
        <form id="dept-settings-form" class="card" style="padding:1.5rem;max-width:560px;">
            <h2 style="margin-top:0;">Settings</h2>
            <label>Name<input type="text" name="name" value="{{department.name}}" required></label>
            <label>Description<textarea name="description" rows="3">{{department.description}}</textarea></label>
            <div style="display:flex;gap:.5rem;margin-top:1rem;">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-danger" id="dept-delete-btn">Delete department</button>
            </div>
            <p id="dept-settings-msg" class="text-muted" style="margin-top:.75rem;display:none;"></p>
        </form>
    </section>
    {{/unless}}

    <script>
    (function() {
        const deptId = "{{department.id}}";
        const deptName = "{{department.name}}";

        const addDlg = document.getElementById('member-add-dialog');
        const addOpen = () => { document.getElementById('member-add-error').style.display = 'none'; addDlg?.showModal(); };
        document.getElementById('btn-add-member')?.addEventListener('click', addOpen);
        document.getElementById('btn-add-member-empty')?.addEventListener('click', addOpen);
        document.getElementById('member-add-cancel')?.addEventListener('click', () => addDlg.close());
        document.getElementById('member-add-form')?.addEventListener('submit', async (ev) => {
            ev.preventDefault();
            const fd = new FormData(ev.target);
            const userId = String(fd.get('user_id') || '').trim();
            if (!userId) return;
            const errEl = document.getElementById('member-add-error');
            const res = await fetch('/admin/management/users/' + encodeURIComponent(userId) + '/department', {
                method: 'PUT',
                headers: {'content-type': 'application/json'},
                body: JSON.stringify({ department_name: deptName }),
            });
            if (res.ok) { location.reload(); return; }
            errEl.textContent = await res.text();
            errEl.style.display = 'block';
        });
        document.querySelectorAll('[data-unassign-user]').forEach(btn => {
            btn.addEventListener('click', async () => {
                const uid = btn.getAttribute('data-unassign-user');
                if (!confirm('Move this user back to "Default"?')) return;
                const res = await fetch('/admin/management/users/' + encodeURIComponent(uid) + '/department', {
                    method: 'PUT',
                    headers: {'content-type': 'application/json'},
                    body: JSON.stringify({ department_name: 'Default' }),
                });
                if (res.ok) location.reload();
                else alert('Failed: ' + await res.text());
            });
        });

        document.getElementById('dept-settings-form')?.addEventListener('submit', async (ev) => {
            ev.preventDefault();
            const fd = new FormData(ev.target);
            const body = {
                name: fd.get('name'),
                description: fd.get('description') || '',
            };
            const res = await fetch('/admin/management/departments/' + deptId, {
                method: 'PUT',
                headers: {'content-type': 'application/json'},
                body: JSON.stringify(body),
            });
            const msg = document.getElementById('dept-settings-msg');
            msg.style.display = 'block';
            if (res.ok) { msg.textContent = 'Saved.'; setTimeout(() => location.reload(), 600); }
            else { msg.textContent = 'Save failed: ' + await res.text(); }
        });
        document.getElementById('dept-delete-btn')?.addEventListener('click', async () => {
            if (!confirm('Delete "' + deptName + '"? Members will be reassigned to "Default" and department-level access rules removed.')) return;
            const res = await fetch('/admin/management/departments/' + deptId, { method: 'DELETE' });
            if (res.ok) location = '/admin/access/departments';
            else alert('Delete failed: ' + await res.text());
        });

        document.getElementById('member-search')?.addEventListener('input', (ev) => {
            const q = ev.target.value.toLowerCase();
            document.querySelectorAll('[data-member-email]').forEach(row => {
                row.style.display = !q || row.getAttribute('data-member-email').includes(q) ? '' : 'none';
            });
        });
    })();
    </script>
    {{/inline}}
{{/layout}}
