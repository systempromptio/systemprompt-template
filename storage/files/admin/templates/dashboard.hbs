{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}

    <div class="gf-grid">

        {{! ============= AI USAGE & COST (12) ============= }}
        {{#> components/panel title="AI usage & cost" href="/admin/analytics/requests" span="12"}}
            <div class="usage-chart-container">
                <div class="usage-chart-header">
                    <div class="chart-range-tabs">
                        <a href="?range=24h" class="chart-range-tab {{#if range_24h}}active{{/if}}">24h</a>
                        <a href="?range=7d" class="chart-range-tab {{#if range_7d}}active{{/if}}">7d</a>
                        <a href="?range=14d" class="chart-range-tab {{#if range_14d}}active{{/if}}">14d</a>
                    </div>
                    <div class="usage-chart-legend">
                        <span class="legend-item legend-sessions">Logins</span>
                        <span class="legend-item legend-active-users">Active Users</span>
                        <span class="legend-item legend-prompts">Edits</span>
                        <span class="legend-item legend-tools">MCP Calls</span>
                        <span class="legend-item legend-errors">MCP Errors</span>
                    </div>
                    <div class="usage-chart-peak">Peak: {{chart.peak}}</div>
                </div>
                {{#if chart.has_data}}
                <div class="usage-chart-body">
                    <svg viewBox="0 0 960 280" preserveAspectRatio="none" class="usage-svg" role="img" aria-labelledby="chart-title-ai-usage">
                        <title id="chart-title-ai-usage">AI usage metrics over time showing logins, active users, edits, MCP calls, and errors</title>
                        <defs>
                            <linearGradient id="grad-sessions" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--sp-chart-purple, #8B5CF6)" stop-opacity="0.7"/>
                                <stop offset="100%" stop-color="var(--sp-chart-purple, #8B5CF6)" stop-opacity="0.08"/>
                            </linearGradient>
                            <linearGradient id="grad-active-users" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--sp-chart-green, #10B981)" stop-opacity="0.7"/>
                                <stop offset="100%" stop-color="var(--sp-chart-green, #10B981)" stop-opacity="0.08"/>
                            </linearGradient>
                            <linearGradient id="grad-prompts" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--sp-chart-blue, #3B82F6)" stop-opacity="0.7"/>
                                <stop offset="100%" stop-color="var(--sp-chart-blue, #3B82F6)" stop-opacity="0.08"/>
                            </linearGradient>
                            <linearGradient id="grad-tools" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--sp-chart-indigo, #6B68FA)" stop-opacity="0.7"/>
                                <stop offset="100%" stop-color="var(--sp-chart-indigo, #6B68FA)" stop-opacity="0.08"/>
                            </linearGradient>
                            <linearGradient id="grad-errors" x1="0" y1="0" x2="0" y2="1">
                                <stop offset="0%" stop-color="var(--sp-chart-red, #EF4444)" stop-opacity="0.7"/>
                                <stop offset="100%" stop-color="var(--sp-chart-red, #EF4444)" stop-opacity="0.08"/>
                            </linearGradient>
                            <filter id="glow">
                                <feGaussianBlur stdDeviation="3" result="blur"/>
                                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
                            </filter>
                        </defs>
                        {{#each chart.y_labels}}
                        <line x1="40" y1="{{this.y}}" x2="960" y2="{{this.y}}" class="chart-grid-line" stroke-width="1"/>
                        <text x="36" y="{{this.y}}" class="chart-axis-label" text-anchor="end" dominant-baseline="middle">{{this.label}}</text>
                        {{/each}}
                        <path d="{{chart.paths.sessions}}" fill="url(#grad-sessions)" class="area-path area-sessions"/>
                        <path d="{{chart.paths.active_users}}" fill="url(#grad-active-users)" class="area-path area-active-users"/>
                        <path d="{{chart.paths.prompts}}" fill="url(#grad-prompts)" class="area-path area-prompts"/>
                        <path d="{{chart.paths.tools}}" fill="url(#grad-tools)" class="area-path area-tools"/>
                        <path d="{{chart.paths.errors}}" fill="url(#grad-errors)" class="area-path area-errors"/>
                        <path d="{{chart.paths.top_line}}" fill="none" stroke="var(--sp-accent)" stroke-width="2" filter="url(#glow)" class="line-path line-top"/>
                    </svg>
                    <div class="usage-chart-x-axis">
                        {{#each chart.x_labels}}
                        <span>{{this}}</span>
                        {{/each}}
                    </div>
                </div>
                {{else}}
                <div class="usage-chart-body usage-chart-empty">
                    <p>No activity data for this time range.</p>
                </div>
                {{/if}}
            </div>
            {{#if has_cost_kpis}}
            <div class="metric-ribbon" style="margin-top: var(--space-4);">
                <div class="metric-ribbon-item">
                    <span class="metric-ribbon-value">${{cost_kpis.total_cost_usd}}</span>
                    <span class="metric-ribbon-label">Cost (30d)</span>
                </div>
                <div class="metric-ribbon-item">
                    <span class="metric-ribbon-value">{{cost_kpis.requests}}</span>
                    <span class="metric-ribbon-label">AI Requests (30d)</span>
                </div>
                <div class="metric-ribbon-item">
                    <span class="metric-ribbon-value">{{cost_kpis.total_tokens}}</span>
                    <span class="metric-ribbon-label">Total Tokens (30d)</span>
                </div>
                <div class="metric-ribbon-item">
                    <span class="metric-ribbon-value">{{cost_kpis.tokens_per_min}}/min</span>
                    <span class="metric-ribbon-label">Token Throughput</span>
                </div>
            </div>
            {{/if}}
        {{/components/panel}}

        {{! ============= SERVICES (12) ============= }}
        {{#> components/panel title="Services" href="/admin/infra/services" span="12"}}
            {{#if has_services}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th class="col-status">Status</th>
                    <th class="col-numeric">Calls (24h)</th>
                </tr></thead>
                <tbody>
                {{#each services}}
                <tr>
                    <td><strong>{{name}}</strong></td>
                    <td><code class="code-inline">{{service_type}}</code></td>
                    <td class="col-status">
                        {{#if enabled}}
                        <span class="mcp-badge mcp-badge-success">Running</span>
                        {{else}}
                        <span class="mcp-badge">Disabled</span>
                        {{/if}}
                    </td>
                    <td class="col-numeric numeric">{{calls_24h}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No services configured."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= ACTION QUEUE (6) ============= }}
        {{#> components/panel title="Action queue" href="/admin/governance/decisions" span="6"}}
            {{#if has_governance_action_queue}}
            <div class="action-queue-list">
                {{#each governance_action_queue}}
                <a class="feed-item action-queue-item action-queue-item--{{severity}}" href="{{link}}">
                    <div class="feed-icon {{#if (eq severity "danger")}}feed-orange{{else if (eq severity "warning")}}feed-gold{{else}}feed-blue{{/if}}"></div>
                    <div class="feed-content">
                        <span class="feed-text">{{label}}</span>
                    </div>
                    <span class="action-queue-chevron" aria-hidden="true">&rsaquo;</span>
                </a>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No action items."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= QUICK STATS (6) ============= }}
        {{#> components/panel title="Quick stats" href="/admin/analytics" span="6"}}
            <div class="quick-stats-grid">
                <div class="quick-stat-card">
                    <div class="quick-stat-label">Total Users</div>
                    <div class="quick-stat-value">{{total_users}}</div>
                </div>
                <div class="quick-stat-card">
                    <div class="quick-stat-label">Active Users (24h)</div>
                    <div class="quick-stat-value">{{active_users_24h}}</div>
                </div>
                <div class="quick-stat-card">
                    <div class="quick-stat-label">MCP Error Rate</div>
                    <div class="quick-stat-value {{#if stats.mcp_errors}}text-danger{{else}}text-success{{/if}}">{{error_rate_pct}}%</div>
                </div>
                <div class="quick-stat-card">
                    <div class="quick-stat-label">Events This Week</div>
                    <div class="quick-stat-value">{{stats.events_this_week}}</div>
                </div>
            </div>
        {{/components/panel}}

        {{! ============= TOP ACTORS (6) ============= }}
        {{#> components/panel title="Top actors (24h denials)" href="/admin/governance/decisions" span="6"}}
            {{#if has_governance_top_actors}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>Actor</th>
                    <th class="col-numeric">Denials</th>
                    <th class="col-numeric">Secret</th>
                    <th class="col-numeric">Total</th>
                </tr></thead>
                <tbody>
                {{#each governance_top_actors}}
                <tr{{#if is_secret_offender}} class="row-danger"{{/if}}>
                    <td>
                        <div class="user-cell">
                            <div class="user-avatar">{{initials display_name}}</div>
                            <div class="user-info">
                                <a href="/admin/user?id={{user_id}}" class="user-name">{{display_name}}</a>
                                {{#if email}}<span class="user-email">{{email}}</span>{{/if}}
                            </div>
                        </div>
                    </td>
                    <td class="col-numeric numeric">{{deny_count}}</td>
                    <td class="col-numeric numeric{{#if is_secret_offender}} text-danger{{/if}}">{{secret_count}}</td>
                    <td class="col-numeric numeric">{{total}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No actor activity in the last 24 hours."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= TOP POLICIES (6) ============= }}
        {{#> components/panel title="Top policies firing (24h)" href="/admin/governance/decisions/portfolio" span="6"}}
            {{#if has_governance_top_policies}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>Policy</th>
                    <th>Tool</th>
                    <th class="col-numeric">Hits</th>
                    <th class="col-numeric">Actors</th>
                </tr></thead>
                <tbody>
                {{#each governance_top_policies}}
                <tr{{#if is_secret_policy}} class="row-danger"{{/if}}>
                    <td><code class="code-inline">{{policy}}</code></td>
                    <td><code class="code-inline">{{tool_name}}</code></td>
                    <td class="col-numeric numeric">{{hits}}</td>
                    <td class="col-numeric numeric">{{distinct_actors}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No policy denials in the last 24 hours."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= LIVE ACTIVITY (6) ============= }}
        {{#> components/panel title="Live activity" href="/admin/events" subtitle="SSE" span="6"}}
            <span class="live-dot" id="sse-indicator" aria-hidden="true"></span>
            {{#if timeline}}
            <div class="live-feed" id="live-feed" aria-live="polite">
                {{#each timeline}}
                <div class="feed-item" data-ts="{{created_at}}">
                    <div class="feed-icon {{#if (eq category "login")}}feed-blue{{else if (eq category "logout")}}feed-cyan{{else if (eq category "marketplace_connect")}}feed-purple{{else if (eq category "marketplace_edit")}}feed-green{{else if (eq category "session")}}feed-indigo{{else if (eq category "session_rated")}}feed-gold{{else if (eq category "user_management")}}feed-teal{{else}}feed-orange{{/if}}"></div>
                    <div class="feed-content">
                        <span class="feed-text"><strong>{{default display_name "Anonymous"}}</strong> {{description}}</span>
                        <span class="feed-time">{{relativeTime created_at}}</span>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No activity recorded yet."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= HOURLY ACTIVITY (6) ============= }}
        {{#> components/panel title="Activity (last 24h)" href="/admin/events" span="6"}}
            {{#if hourly_activity}}
            <div class="mini-chart">
                {{#each hourly_activity}}
                <div class="mini-chart-bar" title="{{hour}}:00: {{count}} events">
                    <div class="mini-chart-fill" style="--fill: {{pct}}%"></div>
                    <div class="mini-chart-label">{{label}}</div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No hourly activity data."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= MCP TOOL USAGE (6) ============= }}
        {{#> components/panel title="MCP tool usage" href="/admin/mcp/tools" span="6"}}
            {{#if popular_skills}}
            <div class="skill-bar-list">
                {{#each popular_skills}}
                <div class="skill-bar-row">
                    <div class="skill-bar-label" title="{{tool_name}}">{{tool_name}}</div>
                    <div class="skill-bar-track">
                        <div class="progress-bar"><div class="progress-fill progress-blue" style="--fill: {{pct}}%"></div></div>
                    </div>
                    <div class="skill-bar-count">{{count}}</div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No MCP tool usage data yet."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= MCP TOOL RELIABILITY (6) ============= }}
        {{#> components/panel title="MCP tool reliability" href="/admin/mcp/tools" span="6"}}
            {{#if tool_success_rates}}
            <div class="skill-bar-list">
                {{#each tool_success_rates}}
                <div class="skill-bar-row">
                    <div class="skill-bar-label">{{tool_name}}</div>
                    <div class="skill-bar-track">
                        <div class="progress-bar"><div class="progress-fill {{color_class}}" style="--fill: {{success_pct}}%"></div></div>
                    </div>
                    <div class="skill-bar-count">{{success_pct}}%</div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No tool reliability data."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= TOP USERS (6) ============= }}
        {{#> components/panel title="Top users" href="/admin/users" span="6"}}
            {{#if top_users}}
            {{#> components/data-table}}
                <thead><tr><th>#</th><th>User</th><th class="col-numeric">Logins</th><th class="col-numeric">Edits</th><th class="col-numeric">MCP Calls</th></tr></thead>
                <tbody>
                {{#each top_users}}
                <tr>
                    <td><span class="leaderboard-rank{{#if (eq @index 0)}} leaderboard-rank-1{{else if (eq @index 1)}} leaderboard-rank-2{{else if (eq @index 2)}} leaderboard-rank-3{{/if}}">{{add @index 1}}</span></td>
                    <td><div class="user-cell"><div class="user-avatar">{{initials (default display_name "A")}}</div><div class="user-info"><span class="user-name">{{default display_name "Anonymous"}}</span></div></div></td>
                    <td class="col-numeric numeric">{{logins}}</td>
                    <td class="col-numeric numeric">{{edits}}</td>
                    <td class="col-numeric numeric">{{mcp_calls}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No user activity yet."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= TOP CONTENT TODAY (6) ============= }}
        {{#> components/panel title="Top content today" href="/admin/analytics/content" span="6"}}
            {{#if top_pages_today}}
            <div class="skill-bar-list">
                {{#each top_pages_today}}
                <div class="skill-bar-row">
                    <div class="skill-bar-label" title="{{page_url}}">{{page_url}}</div>
                    <div class="skill-bar-count">{{events}} views</div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No content traffic today."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= MCP SERVER ACCESS (6) ============= }}
        {{#> components/panel title="MCP server access" href="/admin/mcp/access" span="6"}}
            {{#if has_mcp_access_events}}
            <div class="mcp-access-list">
                {{#each mcp_access_events}}
                <div class="feed-item">
                    <div class="feed-icon {{#if is_granted}}feed-green{{else}}feed-orange{{/if}}"></div>
                    <div class="feed-content">
                        <span class="feed-text"><strong>{{server_name}}</strong>
                            {{#if is_granted}}
                                <span class="mcp-badge mcp-badge-success">Granted</span>
                            {{else}}
                                <span class="mcp-badge mcp-badge-danger">Rejected</span>
                            {{/if}}
                        </span>
                        <span class="feed-time">{{created_at}}</span>
                        {{#if description}}<div class="text-sm text-tertiary">{{truncate description 60}}</div>{{/if}}
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No MCP access events recorded yet."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= TOKEN USAGE (6) ============= }}
        {{#> components/panel title="Token usage (30d)" href="/admin/analytics/costs" span="6"}}
            {{#if has_token_usage}}
            <div class="skill-bar-list">
                {{#each token_usage}}
                <div class="skill-bar-row">
                    <div class="skill-bar-label" title="{{label}}">{{truncate label 20}}</div>
                    <div class="skill-bar-track">
                        <div class="progress-bar"><div class="progress-fill progress-blue" style="--fill: {{pct}}%"></div></div>
                    </div>
                    <div class="skill-bar-count" title="{{input_tokens}} in / {{output_tokens}} out">{{total_tokens}}</div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No token usage data yet."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= RECENT MCP ERRORS (6) ============= }}
        {{#> components/panel title="Recent MCP errors" href="/admin/analytics/tools" span="6"}}
            {{#if recent_mcp_errors}}
            <div class="mcp-errors-list">
                {{#each recent_mcp_errors}}
                <div class="feed-item">
                    <div class="feed-icon feed-orange"></div>
                    <div class="feed-content">
                        <span class="feed-text"><strong>{{tool_name}}</strong></span>
                        <span class="feed-time">{{created_at_display}}</span>
                    </div>
                </div>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No recent MCP errors."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= GROUPED INCIDENTS (12) ============= }}
        {{#> components/panel title="Grouped incidents (24h)" href="/admin/governance/decisions" span="12"}}
            {{#if has_governance_incidents}}
            <div class="incident-group-list">
                {{#each governance_incidents}}
                <details class="incident-group{{#if is_secret_policy}} incident-group--danger{{/if}}">
                    <summary class="incident-group__summary">
                        <span class="incident-group__attempts">{{attempts}}×</span>
                        <span class="incident-group__policy"><code class="code-inline">{{policy}}</code></span>
                        <span class="incident-group__tool"><code class="code-inline">{{tool_name}}</code></span>
                        <span class="incident-group__actor">{{actor_label}}{{#if agent_id}} · <code class="code-inline">{{agent_id}}</code>{{/if}}</span>
                        <span class="incident-group__time">{{last_seen}}</span>
                    </summary>
                    <div class="incident-group__body">
                        <div class="incident-group__meta">
                            <span>First: {{first_seen}}</span>
                            <span>Last: {{last_seen}}</span>
                            <a href="/admin/user?id={{user_id}}">View actor &rarr;</a>
                        </div>
                        <pre class="incident-group__reason">{{sample_reason}}</pre>
                    </div>
                </details>
                {{/each}}
            </div>
            {{else}}
            {{> components/empty-state message="No grouped incidents in the last 24 hours."}}
            {{/if}}
        {{/components/panel}}

        {{! ============= RAW EVENT STREAM (12) ============= }}
        {{#> components/panel title="Raw event stream" href="/admin/governance" subtitle="latest 50" span="12"}}
            {{#if has_governance_events}}
            {{#> components/data-table}}
                <thead><tr>
                    <th>User</th>
                    <th>Tool</th>
                    <th class="col-status">Decision</th>
                    <th class="col-multiline">Reason</th>
                    <th class="col-date">Time</th>
                </tr></thead>
                <tbody>
                {{#each governance_events}}
                <tr>
                    <td>
                        {{#> components/table-cell-stacked secondary=agent_id}}
                            <a href="/admin/user?id={{user_id}}">{{truncate user_id 12}}</a>
                        {{/components/table-cell-stacked}}
                    </td>
                    <td><code class="code-inline">{{tool_name}}</code></td>
                    <td class="col-status">
                        {{#if is_denied}}
                            <span class="mcp-badge mcp-badge-danger">DENIED</span>
                        {{else}}
                            <span class="mcp-badge mcp-badge-success">ALLOWED</span>
                        {{/if}}
                    </td>
                    <td class="col-multiline" title="{{reason}}">{{truncate reason 50}}</td>
                    <td class="col-date text-sm text-tertiary">{{created_at}}</td>
                </tr>
                {{/each}}
                </tbody>
            {{/components/data-table}}
            {{else}}
            {{> components/empty-state message="No governance decisions recorded yet."}}
            {{/if}}
        {{/components/panel}}

    </div>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-dashboard.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
