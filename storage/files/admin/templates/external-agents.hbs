{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    <section aria-label="External agents intro" class="hero-cli">
        <p class="text-tertiary text-sm">{{subtitle}}</p>
        <p class="text-tertiary text-sm">Edit <code class="code-inline">{{yaml_dir}}&lt;id&gt;.yaml</code> and restart to toggle <code class="code-inline">enabled</code>.</p>
    </section>

    <section aria-label="Enabled external agents">
        <h2>Enabled</h2>
        {{#if has_enabled}}
        {{#> components/data-table}}
            <thead><tr><th>ID</th><th>Name</th><th>Kind</th><th>Platforms</th><th>Description</th></tr></thead>
            <tbody>
            {{#each enabled}}
            <tr>
                <td><code class="code-inline">{{id}}</code></td>
                <td>{{display_name}}</td>
                <td>{{kind_label}}</td>
                <td>{{#each platforms}}<code class="code-inline">{{this}}</code> {{/each}}</td>
                <td>{{description}}{{#if docs_url}} <a href="{{docs_url}}" rel="noopener" target="_blank">docs</a>{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No external agents are enabled."}}
        {{/if}}
    </section>

    <section aria-label="Disabled external agents">
        <h2>Disabled</h2>
        {{#if has_disabled}}
        {{#> components/data-table}}
            <thead><tr><th>ID</th><th>Name</th><th>Kind</th><th>Platforms</th><th>Description</th></tr></thead>
            <tbody>
            {{#each disabled}}
            <tr>
                <td><code class="code-inline">{{id}}</code></td>
                <td>{{display_name}}</td>
                <td>{{kind_label}}</td>
                <td>{{#each platforms}}<code class="code-inline">{{this}}</code> {{/each}}</td>
                <td>{{description}}{{#if docs_url}} <a href="{{docs_url}}" rel="noopener" target="_blank">docs</a>{{/if}}</td>
            </tr>
            {{/each}}
            </tbody>
        {{/components/data-table}}
        {{else}}
        {{> components/empty-state message="No external agents are disabled."}}
        {{/if}}
    </section>

    {{#unless has_any}}
    {{> components/empty-state message="No external-agent YAML files found in services/external_agents/."}}
    {{/unless}}
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
