{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}

    {{> components/page-hero}}

    <section aria-label="Profile settings">
    <div class="card mb-6">
        <div class="card-header">
            <h2 class="card-title">Profile</h2>
        </div>
        <div class="card-body">
            <form id="settings-form" class="settings-form">
                <div class="settings-form-grid">
                    <div class="settings-field">
                        <label class="settings-label" for="settings-username">Username</label>
                        <input type="text" id="settings-username" class="form-input" value="{{username}}" readonly disabled />
                        <span class="settings-hint">Username cannot be changed</span>
                    </div>
                    <div class="settings-field">
                        <label class="settings-label" for="settings-email">Email</label>
                        <input type="email" id="settings-email" class="form-input" value="{{user_email}}" readonly disabled />
                        <span class="settings-hint">Contact support to change email</span>
                    </div>
                    <div class="settings-field">
                        <label class="settings-label" for="settings-display-name">Display Name</label>
                        <input type="text" id="settings-display-name" class="form-input" value="{{settings.display_name}}" placeholder="Enter a display name" />
                    </div>
                    <div class="settings-field">
                        <label class="settings-label" for="settings-avatar-url">Avatar URL</label>
                        <div class="settings-avatar-row">
                            <input type="url" id="settings-avatar-url" class="form-input" value="{{settings.avatar_url}}" placeholder="https://example.com/avatar.png" />
                            <div class="settings-avatar-preview" id="avatar-preview">
                                {{#if settings.avatar_url}}
                                <img src="{{settings.avatar_url}}" alt="Avatar preview" />
                                {{else}}
                                <span class="settings-avatar-placeholder">?</span>
                                {{/if}}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="settings-divider"></div>

                <h3 class="settings-section-title">Notifications</h3>
                <div class="settings-toggles">
                    <label class="settings-toggle" id="toggle-daily-summary">
                        <input type="checkbox" id="settings-notify-daily-summary" role="switch" aria-checked="{{#if settings.notify_daily_summary}}true{{else}}false{{/if}}" {{#if settings.notify_daily_summary}}checked{{/if}} />
                        <span class="settings-toggle-slider" aria-hidden="true"></span>
                        <span class="settings-toggle-text">
                            <strong>Daily Summary</strong>
                            <span class="text-secondary text-sm">Receive a daily email with your activity summary, insights, and metrics</span>
                        </span>
                    </label>
                    <label class="settings-toggle" id="toggle-achievements">
                        <input type="checkbox" id="settings-notify-achievements" role="switch" aria-checked="{{#if settings.notify_achievements}}true{{else}}false{{/if}}" {{#if settings.notify_achievements}}checked{{/if}} />
                        <span class="settings-toggle-slider" aria-hidden="true"></span>
                        <span class="settings-toggle-text">
                            <strong>Achievements</strong>
                            <span class="text-secondary text-sm">Get notified when you unlock new achievements and milestones</span>
                        </span>
                    </label>
                </div>
                <p class="text-secondary text-sm" style="margin-top: 8px;">Turn off both to stop all email notifications.</p>

                <div class="settings-divider"></div>

                <h3 class="settings-section-title">Preferences</h3>
                <div class="settings-toggles">
                    <label class="settings-toggle" id="toggle-leaderboard">
                        <input type="checkbox" id="settings-leaderboard-opt-in" role="switch" aria-checked="{{#if settings.leaderboard_opt_in}}true{{else}}false{{/if}}" {{#if settings.leaderboard_opt_in}}checked{{/if}} />
                        <span class="settings-toggle-slider" aria-hidden="true"></span>
                        <span class="settings-toggle-text">
                            <strong>Leaderboard Visibility</strong>
                            <span class="text-secondary text-sm">Show your profile on the public leaderboard</span>
                        </span>
                    </label>
                </div>

                <div class="settings-field" style="margin-top: 16px;">
                    <label class="settings-label" for="settings-timezone">Timezone</label>
                    <select id="settings-timezone" class="form-input">
                        <option value="UTC">UTC</option>
                    </select>
                    <span class="settings-hint">Used to schedule achievement emails at your local morning time</span>
                    <input type="hidden" id="settings-timezone-saved" value="{{settings.timezone}}" />
                </div>

                <div class="settings-actions">
                    <button type="submit" class="btn btn-primary" id="save-settings-btn">Save Settings</button>
                    <span class="settings-save-status" id="save-status" role="status" aria-live="polite"></span>
                </div>
            </form>
        </div>
    </div>
    </section>

    <section aria-label="Usage and limits">
    <div class="card mb-6">
        <div class="card-header">
            <h2 class="card-title">Usage & Limits</h2>
            <div class="d-flex align-center gap-2">
                <span class="badge {{#if is_premium}}badge-success{{else}}badge-secondary{{/if}}">{{tier_name}} Plan</span>
            </div>
        </div>
        <div class="card-body">
            <div class="usage-limits-grid">
                {{#each usage_items}}
                <div class="usage-limit-item{{#if is_at_limit}} usage-limit-item--warning{{/if}}">
                    <div class="usage-limit-header">
                        <span class="usage-limit-label">{{label}}</span>
                        <span class="usage-limit-value" style="font-variant-numeric: tabular-nums;">{{current}} / {{#if is_unlimited}}<span class="text-secondary">&infin;</span>{{else}}{{limit_display}}{{/if}}</span>
                    </div>
                    {{#unless is_unlimited}}
                    <div class="usage-limit-bar" role="progressbar" aria-valuenow="{{percentage}}" aria-valuemin="0" aria-valuemax="100" aria-label="{{label}}: {{current}} of {{limit_display}} used">
                        <div class="usage-limit-fill{{#if is_at_limit}} usage-limit-fill--danger{{/if}}" style="width: {{percentage}}%"></div>
                    </div>
                    <span class="usage-limit-pct text-tertiary text-xs">{{percentage}}% used</span>
                    {{/unless}}
                    {{#if is_unlimited}}
                    <div class="usage-limit-bar" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" aria-label="{{label}}: unlimited">
                        <div class="usage-limit-fill usage-limit-fill--unlimited w-full"></div>
                    </div>
                    <span class="usage-limit-pct text-tertiary text-xs">Unlimited</span>
                    {{/if}}
                </div>
                {{/each}}
            </div>
        </div>
    </div>
    </section>


    <section aria-label="Danger zone">
    <div class="card mb-6 card--danger">
        <div class="card-header">
            <h2 class="card-title">Danger Zone</h2>
        </div>
        <div class="card-body">
            <div class="danger-zone-item">
                <div>
                    <strong>Delete Account</strong>
                    <p class="text-secondary text-sm">Permanently delete your account and all associated data. This action cannot be undone.</p>
                </div>
                <button type="button" class="btn btn-danger" id="delete-account-btn">Delete Account</button>
            </div>
        </div>
    </div>
    </section>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-settings.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
