{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/page-hero}}

    <section aria-label="Skills">
    <div class="toolbar">
        <div class="search-group">
            <input type="text" class="search-input" placeholder="Search skills..." id="my-skills-search" aria-label="Search skills">
        </div>
        <select class="filter-select min-w-filter" id="my-skills-tag-filter">
            <option value="">All Tags</option>
            {{#each all_tags}}
            <option value="{{this}}">{{this}}</option>
            {{/each}}
        </select>
        <a href="/admin/my/skills/edit/" class="btn btn-primary">+ New Skill</a>
    </div>

    <p class="text-muted mb-4">All skills in your workspace. Skills are added when you add plugins from the <a href="/admin/browse/plugins/">Plugin Directory</a>.</p>

    {{#if stats}}
    <div class="config-stats mb-4">
        <span class="badge badge-info">{{stats.skill_count}} skill{{#if (not (eq stats.skill_count 1))}}s{{/if}}</span>
    </div>
    {{/if}}
    <div class="entity-batch-bar" id="entity-batch-bar" hidden>
        <span class="entity-batch-count" id="entity-batch-count">0 selected</span>
        <button type="button" class="entity-batch-btn entity-batch-btn--danger" id="entity-batch-delete">Delete Selected</button>
    </div>

    {{#if skills}}
    <div class="table-container">
        <table class="data-table" id="my-skills-table">
            <thead>
                <tr>
                    <th class="col-checkbox"><input type="checkbox" id="entity-select-all" class="entity-batch-checkbox" aria-label="Select all"></th>
                    <th>Name</th>
                    <th>Tags</th>
                    <th>Plugin</th>
                    <th class="col-status">Source</th>
                    <th>Usage</th>
                    <th class="col-actions"></th>
                </tr>
            </thead>
            <tbody>
                {{#each skills}}
                <tr class="clickable-row" data-expandable aria-expanded="false" data-entity-type="user-skill" data-entity-id="{{skill_id}}" data-name="{{toLowerCase name}}" data-tags="{{#each tags}}{{this}} {{/each}}">
                    <td class="col-checkbox" data-no-row-click><input type="checkbox" class="entity-batch-checkbox entity-row-checkbox" data-batch-id="{{skill_id}}" aria-label="Select {{name}}"></td>
                    <td>
                        {{#> components/table-cell-stacked secondary=(truncate description 80)}}<span class="expand-indicator" data-expand-for="{{skill_id}}" aria-hidden="true">&#9654;</span> {{name}}{{/components/table-cell-stacked}}
                    </td>
                    <td>
                        <div class="badge-row">
                            {{#each tags}}<span class="badge badge-secondary">{{this}}</span>{{/each}}
                        </div>
                    </td>
                    <td>
                        {{#if plugin_names}}
                            {{#each plugin_names}}
                            <a href="/admin/my/plugins/edit?id={{this.id}}" class="badge badge-purple text-no-decor cursor-pointer">{{this.name}}</a>
                            {{/each}}
                        {{else}}
                            <span class="text-tertiary">&mdash;</span>
                        {{/if}}
                    </td>
                    <td class="col-status">
                        {{#if base_skill_id}}<span class="badge badge-purple">Official</span>{{else}}<span class="badge badge-success">Custom</span>{{/if}}
                    </td>
                    <td>
                        {{#if (gt total_uses 0)}}
                            <div class="usage-metric">
                                <span class="badge badge-info">{{total_uses}} uses</span>
                                <span class="text-tertiary text-xs">{{sessions_used_in}} sessions</span>
                            </div>
                        {{else}}
                            <span class="text-tertiary">&mdash;</span>
                        {{/if}}
                    </td>
                    <td class="col-actions" data-no-row-click>
                        <div class="actions-menu" data-actions-for="{{skill_id}}">
                            <button type="button" class="actions-trigger" data-action="menu" title="Actions" aria-label="Actions menu">&#8942;</button>
                            <div class="actions-dropdown">
                                <a href="/admin/my/skills/edit/?id={{skill_id}}" class="actions-item">Edit</a>
                                <div class="actions-popup-separator"></div>
                                <button type="button" class="actions-item actions-item-danger" data-delete-entity="{{skill_id}}" data-entity-type="user-skill">Delete</button>
                            </div>
                        </div>
                    </td>
                </tr>
                <tr class="detail-row" data-detail-for="{{skill_id}}" aria-hidden="true">
                    <td colspan="8">
                        <div class="detail-row-content">
                            {{#if content_preview}}
                            <div class="detail-section">
                                <strong>Content Preview</strong>
                                <pre class="detail-pre-wrap text-sm text-secondary mt-2">{{content_preview}}</pre>
                            </div>
                            {{/if}}
                            {{#if tags}}
                            <div class="detail-section">
                                <strong>Tags</strong>
                                <div class="badge-row mt-1">
                                    {{#each tags}}<span class="badge badge-secondary">{{this}}</span>{{/each}}
                                </div>
                            </div>
                            {{/if}}
                            {{#if (gt total_uses 0)}}
                            <div class="detail-section">
                                <strong>Metrics</strong>
                                <div class="badge-row mt-2">
                                    <span class="badge badge-info">{{total_uses}} total uses</span>
                                    <span class="badge badge-success">{{sessions_used_in}} sessions</span>
                                    {{#if (gt scored_sessions 0)}}
                                    <span class="badge badge-warning">{{avg_effectiveness}} AI score ({{scored_sessions}} scored)</span>
                                    <span class="badge badge-purple">{{goal_achievement_pct}}% goals</span>
                                    {{/if}}
                                </div>
                                {{#if skill_rating}}
                                <div class="mt-2">
                                    <span class="text-sm text-secondary">Your rating:</span>
                                    {{> components/star-rating avg_rating=skill_rating avg_rating_display=skill_rating rating_count=1}}
                                </div>
                                {{/if}}
                            </div>
                            {{/if}}
                            {{#if base_skill_id}}
                            <div class="detail-section">
                                <span class="text-sm text-secondary">Added from: <code class="code-inline">{{base_skill_id}}</code> <span class="badge badge-purple">Official</span></span>
                            </div>
                            {{/if}}
                            <div class="detail-section">
                                <button type="button" class="btn btn-secondary btn-sm text-xs btn-compact mb-2" data-toggle-json="{{skill_id}}">Show JSON</button>
                                <div class="json-view d-none" data-json-for="{{skill_id}}"></div>
                            </div>
                        </div>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
    {{else}}
    {{> components/empty-state message="No skills yet. Create your first skill to get started."}}
    {{/if}}

    {{#each skills}}
    <script type="application/json" data-my-skill-detail="{{skill_id}}">
        {{{json this}}}
    </script>
    {{/each}}
    </section>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" src="/js/pages/admin-my-skills.js" type="module" defer></script>
    {{/inline}}
{{/layout}}
