{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}
    {{> components/back-button href="/admin/gateway" label="Back to Gateway"}}

    <div class="card max-w-lg">
        <form id="gw-route-form" data-edit-index="{{#if is_edit}}{{edit_index}}{{/if}}">
            {{> components/form-group label="Model pattern" name="model_pattern" type="text" value=route.model_pattern placeholder="claude-* or gpt-4 or *" required=true hint="Glob; first match wins. Use * for catch-all."}}
            {{> components/form-group label="Provider" name="provider" type="text" value=route.provider placeholder="anthropic, openai, minimax, ..." required=true}}
            {{> components/form-group label="Endpoint" name="endpoint" type="text" value=route.endpoint placeholder="https://api.provider.com/v1" required=true hint="Upstream base URL."}}
            {{> components/form-group label="API key secret" name="api_key_secret" type="text" value=route.api_key_secret placeholder="anthropic_key" required=true hint="Name of a secret in secrets.json. Never paste the key itself."}}
            {{> components/form-group label="Upstream model" name="upstream_model" type="text" value=route.upstream_model placeholder="(optional rename)" hint="Optional. Sent to upstream instead of the requested model."}}

            <fieldset style="border: 1px solid var(--color-border, #ddd); padding: 0.75rem 1rem; border-radius: 4px; margin: 1rem 0;">
                <legend style="padding: 0 0.5rem;">Extra headers</legend>
                <div id="gw-headers-list"></div>
                <button type="button" class="btn btn-small" id="gw-headers-add">+ Add header</button>
            </fieldset>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save route</button>
                <a href="/admin/gateway" class="btn btn-secondary">Cancel</a>
                <span id="gw-route-status" class="text-muted" style="margin-left: 0.75rem;"></span>
            </div>
        </form>
    </div>
    {{/inline}}

    {{#*inline "scripts"}}
    <script>
    (function() {
        const initialHeaders = {{{json route.extra_headers}}} || {};
        const list = document.getElementById('gw-headers-list');

        function row(name, value) {
            const div = document.createElement('div');
            div.style.display = 'grid';
            div.style.gridTemplateColumns = '1fr 1fr auto';
            div.style.gap = '0.5rem';
            div.style.marginBottom = '0.5rem';
            div.innerHTML = `
                <input type="text" placeholder="Header-Name" value="${(name||'').replace(/"/g,'&quot;')}" data-hdr-name />
                <input type="text" placeholder="value" value="${(value||'').replace(/"/g,'&quot;')}" data-hdr-value />
                <button type="button" class="btn btn-small btn-danger" data-hdr-remove>×</button>
            `;
            div.querySelector('[data-hdr-remove]').addEventListener('click', () => div.remove());
            return div;
        }

        Object.entries(initialHeaders).forEach(([k, v]) => list.appendChild(row(k, v)));
        document.getElementById('gw-headers-add').addEventListener('click', () => list.appendChild(row('', '')));

        const status = document.getElementById('gw-route-status');
        document.getElementById('gw-route-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const editIndex = form.getAttribute('data-edit-index');
            const headers = {};
            list.querySelectorAll('div').forEach(r => {
                const k = r.querySelector('[data-hdr-name]').value.trim();
                const v = r.querySelector('[data-hdr-value]').value;
                if (k) headers[k] = v;
            });
            const upstream = form.upstream_model.value.trim();
            const body = {
                model_pattern: form.model_pattern.value.trim(),
                provider: form.provider.value.trim(),
                endpoint: form.endpoint.value.trim(),
                api_key_secret: form.api_key_secret.value.trim(),
                upstream_model: upstream || null,
                extra_headers: headers,
            };
            const url = editIndex ? `/api/public/admin/gateway/routes/${editIndex}` : '/api/public/admin/gateway/routes';
            const method = editIndex ? 'PATCH' : 'POST';
            try {
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body),
                });
                if (!res.ok) {
                    const err = await res.json().catch(() => ({}));
                    status.textContent = err.error || 'Save failed';
                    status.style.color = 'var(--color-danger, #c00)';
                    return;
                }
                location.href = '/admin/gateway';
            } catch (e) {
                status.textContent = String(e);
                status.style.color = 'var(--color-danger, #c00)';
            }
        });
    })();
    </script>
    {{/inline}}
{{/layout}}
