{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title subtitle=window_label}}

    <div class="conversations-page" data-page="conversations">
        <aside class="conversations-page__list" aria-label="Sessions">
            <form class="conversations-page__filters" method="get" action="" role="search">
                <label class="conversations-page__field">
                    <span>Range</span>
                    <select name="range">
                        <option value="1h"  {{#if (eq filters.range "1h")}}selected{{/if}}>Last hour</option>
                        <option value="24h" {{#if (eq filters.range "24h")}}selected{{/if}}>Last 24 hours</option>
                        <option value="7d"  {{#if (eq filters.range "7d")}}selected{{/if}}>Last 7 days</option>
                        <option value="30d" {{#if (eq filters.range "30d")}}selected{{/if}}>Last 30 days</option>
                        <option value="all" {{#if (eq filters.range "all")}}selected{{/if}}>All time</option>
                    </select>
                </label>
                <label class="conversations-page__field">
                    <span>User</span>
                    <input type="text" name="user_id" value="{{filters.user_id}}" placeholder="user_id" />
                </label>
                <label class="conversations-page__field">
                    <span>Plugin</span>
                    <input type="text" name="plugin_id" value="{{filters.plugin_id}}" placeholder="plugin_id" />
                </label>
                <label class="conversations-page__field conversations-page__field--wide">
                    <span>Search</span>
                    <input type="search" name="q" value="{{filters.q}}" placeholder="title or transcript text" />
                </label>
                {{#if selected_session_id}}
                    <input type="hidden" name="session_id" value="{{selected_session_id}}" />
                {{/if}}
                <button type="submit" class="btn btn-primary">Apply</button>
            </form>

            {{#if has_sessions}}
                <ol class="conversations-page__sessions" role="listbox">
                    {{#each sessions}}
                        <li class="conversations-page__session{{#if this.is_selected}} is-selected{{/if}}{{#if this.deny_count}} has-denials{{/if}}"
                            data-session-id="{{this.session_id}}">
                            <a class="conversations-page__session-link"
                               href="?session_id={{this.session_id}}{{#if @root.filters.user_id}}&amp;user_id={{@root.filters.user_id}}{{/if}}{{#if @root.filters.plugin_id}}&amp;plugin_id={{@root.filters.plugin_id}}{{/if}}{{#if @root.filters.q}}&amp;q={{@root.filters.q}}{{/if}}{{#if @root.filters.range}}&amp;range={{@root.filters.range}}{{/if}}">
                                <span class="conversations-page__session-title">{{this.ai_title}}</span>
                                <span class="conversations-page__session-meta">
                                    <code class="code-inline">{{truncate this.session_id}}</code>
                                    <span class="text-tertiary">{{default this.user_id "—"}}</span>
                                </span>
                                <span class="conversations-page__session-stats">
                                    {{#if this.model}}<span class="conversations-page__session-model">{{this.model}}</span>{{/if}}
                                    {{#if this.governance_intervention_count}}
                                        <span class="conversations-page__session-badge conversations-page__session-badge--gov" title="{{this.deny_count}} deny / {{this.governance_intervention_count}} total">G&middot;{{this.governance_intervention_count}}</span>
                                    {{/if}}
                                    {{#if this.started_at}}
                                        <time class="conversations-page__session-time" datetime="{{this.started_at}}">{{relativeTime this.started_at}}</time>
                                    {{/if}}
                                </span>
                            </a>
                        </li>
                    {{/each}}
                </ol>
            {{else}}
                {{> components/empty-state message="No sessions match the current filters."}}
            {{/if}}
        </aside>

        <main class="conversations-page__detail" aria-label="Transcript">
            {{#if detail}}
                <header class="conversations-page__detail-header">
                    <h2 class="conversations-page__detail-title">{{default detail.ai_title "(untitled session)"}}</h2>
                    <p class="conversations-page__detail-meta">
                        <code class="code-inline">{{detail.session_id}}</code>
                        {{#if detail.user_id}}&middot; <span>{{detail.user_id}}</span>{{/if}}
                        {{#if detail.model}}&middot; <span class="conversations-page__detail-model">{{detail.model}}</span>{{/if}}
                        &middot; <span>{{detail.turn_count}} turn(s)</span>
                    </p>
                    <div class="conversations-page__detail-actions">
                        <button type="button"
                                id="conversations-redaction-toggle"
                                class="btn btn-secondary"
                                data-session-id="{{detail.session_id}}"
                                data-can-view-pii="{{can_view_pii}}"
                                {{#unless can_view_pii}}disabled title="Requires auditor role"{{/unless}}>
                            Show raw content
                        </button>
                        <a class="btn btn-secondary" href="#chain:{{detail.session_id}}" data-chain-id="{{detail.session_id}}">Open full chain</a>
                    </div>
                </header>

                <div class="conversations-page__detail-body" data-conversation-detail data-redaction-mode="redacted">
                    <nav class="conversations-page__jumpnav" aria-label="Jump to turn">
                        <ol>
                            {{#each detail.turns}}
                                <li>
                                    <a href="#turn-{{this.ordinal}}" data-jump="{{this.ordinal}}" title="{{this.role}} #{{this.ordinal}}">#{{this.ordinal}}</a>
                                </li>
                            {{/each}}
                        </ol>
                    </nav>

                    <section class="conversations-page__turns" id="conversations-turns">
                        {{#if detail.turns}}
                            {{#each detail.turns}}
                                {{> components/transcript-turn turn=this}}
                            {{/each}}
                        {{else}}
                            {{> components/empty-state message="This session has no captured transcript."}}
                        {{/if}}
                    </section>
                </div>
            {{else}}
                {{> components/empty-state message="Select a session on the left to view its transcript."}}
            {{/if}}
        </main>
    </div>
    {{/inline}}
    {{#*inline "scripts"}}{{/inline}}
{{/layout}}
