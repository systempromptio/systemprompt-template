{{#> layout title=title page=page}}
    {{#*inline "head_extra"}}{{/inline}}
    {{#*inline "content"}}
    {{> components/page-header title=title}}

    <!-- ===== Toolbar / source-of-truth ===== -->
    <div class="ac-toolbar" role="toolbar" aria-label="Access control toolbar">
        <div class="ac-search-group">
            <input type="search" class="search-input" id="ac-search"
                   placeholder="Search users, departments, entities…"
                   aria-label="Search">
        </div>
        <div class="ac-source-pill" data-tip="Bootstrap config is read from services/access-control/*.yaml on startup. Live edits are written to this instance's database only — they never get pushed back to the YAML or to git.">
            <strong>Bootstrap:</strong> services/access-control/*.yaml &nbsp;·&nbsp;
            <strong>Runtime edits:</strong> this instance's database
        </div>
        <button type="button" class="btn btn-secondary" id="ac-show-yaml">
            Show as YAML
        </button>
        <button type="button" class="btn btn-secondary" id="ac-new-department">
            + New department
        </button>
    </div>

    <div class="ac-stats">
        <span><strong>{{stats.department_count}}</strong> departments</span>
        <span>·</span>
        <span><strong>{{stats.user_count}}</strong> users</span>
    </div>

    <!-- ===== Three-pane layout ===== -->
    <div class="ac-layout">
        <!-- Left: department tree -->
        <aside class="ac-tree" aria-label="Departments and users">
            <h3 class="ac-tree-heading">Departments</h3>
            {{#each departments}}
            <div class="ac-tree-dept" data-dept="{{name}}">
                <button type="button" class="ac-dept-row" data-action="select-dept" data-dept="{{name}}">
                    <span class="ac-dept-name">{{name}}</span>
                    <span class="ac-dept-count">{{user_count}}</span>
                </button>
                <ul class="ac-dept-users" role="list">
                    {{#each users}}
                    <li>
                        <button type="button" class="ac-user-row {{#unless is_active}}is-inactive{{/unless}}"
                                data-action="select-user"
                                data-user-id="{{id}}"
                                data-user-display="{{display_name}}"
                                data-user-email="{{email}}">
                            <span class="ac-user-name">{{display_name}}</span>
                            <span class="ac-user-roles">
                                {{#each roles}}<span class="ac-role-chip">{{this}}</span>{{/each}}
                            </span>
                        </button>
                    </li>
                    {{/each}}
                </ul>
            </div>
            {{/each}}

            {{#if unassigned_count}}
            <div class="ac-tree-dept" data-dept="">
                <button type="button" class="ac-dept-row ac-dept-unassigned" data-action="select-dept" data-dept="">
                    <span class="ac-dept-name"><em>Unassigned</em></span>
                    <span class="ac-dept-count">{{unassigned_count}}</span>
                </button>
                <ul class="ac-dept-users" role="list">
                    {{#each unassigned_users}}
                    <li>
                        <button type="button" class="ac-user-row {{#unless is_active}}is-inactive{{/unless}}"
                                data-action="select-user"
                                data-user-id="{{id}}"
                                data-user-display="{{display_name}}"
                                data-user-email="{{email}}">
                            <span class="ac-user-name">{{display_name}}</span>
                            <span class="ac-user-roles">
                                {{#each roles}}<span class="ac-role-chip">{{this}}</span>{{/each}}
                            </span>
                        </button>
                    </li>
                    {{/each}}
                </ul>
            </div>
            {{/if}}
        </aside>

        <!-- Center pane: switches between welcome / dept editor / user matrix -->
        <section class="ac-detail" id="ac-detail" aria-live="polite">
            <div class="ac-welcome" id="ac-welcome">
                <h2>Access Control</h2>
                <p>Pick a department to assign access at the group level, or pick a user to see their full permission matrix.</p>
                <ul class="ac-welcome-tips">
                    <li><strong>YAML is bootstrap config.</strong> Hand-edit <code>services/access-control/*.yaml</code> in the source repo and redeploy to apply changes everywhere.</li>
                    <li><strong>The dashboard writes to the database</strong> on this instance only — useful for one-off operational overrides.</li>
                    <li>Use <em>Show as YAML</em> to copy the current DB state as a YAML snippet you can paste back into the source repo.</li>
                </ul>
            </div>

            <!-- Department editor (rendered by JS) -->
            <div class="ac-dept-editor" id="ac-dept-editor" hidden></div>

            <!-- User permission matrix (rendered by JS) -->
            <div class="ac-user-matrix" id="ac-user-matrix" hidden></div>
        </section>
    </div>

    <!-- ===== Modal overlay shells ===== -->
    <div class="panel-overlay" id="ac-modal-overlay" hidden></div>
    <div class="ac-modal" id="ac-yaml-modal" role="dialog" aria-modal="true" aria-labelledby="ac-yaml-title" hidden>
        <div class="ac-modal-header">
            <h2 id="ac-yaml-title">Current state as YAML</h2>
            <button type="button" class="panel-close" id="ac-yaml-close" aria-label="Close">&times;</button>
        </div>
        <div class="ac-modal-body">
            <p class="ac-modal-hint">
                This is the current database state of role/department rules on this instance,
                rendered in the loader's YAML schema. Copy any rules you want to make
                permanent into <code>services/access-control/*.yaml</code> in the source repo
                and redeploy. Per-user overrides are intentionally excluded.
            </p>
            <pre class="ac-yaml-pre" id="ac-yaml-content">Loading…</pre>
            <div class="ac-modal-actions">
                <button type="button" class="btn btn-secondary" id="ac-yaml-copy">Copy</button>
            </div>
        </div>
    </div>

    <div class="ac-modal" id="ac-new-dept-modal" role="dialog" aria-modal="true" aria-labelledby="ac-new-dept-title" hidden>
        <div class="ac-modal-header">
            <h2 id="ac-new-dept-title">Create department</h2>
            <button type="button" class="panel-close" id="ac-new-dept-close" aria-label="Close">&times;</button>
        </div>
        <div class="ac-modal-body">
            <label class="ac-field">
                <span>Name</span>
                <input type="text" id="ac-new-dept-name" class="search-input" placeholder="e.g. Engineering">
            </label>
            <label class="ac-field">
                <span>Description (optional)</span>
                <input type="text" id="ac-new-dept-desc" class="search-input">
            </label>
            <p class="ac-modal-hint">
                Saving creates the department in this instance's database.
                To make it part of the bootstrap baseline, add it to
                <code>services/access-control/departments.yaml</code> in the source repo.
            </p>
            <div class="ac-modal-actions">
                <button type="button" class="btn btn-primary" id="ac-new-dept-save">Create</button>
                <button type="button" class="btn btn-secondary" id="ac-new-dept-cancel">Cancel</button>
            </div>
        </div>
    </div>

    <!-- Embedded data for the JS controller. -->
    <script type="application/json" id="ac-entity-catalogue">{{{json entity_catalogue}}}</script>
    <script type="application/json" id="ac-known-roles">{{{json known_roles}}}</script>

    {{/inline}}
    {{#*inline "scripts"}}
    <script data-cfasync="false" type="module" src="/js/pages/admin-access-control.js"></script>
    {{/inline}}
{{/layout}}
