<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <title>{{default branding.domain "demo.systemprompt.io"}} Admin - {{title}}</title>
    <link rel="stylesheet" href="/css/core/fonts.css?v={{css_version}}">
    <link rel="stylesheet" href="/css/admin-bundle.css?v={{css_version}}">
    <script data-cfasync="false">(function(){let t;try{t=localStorage.getItem('sp-admin-theme')}catch(e){}if(!t){t=window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';}if(t==='dark'){document.documentElement.setAttribute('data-theme','dark');document.documentElement.style.colorScheme='dark';}else{document.documentElement.style.colorScheme='light';}})();</script>
    <style>html,body{margin:0;background:oklch(0.96 0.004 70);color:#1c1917;font-family:"OpenSans",-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}[data-theme="dark"],[data-theme="dark"] body{background:oklch(0.16 0.01 45);color:#fafaf9}</style>
    {{> head_extra}}
</head>
<body>
    <a href="#main" class="sp-skip-link">Skip to main content</a>
    <div class="admin-layout" data-section="{{page}}">
        {{> sidebar page=page}}
        <div class="sidebar-overlay" id="sidebar-overlay" aria-hidden="true"></div>
        <main class="admin-main" id="main">
            <header class="admin-header" role="banner">
                <button class="sidebar-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="admin-sidebar">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <rect x="2" y="4" width="16" height="2" rx="1"/>
                        <rect x="2" y="9" width="16" height="2" rx="1"/>
                        <rect x="2" y="14" width="16" height="2" rx="1"/>
                    </svg>
                </button>
                <h1>{{title}}</h1>
                <div class="header-actions" id="header-actions">
                    <button class="header-actions-toggle" type="button" aria-label="Actions menu" aria-expanded="false" aria-haspopup="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/>
                        </svg>
                    </button>
                    <div class="header-actions-menu">
                        <a href="/platform/{{page}}" target="_blank" rel="noopener noreferrer" class="header-help-link" title="Help for this page" aria-label="Help for {{title}}">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <path d="M9 9a3.5 3.5 0 116 2c0 1.5-2 2.5-3 3"/>
                                <line x1="12" y1="18.5" x2="12.01" y2="18.5"/>
                            </svg>
                        </a>
                        {{> components/install-widget}}
                        <div class="user-widget-row">
                            <a href="/admin/achievements/" class="user-widget user-widget--tier-{{marketplace.rank_tier}}" id="user-profile" title="Level {{marketplace.rank_level}} {{marketplace.rank_name}} — {{marketplace.total_xp}} XP">
                                <svg class="user-widget__xp-ring" viewBox="0 0 44 44" aria-hidden="true">
                                    <circle class="user-widget__xp-track" cx="22" cy="22" r="20" />
                                    <circle class="user-widget__xp-fill rank-ring-tier-{{marketplace.rank_tier}}" cx="22" cy="22" r="20" stroke-dasharray="125.66" style="stroke-dashoffset: calc(125.66px - 125.66px * {{marketplace.xp_progress_pct}} / 100)" />
                                </svg>
                                <div class="user-widget__avatar" id="user-avatar"></div>
                                <span class="user-widget__level rank-bg-tier-{{marketplace.rank_tier}}{{#if marketplace.is_premium}} is-premium{{/if}}">{{marketplace.rank_level}}</span>
                            </a>
                            <button type="button" id="btn-logout" class="btn-logout" title="Sign out" aria-label="Sign out">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                            </button>
                        </div>
                    </div>
                </div>
            </header>
            <div class="global-limit-warnings" id="global-limit-warnings" hidden></div>
            {{#unless marketplace.has_completed_onboarding}}
            <div class="sp-onboarding-banner" id="onboarding-banner">
                <div class="sp-onboarding-banner__content">
                    <svg class="sp-onboarding-banner__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                    <span>Connect Claude to {{default branding.domain "demo.systemprompt.io"}} to start tracking conversations.</span>
                    <a href="/admin/setup" class="sp-onboarding-banner__link">Complete setup</a>
                </div>
                <button type="button" class="sp-onboarding-banner__dismiss" id="onboarding-banner-dismiss" aria-label="Dismiss">&times;</button>
            </div>
            {{/unless}}
            {{> components/demo-help}}
            {{> content}}
            {{> components/admin-footer}}
        </main>
    </div>
<script data-cfasync="false" type="module" src="/js/services/bootstrap.js?v={{css_version}}" defer></script>
    {{> scripts}}
</body>
</html>
