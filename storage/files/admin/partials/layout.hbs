<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate">
    <title>Foodles Admin - {{title}}</title>
    <link rel="stylesheet" href="https://use.typekit.net/sis4nqz.css">
    <link rel="icon" type="image/x-icon" href="/files/images/favicon.ico">
    <link rel="stylesheet" href="/css/admin-bundle.css">
    <script>window.ADMIN_API_BASE = '/api/public/admin'; window.ADMIN_BASE = '/admin';</script>
    {{> head_extra}}
</head>
<body>
    <div class="admin-layout" data-section="{{page}}">
        {{> sidebar page=page}}
        <div class="sidebar-overlay" id="sidebar-overlay"></div>
        <main class="admin-main">
            <div class="admin-header">
                <button class="sidebar-toggle" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="admin-sidebar">
                    <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <rect x="2" y="4" width="16" height="2" rx="1"/>
                        <rect x="2" y="9" width="16" height="2" rx="1"/>
                        <rect x="2" y="14" width="16" height="2" rx="1"/>
                    </svg>
                </button>
                <h1>{{title}}</h1>
                {{> components/install-widget}}
                <div class="user-profile" id="user-profile">
                    <div class="user-avatar" id="user-avatar"></div>
                    <div class="user-info">
                        <span class="user-name" id="user-name"></span>
                        <span class="user-meta" id="user-meta"></span>
                    </div>
                    <button id="btn-logout" class="btn-logout" title="Sign out">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </div>
            </div>
            {{> content}}
        </main>
    </div>
    <footer class="admin-footer">
        Powered by <a href="https://foodles.com" target="_blank" rel="noopener"><img src="/files/images/logo-white.svg" alt="Foodles" class="admin-footer-logo" /></a>
    </footer>
    <script src="/js/admin-core.js"></script>
    <script src="/js/admin/sidebar-toggle.js"></script>
    <script>
        (function() {
            var u = window.AdminApp && window.AdminApp.user;
            if (u) {
                var av = document.getElementById('user-avatar');
                var nm = document.getElementById('user-name');
                if (av) av.textContent = window.AdminApp.getUserInitials(u.username);
                if (nm) nm.textContent = u.username;
            }
        })();
    </script>
    {{> scripts}}
</body>
</html>
