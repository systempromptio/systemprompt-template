<div class="plugin-tabs-container">
    <div class="sp-tabs" role="tablist" aria-label="Plugin details">
        <button type="button" class="sp-tab sp-tab--active" role="tab" aria-selected="true" aria-controls="tab-skills-{{pluginId}}" data-tab="skills" data-plugin-owner="{{pluginId}}">Skills <span class="sp-tab-count">{{skill_count}}</span></button>
        <button type="button" class="sp-tab" role="tab" aria-selected="false" aria-controls="tab-agents-{{pluginId}}" data-tab="agents" data-plugin-owner="{{pluginId}}">Agents <span class="sp-tab-count">{{agent_count}}</span></button>
        <button type="button" class="sp-tab" role="tab" aria-selected="false" aria-controls="tab-mcp-{{pluginId}}" data-tab="mcp" data-plugin-owner="{{pluginId}}">MCP Servers <span class="sp-tab-count">{{mcp_count}}</span></button>
        <button type="button" class="sp-tab" role="tab" aria-selected="false" aria-controls="tab-env-{{pluginId}}" data-tab="env" data-plugin-owner="{{pluginId}}">Env</button>
    </div>
    <div class="sp-tab-panel" role="tabpanel" id="tab-skills-{{pluginId}}" data-tab-panel="skills" data-plugin-owner="{{pluginId}}">
        {{#if skills}}
        {{#each skills}}
        <div class="detail-item">
            <div class="detail-item-info">
                <div class="detail-item-name">{{name}} <span class="badge {{#if (eq source "custom")}}badge-success{{else}}badge-info{{/if}}">{{default source "system"}}</span></div>
                {{#if description}}<div class="detail-item-desc">{{description}}</div>{{/if}}
            </div>
            <button type="button" class="btn btn-secondary btn-sm btn--files" data-browse-skill="{{id}}" data-skill-name="{{name}}">Files</button>
            {{#if command}}<span class="detail-item-command">{{command}}</span>{{/if}}
        </div>
        {{/each}}
        {{else}}
        <div class="empty-state"><p>No skills assigned to this plugin.</p></div>
        {{/if}}
    </div>
    <div class="sp-tab-panel" role="tabpanel" id="tab-agents-{{pluginId}}" data-tab-panel="agents" data-plugin-owner="{{pluginId}}" hidden>
        {{#if agents}}
        {{#each agents}}
        <div class="detail-item">
            <div class="detail-item-info">
                <div class="detail-item-name">{{name}}</div>
                {{#if description}}<div class="detail-item-desc">{{description}}</div>{{/if}}
            </div>
        </div>
        {{/each}}
        {{else}}
        <div class="empty-state"><p>No agents assigned to this plugin.</p></div>
        {{/if}}
    </div>
    <div class="sp-tab-panel" role="tabpanel" id="tab-mcp-{{pluginId}}" data-tab-panel="mcp" data-plugin-owner="{{pluginId}}" hidden>
        {{#if mcp_servers}}
        {{#each mcp_servers}}
        <div class="detail-item">
            <div class="detail-item-info">
                <div class="detail-item-name">{{this}}</div>
            </div>
        </div>
        {{/each}}
        {{else}}
        <div class="empty-state"><p>No MCP servers assigned to this plugin.</p></div>
        {{/if}}
    </div>
    <div class="sp-tab-panel" role="tabpanel" id="tab-env-{{pluginId}}" data-tab-panel="env" data-plugin-owner="{{pluginId}}" hidden>
        <div id="env-status-{{pluginId}}">
            <div class="plugin-tab-placeholder">Click to load environment variables...</div>
        </div>
    </div>
</div>
