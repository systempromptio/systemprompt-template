<div class="sp-tab-panel" role="tabpanel" id="tab-conversations" data-tab-panel="conversations"{{#unless has_any_data}} hidden{{/unless}} aria-label="Conversations">
    <div class="cc-filter-bar">
        <label class="cc-select-all-label">
            <input type="checkbox" id="cc-select-all"> All
        </label>
        <button type="button" class="cc-filter-btn cc-filter-btn--active" data-filter="" aria-pressed="true">Recent ({{unanalysed_count}})</button>
        <button type="button" class="cc-filter-btn" data-filter="active" aria-pressed="false">Active ({{active_count}})</button>
        <button type="button" class="cc-filter-btn" data-filter="analysed" aria-pressed="false">Analysed ({{analysed_count}})</button>
    </div>
    <div class="cc-next-jobs" id="cc-next-jobs">
        <span class="cc-next-job" title="Daily analysis runs at 23:00 UTC">Analysis in <span id="cc-analysis-countdown">--:--</span></span>
        <span class="cc-next-job-sep">&middot;</span>
        <span class="cc-next-job" title="Daily cleanup runs at 00:00 UTC">Cleanup in <span id="cc-cleanup-countdown">--:--</span></span>
    </div>
    <div class="cc-batch-bar" id="cc-batch-bar" hidden>
        <span class="cc-batch-count" id="cc-batch-count">0 selected</span>
        <button type="button" class="cc-batch-btn" data-batch-action="completed">Complete</button>
        <button type="button" class="cc-batch-btn cc-batch-btn--danger" data-batch-action="deleted">Delete</button>
    </div>

    {{#if session_groups}}
    <div class="sf-feed" id="activity-feed" aria-live="polite">
        {{#each session_groups}}
        <details class="sf-session" data-session-id="{{session_id}}" data-is-active="{{is_active}}" data-status="{{status}}" data-is-analysed="{{is_analysed}}"{{#if @first}} open{{/if}}>
            <span class="cc-select-check" onclick="event.stopPropagation()">
                <input type="checkbox" class="cc-session-checkbox" data-session-id="{{session_id}}" onclick="event.stopPropagation()">
            </span>
            <summary class="sf-session-header">
                <span class="sf-session-header-row1">
                    <span class="sf-session-title">{{#if ai_title}}{{ai_title}}{{else}}{{#if session_title}}{{session_title}}{{else}}{{project_name}}{{/if}}{{/if}}</span>
                    <span class="sf-session-right">
                        <span class="sf-session-time">{{relativeTime last_activity_at}}</span>
                        {{#if is_active}}<span class="sf-session-active-label">active</span>{{/if}}
                        {{#if quality_score}}<span class="sf-quality-badge sf-quality-badge--{{quality_class}}" title="Quality: {{quality_score}}/5">Q{{quality_score}}</span>{{/if}}
                        {{#if goal_achieved}}<span class="sf-goal-badge sf-goal-badge--{{goal_achieved}}" title="Goal: {{goal_achieved}}">{{{goal_icon}}}</span>{{/if}}
                        {{#if is_analysed}}<span class="sf-session-status-label sf-session-status-label--analysed">analysed</span>{{/if}}
                        {{#if (eq status "completed")}}<span class="sf-session-status-label sf-session-status-label--completed">completed</span>{{/if}}
                    </span>
                </span>
                <span class="sf-session-header-row2">
                    <span class="sf-metric-chips">
                        {{#if client_source}}<span class="sf-metric-chip sf-chip--source sf-chip--source-{{client_source_class}}" title="Client: {{client_source}}">{{client_source_label}}</span><span class="sf-metric-sep">&middot;</span>{{/if}}
                        {{#if is_plan_mode}}<span class="sf-metric-chip sf-chip--mode" title="Plan mode">plan</span><span class="sf-metric-sep">&middot;</span>{{/if}}
                        {{#if model}}<span class="sf-metric-chip sf-chip--model" title="Model: {{model}}">{{model_short}}</span><span class="sf-metric-sep">&middot;</span>{{/if}}
                        {{#if automated_actions}}<span class="sf-metric-chip" title="{{user_prompts}} user prompts, {{automated_actions}} automated actions">{{user_prompts}} user / {{automated_actions}} auto</span><span class="sf-metric-sep">&middot;</span>{{else}}{{#if total_prompts}}<span class="sf-metric-chip">{{total_prompts}} prompts</span><span class="sf-metric-sep">&middot;</span>{{/if}}{{/if}}
                        {{#if entity_count}}<span class="sf-metric-chip">{{entity_count}} skills</span><span class="sf-metric-sep">&middot;</span>{{/if}}
                        {{#if total_tools}}<span class="sf-metric-chip">{{total_tools}} tools</span><span class="sf-metric-sep">&middot;</span>{{/if}}
                        {{#if duration_display}}<span class="sf-metric-chip">{{duration_display}}</span>{{/if}}
                    </span>
                    <span class="sf-session-project">{{project_name}}</span>
                </span>
            </summary>
            <span class="sf-session-actions" data-session-id="{{session_id}}">
                <button type="button" class="sf-action-btn" title="Actions">&#8942;</button>
                <div class="sf-action-menu">
                    {{#unless is_analysed}}<button type="button" class="sf-action-item sf-action-item--accent" data-action="analyse">Analyse</button>{{/unless}}
                    <button type="button" class="sf-action-item" data-action="completed">Mark Complete</button>
                    <button type="button" class="sf-action-item sf-action-item--danger" data-action="deleted">Delete</button>
                    <button type="button" class="sf-action-item" data-action="active">Restore</button>
                </div>
            </span>

            {{#if is_analysed}}
            <div class="cc-analysis-preview">
                {{#if description}}<span class="cc-analysis-desc">{{description}}</span>{{/if}}
                {{#if recommendations}}<span class="cc-analysis-rec">{{recommendations}}</span>{{/if}}
            </div>
            {{else if ai_summary}}
            <div class="cc-ai-summary">{{ai_summary}}</div>
            {{/if}}

            {{#if entities}}
            <div class="cc-card-entities-inline">
                {{#each entities}}
                <span class="cc-entity-pill cc-entity-pill--{{entity_type}}" title="{{entity_name}} ({{usage_count}}x)">{{entity_name}}</span>
                {{/each}}
            </div>
            {{/if}}

            <details class="cc-card-section">
                <summary class="cc-card-section-title">Conversation ({{turn_count}} turns)</summary>
                <div class="cc-card-section-body">
                    {{#if first_prompt}}
                    <div class="sf-prompt">
                        <span class="sf-speaker sf-speaker--you">You</span>
                        <span class="sf-prompt-text">{{first_prompt}}</span>
                    </div>
                    {{/if}}
                    {{#if last_response}}
                    <div class="sf-response">
                        <span class="sf-speaker sf-speaker--ai">AI</span>
                        <span class="sf-response-text">{{last_response}}</span>
                    </div>
                    {{/if}}
                    {{#if turns}}
                    {{#if (gt turn_count 1)}}
                    <details class="cc-turns-expand">
                        <summary>View all {{turn_count}} turns</summary>
                        <div class="sf-turns">
                            {{#each turns}}
                            <div class="sf-turn">
                                {{#if prompt_text}}
                                <div class="sf-prompt">
                                    <span class="sf-speaker sf-speaker--you">You</span>
                                    <span class="sf-prompt-text">{{prompt_text}}</span>
                                </div>
                                {{/if}}
                                {{#if tool_groups}}
                                <details class="sf-tools-summary">
                                    <summary class="sf-tools-toggle">
                                        <span class="sf-tools-arrow">&#9656;</span>
                                        {{total_tools}} tools used
                                    </summary>
                                    <div class="sf-tools-detail">
                                        {{#each tool_groups}}
                                        <span class="sf-tool-chip">{{name}} &times;{{count}}</span>
                                        {{/each}}
                                    </div>
                                </details>
                                {{/if}}
                                {{#each errors}}
                                <div class="sf-error">
                                    <span class="sf-error-icon">&#10005;</span>
                                    <span class="sf-error-tool">{{tool_name}}:</span>
                                    <span class="sf-error-desc">{{description}}</span>
                                </div>
                                {{/each}}
                                {{#if response_text}}
                                <div class="sf-response">
                                    <span class="sf-speaker sf-speaker--ai">AI</span>
                                    <span class="sf-response-text">{{response_text}}</span>
                                </div>
                                {{/if}}
                            </div>
                            {{/each}}
                        </div>
                    </details>
                    {{/if}}
                    {{/if}}
                </div>
            </details>

            {{#if all_errors}}
            <details class="cc-card-section">
                <summary class="cc-card-section-title cc-card-section-title--error">Errors ({{total_errors}})</summary>
                <div class="cc-card-section-body">
                    {{#each all_errors}}
                    <div class="sf-error">
                        <span class="sf-error-icon">&#10005;</span>
                        <span class="sf-error-tool">{{tool_name}}:</span>
                        <span class="sf-error-desc">{{description}}</span>
                    </div>
                    {{/each}}
                </div>
            </details>
            {{/if}}
        </details>
        {{/each}}
    </div>
    {{else}}
    <div class="cc-empty-section">
        <p>No activity recorded yet. Events appear here as you use Claude Code.</p>
    </div>
    {{/if}}
</div>
