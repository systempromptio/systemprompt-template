<aside class="admin-sidebar" id="admin-sidebar">
    <button class="sidebar-close-btn" type="button" aria-label="Close menu">&times;</button>
    <a href="/admin/access/users" class="admin-sidebar-brand" aria-label="{{default branding.domain "demo.systemprompt.io"}} - Go to admin">
        <img src="{{default branding.logo_light "/files/images/logo.svg"}}" alt="{{default branding.domain "demo.systemprompt.io"}}" class="admin-logo admin-logo--light" />
        <img src="{{default branding.logo_dark "/files/images/logo-white.svg"}}" alt="{{default branding.domain "demo.systemprompt.io"}}" class="admin-logo admin-logo--dark" />
    </a>
    <nav aria-label="Admin navigation">

        {{!-- ACCESS — who can do what --}}
        <h2 class="nav-label">Access</h2>
        <a href="/admin/access/users"{{#if (eq page "users")}} class="active" aria-current="page"{{else}}{{#if (eq page "user-detail")}} class="active" aria-current="page"{{/if}}{{/if}}>
            <svg class="icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="5" r="3"/><path d="M2 14c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>
            Users
        </a>
        <a href="/admin/access/departments"{{#if (eq page "departments")}} class="active" aria-current="page"{{else}}{{#if (eq page "department-detail")}} class="active" aria-current="page"{{/if}}{{/if}}>
            <svg class="icon" aria-hidden="true" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 14V6l3-2 3 2v8M8 14V8l3-2 3 2v6M2 14h12"/></svg>
