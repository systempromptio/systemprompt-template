{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            mc.slug,\n            mc.title,\n            mc.description,\n            mc.image,\n            mce.category,\n            mc.published_at\n        FROM markdown_content mc\n        LEFT JOIN markdown_content_enrichment mce ON mce.content_id = mc.id\n        WHERE mc.source_id = 'blog'\n        ORDER BY mc.published_at DESC\n        ",
