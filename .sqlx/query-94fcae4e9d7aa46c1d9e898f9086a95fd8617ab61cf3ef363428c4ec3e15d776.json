  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id              AS \"request_id!: AiRequestId\",\n            model           AS \"model!\",\n            provider        AS \"provider!\",\n            status          AS \"status!\",\n            latency_ms,\n            input_tokens,\n            output_tokens,\n            cost_microdollars AS \"cost_microdollars!\",\n            trace_id        AS \"trace_id: TraceId\",\n            created_at      AS \"created_at!\"\n          FROM ai_requests\n         WHERE session_id = $1\n         ORDER BY created_at ASC\n         LIMIT 200\n        ",
