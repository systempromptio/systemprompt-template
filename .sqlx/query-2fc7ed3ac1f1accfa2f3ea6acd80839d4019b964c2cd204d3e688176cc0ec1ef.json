  "query": "\n        SELECT module as \"module!\", COUNT(*) as \"count\"\n        FROM logs\n        WHERE ($1::TIMESTAMPTZ IS NULL OR timestamp >= $1)\n        GROUP BY module\n        ORDER BY count DESC\n        LIMIT $2\n        ",
