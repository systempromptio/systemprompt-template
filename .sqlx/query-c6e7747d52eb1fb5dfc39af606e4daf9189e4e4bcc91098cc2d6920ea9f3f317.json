  "query": "\n            SELECT\n                id,\n                user_id as \"user_id: UserId\",\n                session_id as \"session_id: SessionId\",\n                event_type,\n                event_category,\n                endpoint as page_url,\n                event_data,\n                timestamp\n            FROM analytics_events\n            WHERE event_data->>'content_id' = $1\n            ORDER BY timestamp DESC\n            LIMIT $2\n            ",
