  "query": "SELECT agent_id as \"id!\",\n                  agent_id as \"label!\",\n                  COUNT(*)::bigint as \"count!\"\n           FROM governance_decisions\n           WHERE agent_id IS NOT NULL\n             AND created_at >= $1 AND created_at < $2\n           GROUP BY agent_id\n           ORDER BY COUNT(*) DESC\n           LIMIT $3",
