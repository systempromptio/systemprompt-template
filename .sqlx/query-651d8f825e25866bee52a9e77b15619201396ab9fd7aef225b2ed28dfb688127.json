{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    id as \"id!\",\n                    provider as \"provider!\",\n                    model as \"model!\",\n                    input_tokens,\n                    output_tokens,\n                    cost_microdollars,\n                    latency_ms,\n                    cache_hit,\n                    created_at as \"created_at!\",\n                    status as \"status!\",\n                    error_message,\n                    user_id as \"user_id!: UserId\"\n                FROM ai_requests\n                WHERE created_at >= $1 AND created_at < $2\n                ORDER BY created_at DESC\n                LIMIT $3\n                ",
