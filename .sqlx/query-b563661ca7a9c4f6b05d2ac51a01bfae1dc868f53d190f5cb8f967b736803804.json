{
  "db_name": "PostgreSQL",
  "query": "SELECT u.id,\n                  u.email,\n                  COALESCE(u.display_name, u.full_name, u.name) AS display_name,\n                  u.roles AS \"roles!: Vec<String>\",\n                  COALESCE(upe.department, 'Default') AS \"department!\"\n           FROM users u\n           LEFT JOIN user_profile_ext upe ON upe.user_id = u.id\n           WHERE u.id = $1",
