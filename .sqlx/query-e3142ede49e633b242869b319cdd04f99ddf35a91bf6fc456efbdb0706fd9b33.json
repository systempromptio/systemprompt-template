{
  "db_name": "PostgreSQL",
  "query": "SELECT r.id, r.user_id AS \"user_id: UserId\", r.trace_id AS \"trace_id: TraceId\",\n                  r.session_id AS \"session_id: SessionId\", r.context_id AS \"context_id: ContextId\",\n                  r.model, r.status,\n                  r.error_message, r.cost_microdollars, r.latency_ms, r.created_at,\n                  u.display_name, upe.department\n           FROM ai_requests r\n           LEFT JOIN users u ON u.id = r.user_id\n           LEFT JOIN user_profile_ext upe ON upe.user_id = r.user_id\n           ORDER BY r.created_at DESC\n           LIMIT $1",
