{
  "db_name": "PostgreSQL",
  "query": "SELECT\n            policy,\n            tool_name,\n            COUNT(*)::bigint AS \"hits!\",\n            COUNT(DISTINCT user_id)::bigint AS \"distinct_actors!\"\n        FROM governance_decisions\n        WHERE decision = 'deny'\n          AND created_at > now() - make_interval(secs => $1::double precision)\n        GROUP BY policy, tool_name\n        ORDER BY 3 DESC\n        LIMIT $2",
