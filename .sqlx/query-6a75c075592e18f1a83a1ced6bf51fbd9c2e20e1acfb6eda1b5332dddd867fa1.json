  "query": "\n        SELECT\n            id                                  AS \"id!\",\n            context_id                          AS \"context_id?: ContextId\",\n            trace_id                            AS \"trace_id?: TraceId\",\n            model                               AS \"model!\",\n            status                              AS \"status!\",\n            latency_ms                          AS \"latency_ms?\",\n            cost_microdollars                   AS \"cost_microdollars!\",\n            created_at                          AS \"created_at!\"\n        FROM ai_requests\n        WHERE session_id = $1\n        ORDER BY created_at DESC\n        LIMIT 200\n        ",
