{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            r.user_id,\n            COALESCE(u.display_name, u.full_name, u.name) AS display_name,\n            r.rank_level,\n            r.rank_name,\n            r.total_xp::BIGINT AS \"total_xp!\",\n            r.events_count,\n            r.unique_skills_count,\n            r.unique_plugins_count,\n            r.current_streak,\n            r.longest_streak\n        FROM employee_ranks r\n        JOIN users u ON r.user_id = u.id\n        WHERE r.user_id = $1\n        ",
