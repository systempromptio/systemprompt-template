{
  "$schema": "https://api.northflank.com/v1/schemas/template",
  "apiVersion": "v1.2",
  "name": "systemprompt-io",
  "description": "systemprompt.io self-owned AI control plane: governance gateway for Claude, OpenAI, and Gemini with audit, policy, and MCP. https://systemprompt.io",
  "arguments": {
    "ANTHROPIC_API_KEY": "",
    "OPENAI_API_KEY": "",
    "GEMINI_API_KEY": ""
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "systemprompt",
            "region": "europe-west",
            "color": "#0f172a"
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "sequential",
            "context": {
              "projectId": "${refs.project.id}"
            },
            "steps": [
              {
                "kind": "Addon",
                "ref": "database",
                "spec": {
                  "name": "database",
                  "type": "postgresql",
                  "version": "latest",
                  "tlsEnabled": false,
                  "externalAccessEnabled": false,
                  "billing": {
                    "deploymentPlan": "nf-compute-20",
                    "storage": 4096,
                    "replicas": 1
                  }
                }
              },
              {
                "kind": "DeploymentService",
                "ref": "gateway",
                "spec": {
                  "name": "gateway",
                  "billing": {
                    "deploymentPlan": "nf-compute-20"
                  },
                  "deployment": {
                    "instances": 1,
                    "external": {
                      "imagePath": "ghcr.io/systempromptio/systemprompt-template:0"
                    }
                  },
                  "ports": [
                    {
                      "name": "web",
                      "internalPort": 8080,
                      "public": true,
                      "protocol": "HTTP"
                    }
                  ],
                  "runtimeEnvironment": {
                    "HOST": "0.0.0.0",
                    "PORT": "8080"
                  },
                  "healthChecks": [
                    {
                      "protocol": "HTTP",
                      "type": "readinessProbe",
                      "path": "/api/v1/health",
                      "port": 8080,
                      "initialDelaySeconds": 60,
                      "periodSeconds": 15,
                      "timeoutSeconds": 5,
                      "failureThreshold": 40,
                      "successThreshold": 1
                    }
                  ]
                }
              },
              {
                "kind": "SecretGroup",
                "ref": "secrets",
                "spec": {
                  "name": "secrets",
                  "secretType": "environment-arguments",
                  "priority": 10,
                  "addonDependencies": [
                    {
                      "addonId": "database",
                      "keys": [
                        {
                          "keyName": "POSTGRES_URI_ADMIN",
                          "aliases": [
                            "DATABASE_URL"
                          ]
                        }
                      ]
                    }
                  ],
                  "secrets": {
                    "variables": {
                      "ANTHROPIC_API_KEY": "${args.ANTHROPIC_API_KEY}",
                      "OPENAI_API_KEY": "${args.OPENAI_API_KEY}",
                      "GEMINI_API_KEY": "${args.GEMINI_API_KEY}",
                      "EXTERNAL_URL": "https://${refs.gateway.ports.0.dns}"
                    }
                  },
                  "restrictions": {
                    "restricted": true,
                    "nfObjects": [
                      {
                        "id": "${refs.gateway.id}",
                        "type": "service"
                      }
                    ]
                  }
                }
              },
              {
                "kind": "Volume",
                "ref": "gateway-data",
                "spec": {
                  "name": "gateway-data",
                  "spec": {
                    "storageSize": 6144,
                    "accessMode": "ReadWriteOnce"
                  },
                  "mounts": [
                    {
                      "volumeMountPath": "web",
                      "containerMountPath": "/app/web"
                    },
                    {
                      "volumeMountPath": "storage",
                      "containerMountPath": "/app/storage/data"
                    },
                    {
                      "volumeMountPath": "profiles",
                      "containerMountPath": "/app/.systemprompt/profiles/docker"
                    }
                  ],
                  "attachedObjects": [
                    {
                      "id": "${refs.gateway.id}",
                      "type": "service"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
}
