{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Profile",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "target": {
      "$ref": "#/$defs/ProfileType",
      "default": "local"
    },
    "site": {
      "$ref": "#/$defs/SiteConfig"
    },
    "database": {
      "$ref": "#/$defs/DatabaseConfig"
    },
    "server": {
      "$ref": "#/$defs/ServerConfig"
    },
    "paths": {
      "$ref": "#/$defs/PathsConfig"
    },
    "security": {
      "$ref": "#/$defs/SecurityConfig"
    },
    "rate_limits": {
      "$ref": "#/$defs/RateLimitsConfig"
    },
    "system_admin": {
      "$ref": "#/$defs/SystemAdminConfig"
    },
    "runtime": {
      "$ref": "#/$defs/RuntimeConfig",
      "default": {
        "environment": "development",
        "log_level": "normal",
        "output_format": "text",
        "no_color": false,
        "non_interactive": false
      }
    },
    "cloud": {
      "anyOf": [
        {
          "$ref": "#/$defs/CloudConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "secrets": {
      "anyOf": [
        {
          "$ref": "#/$defs/SecretsConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "extensions": {
      "$ref": "#/$defs/ExtensionsConfig",
      "default": {
        "disabled": []
      }
    },
    "providers": {
      "$ref": "#/$defs/ProviderRegistry",
      "default": []
    },
    "gateway": {
      "anyOf": [
        {
          "$ref": "#/$defs/GatewayConfigSpec"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "governance": {
      "anyOf": [
        {
          "$ref": "#/$defs/GovernanceConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    }
  },
  "additionalProperties": false,
  "required": [
    "name",
    "display_name",
    "site",
    "database",
    "server",
    "paths",
    "security",
    "rate_limits",
    "system_admin"
  ],
  "$defs": {
    "ProfileType": {
      "type": "string",
      "enum": [
        "local",
        "cloud"
      ]
    },
    "SiteConfig": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "github_link": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "name"
      ]
    },
    "DatabaseConfig": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "external_db_access": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false,
      "required": [
        "type"
      ]
    },
    "ServerConfig": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "minimum": 0,
          "maximum": 65535
        },
        "api_server_url": {
          "type": "string"
        },
        "api_internal_url": {
          "type": "string"
        },
        "api_external_url": {
          "type": "string"
        },
        "use_https": {
          "type": "boolean",
          "default": false
        },
        "cors_allowed_origins": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "content_negotiation": {
          "$ref": "#/$defs/ContentNegotiationConfig",
          "default": {
            "enabled": false,
            "markdown_suffix": ".md"
          }
        },
        "security_headers": {
          "$ref": "#/$defs/SecurityHeadersConfig",
          "default": {
            "enabled": true,
            "hsts": "max-age=63072000; includeSubDomains; preload",
            "frame_options": "DENY",
            "content_type_options": "nosniff",
            "referrer_policy": "strict-origin-when-cross-origin",
            "permissions_policy": "camera=(), microphone=(), geolocation=()",
            "content_security_policy": null
          }
        },
        "instance_id": {
          "description": "Stable identifier for this replica. Empty/unset resolves to the\nOS hostname (or a generated short id) at config build time.",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "max_concurrent_streams": {
          "description": "Global cap on concurrent A2A SSE streams for this replica.",
          "type": "integer",
          "format": "uint",
          "minimum": 0,
          "default": 256
        },
        "trusted_proxies": {
          "description": "CIDR ranges whose immediate-peer requests are allowed to set\n`X-Forwarded-For`, `X-Real-IP`, and `CF-Connecting-IP`. Empty\nmeans the platform treats every connection as direct and ignores\nthose headers — the only safe default behind no proxy. Each entry\nis a CIDR string (e.g. `10.0.0.0/8`, `192.168.1.0/24`,\n`2001:db8::/32`). Single addresses without a `/` are accepted as\n`/32` (IPv4) or `/128` (IPv6).",
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false,
      "required": [
        "host",
        "port",
        "api_server_url",
        "api_internal_url",
        "api_external_url"
      ]
    },
    "ContentNegotiationConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "markdown_suffix": {
          "type": "string",
          "default": ".md"
        }
      },
      "additionalProperties": false
    },
    "SecurityHeadersConfig": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "hsts": {
          "type": "string",
          "default": "max-age=63072000; includeSubDomains; preload"
        },
        "frame_options": {
          "type": "string",
          "default": "DENY"
        },
        "content_type_options": {
          "type": "string",
          "default": "nosniff"
        },
        "referrer_policy": {
          "type": "string",
          "default": "strict-origin-when-cross-origin"
        },
        "permissions_policy": {
          "type": "string",
          "default": "camera=(), microphone=(), geolocation=()"
        },
        "content_security_policy": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "PathsConfig": {
      "type": "object",
      "properties": {
        "system": {
          "type": "string"
        },
        "services": {
          "type": "string"
        },
        "bin": {
          "type": "string"
        },
        "web_path": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "storage": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "geoip_database": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
        "system",
        "services",
        "bin"
      ]
    },
    "SecurityConfig": {
      "type": "object",
      "properties": {
        "jwt_issuer": {
          "type": "string"
        },
        "jwt_access_token_expiration": {
          "type": "integer",
          "format": "int64"
        },
        "jwt_refresh_token_expiration": {
          "type": "integer",
          "format": "int64"
        },
        "jwt_audiences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/JwtAudience"
          }
        },
        "allowed_resource_audiences": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "allow_registration": {
          "type": "boolean",
          "default": true
        },
        "signing_key_path": {
          "type": "string",
          "default": "signing_key.pem"
        },
        "trusted_issuers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TrustedIssuer"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "jwt_issuer",
        "jwt_access_token_expiration",
        "jwt_refresh_token_expiration",
        "jwt_audiences"
      ]
    },
    "JwtAudience": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "web",
            "api",
            "a2a",
            "mcp",
            "internal",
            "bridge",
            "hook"
          ]
        },
        {
          "type": "string"
        }
      ]
    },
    "TrustedIssuer": {
      "type": "object",
      "properties": {
        "issuer": {
          "type": "string"
        },
        "jwks_uri": {
          "type": "string"
        },
        "audience": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "issuer",
        "jwks_uri",
        "audience"
      ]
    },
    "RateLimitsConfig": {
      "type": "object",
      "properties": {
        "disabled": {
          "type": "boolean",
          "default": false
        },
        "oauth_public_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 10
        },
        "oauth_auth_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 10
        },
        "contexts_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 100
        },
        "tasks_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 50
        },
        "artifacts_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 50
        },
        "agent_registry_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 50
        },
        "agents_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 20
        },
        "mcp_registry_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 50
        },
        "mcp_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 200
        },
        "stream_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 100
        },
        "content_per_second": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 50
        },
        "burst_multiplier": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 3
        },
        "tier_multipliers": {
          "$ref": "#/$defs/TierMultipliers",
          "default": {
            "admin": 10.0,
            "user": 1.0,
            "a2a": 5.0,
            "mcp": 5.0,
            "service": 5.0,
            "anon": 0.5
          }
        }
      },
      "additionalProperties": false
    },
    "TierMultipliers": {
      "type": "object",
      "properties": {
        "admin": {
          "type": "number",
          "format": "double",
          "default": 10.0
        },
        "user": {
          "type": "number",
          "format": "double",
          "default": 1.0
        },
        "a2a": {
          "type": "number",
          "format": "double",
          "default": 5.0
        },
        "mcp": {
          "type": "number",
          "format": "double",
          "default": 5.0
        },
        "service": {
          "type": "number",
          "format": "double",
          "default": 5.0
        },
        "anon": {
          "type": "number",
          "format": "double",
          "default": 0.5
        }
      },
      "additionalProperties": false
    },
    "SystemAdminConfig": {
      "description": "Profile-supplied configuration for the platform owner. Must resolve at\nstartup to an active user row carrying the `admin` role; the platform\nrefuses to boot otherwise.",
      "type": "object",
      "properties": {
        "username": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "username"
      ]
    },
    "RuntimeConfig": {
      "type": "object",
      "properties": {
        "environment": {
          "$ref": "#/$defs/Environment",
          "default": "development"
        },
        "log_level": {
          "$ref": "#/$defs/LogLevel",
          "default": "normal"
        },
        "output_format": {
          "$ref": "#/$defs/OutputFormat",
          "default": "text"
        },
        "no_color": {
          "type": "boolean",
          "default": false
        },
        "non_interactive": {
          "type": "boolean",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "Environment": {
      "type": "string",
      "enum": [
        "development",
        "test",
        "staging",
        "production"
      ]
    },
    "LogLevel": {
      "type": "string",
      "enum": [
        "quiet",
        "normal",
        "verbose",
        "debug"
      ]
    },
    "OutputFormat": {
      "type": "string",
      "enum": [
        "text",
        "json",
        "yaml"
      ]
    },
    "CloudConfig": {
      "type": "object",
      "properties": {
        "tenant_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "validation": {
          "$ref": "#/$defs/CloudValidationMode",
          "default": "strict"
        }
      },
      "additionalProperties": false
    },
    "CloudValidationMode": {
      "type": "string",
      "enum": [
        "strict",
        "warn",
        "skip"
      ]
    },
    "SecretsConfig": {
      "type": "object",
      "properties": {
        "secrets_path": {
          "type": "string"
        },
        "validation": {
          "$ref": "#/$defs/SecretsValidationMode",
          "default": "warn"
        },
        "source": {
          "$ref": "#/$defs/SecretsSource"
        }
      },
      "additionalProperties": false,
      "required": [
        "secrets_path",
        "source"
      ]
    },
    "SecretsValidationMode": {
      "type": "string",
      "enum": [
        "strict",
        "warn",
        "skip"
      ]
    },
    "SecretsSource": {
      "type": "string",
      "enum": [
        "file",
        "env"
      ]
    },
    "ExtensionsConfig": {
      "type": "object",
      "properties": {
        "disabled": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "additionalProperties": false
    },
    "ProviderRegistry": {
      "description": "The `profile.providers` section: the registry of upstream providers.",
      "type": "array",
      "items": {
        "$ref": "#/$defs/ProviderEntry"
      }
    },
    "ProviderEntry": {
      "description": "One upstream provider declared once: connectivity + the models it serves.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "protocol": {
          "$ref": "#/$defs/WireProtocol"
        },
        "endpoint": {
          "type": "string"
        },
        "api_key_secret": {
          "type": "string"
        },
        "extra_headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "models": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ProviderModel"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "protocol",
        "endpoint",
        "api_key_secret"
      ]
    },
    "WireProtocol": {
      "description": "The wire-format family a provider's endpoint speaks.",
      "type": "string",
      "enum": [
        "anthropic",
        "openai-chat",
        "openai-responses",
        "gemini"
      ]
    },
    "ProviderModel": {
      "description": "One model served by a provider: identity, routing, and economics.\n\nA model's full description lives here exactly once: identity and routing\n(id, aliases, `upstream_model`, pricing) alongside agent-side capabilities\nand limits.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "upstream_model": {
          "description": "Vendor-side model name to send upstream when it differs from\n[`Self::id`] (the external-facing name). `None` forwards `id`\nunchanged.",
          "type": [
            "string",
            "null"
          ]
        },
        "pricing": {
          "$ref": "#/$defs/ModelPricing",
          "default": {
            "input_per_million": 0.0,
            "output_per_million": 0.0,
            "per_image_cents": null
          }
        },
        "capabilities": {
          "$ref": "#/$defs/ModelCapabilities",
          "default": {
            "vision": false,
            "audio_input": false,
            "video_input": false,
            "image_generation": false,
            "audio_generation": false,
            "streaming": false,
            "tools": false,
            "structured_output": false,
            "system_prompts": false,
            "image_resolution_config": false
          }
        },
        "limits": {
          "$ref": "#/$defs/ModelLimits",
          "default": {
            "context_window": 0,
            "max_output_tokens": 0
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "id"
      ]
    },
    "ModelPricing": {
      "type": "object",
      "properties": {
        "input_per_million": {
          "type": "number",
          "format": "double",
          "default": 0.0
        },
        "output_per_million": {
          "type": "number",
          "format": "double",
          "default": 0.0
        },
        "per_image_cents": {
          "type": [
            "number",
            "null"
          ],
          "format": "double",
          "default": null
        }
      }
    },
    "ModelCapabilities": {
      "type": "object",
      "properties": {
        "vision": {
          "type": "boolean",
          "default": false
        },
        "audio_input": {
          "type": "boolean",
          "default": false
        },
        "video_input": {
          "type": "boolean",
          "default": false
        },
        "image_generation": {
          "type": "boolean",
          "default": false
        },
        "audio_generation": {
          "type": "boolean",
          "default": false
        },
        "streaming": {
          "type": "boolean",
          "default": false
        },
        "tools": {
          "type": "boolean",
          "default": false
        },
        "structured_output": {
          "type": "boolean",
          "default": false
        },
        "system_prompts": {
          "type": "boolean",
          "default": false
        },
        "image_resolution_config": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "ModelLimits": {
      "type": "object",
      "properties": {
        "context_window": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0,
          "default": 0
        },
        "max_output_tokens": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0,
          "default": 0
        },
        "max_thinking_budget": {
          "description": "Maximum extended-thinking / reasoning budget (in tokens) the upstream\naccepts for this model. `None` means the provider validates the budget\nitself (Anthropic) or maps it to an effort bucket (OpenAI); set it for\nproviders that reject an out-of-range numeric budget (Gemini: 24576 for\nflash, 32768 for pro). The gateway clamps the requested budget to this.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      }
    },
    "GatewayConfigSpec": {
      "description": "On-disk gateway configuration: the exact shape accepted under\n`gateway:` in a profile YAML document.\n\nProject to the runtime [`GatewayConfig`] via [`Self::resolve`].",
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "routes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/GatewayRoute"
          },
          "default": []
        },
        "default_provider": {
          "description": "Provider that absorbs any model not matched by an explicit `route`.\nWhen set, the gateway stops being a closed allowlist: an unmatched\nmodel is forwarded to this provider instead of denied.",
          "type": [
            "string",
            "null"
          ]
        },
        "auth_scheme": {
          "type": "string",
          "default": "bearer"
        },
        "inference_path_prefix": {
          "type": "string",
          "default": "/v1"
        }
      },
      "additionalProperties": false
    },
    "GatewayRoute": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "default": ""
        },
        "model_pattern": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "upstream_model": {
          "type": [
            "string",
            "null"
          ]
        },
        "extra_headers": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "pricing": {
          "anyOf": [
            {
              "$ref": "#/$defs/ModelPricing"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false,
      "required": [
        "model_pattern",
        "provider"
      ]
    },
    "GovernanceConfig": {
      "type": "object",
      "properties": {
        "authz": {
          "anyOf": [
            {
              "$ref": "#/$defs/AuthzConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "additionalProperties": false
    },
    "AuthzConfig": {
      "type": "object",
      "properties": {
        "hook": {
          "$ref": "#/$defs/AuthzHookConfig"
        }
      },
      "additionalProperties": false,
      "required": [
        "hook"
      ]
    },
    "AuthzHookConfig": {
      "type": "object",
      "properties": {
        "mode": {
          "$ref": "#/$defs/AuthzMode"
        },
        "url": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "timeout_ms": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0,
          "default": 500
        },
        "acknowledgement": {
          "type": [
            "string",
            "null"
          ],
          "default": null
        }
      },
      "additionalProperties": false,
      "required": [
