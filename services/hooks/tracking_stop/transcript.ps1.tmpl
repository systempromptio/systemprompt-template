$logFile = Join-Path $env:TEMP "systemprompt-transcript-{{plugin_id}}.log"
$reader = [System.IO.StreamReader]::new([System.Console]::OpenStandardInput())
$body = $reader.ReadToEnd()
$reader.Close()

$inputObj = $body | ConvertFrom-Json -ErrorAction SilentlyContinue
$transcriptPath = $inputObj.transcript_path
$sessionId = $inputObj.session_id

if (-not $transcriptPath -or -not (Test-Path $transcriptPath)) {
    Add-Content -Path $logFile -Value "[$(Get-Date -Format o)] No transcript file at: $transcriptPath" -ErrorAction SilentlyContinue
    exit 0
}

$lines = @()
Get-Content $transcriptPath | ForEach-Object {
    $trimmed = $_.Trim()
    if ($trimmed) {
        try { $lines += ($trimmed | ConvertFrom-Json) } catch {}
    }
}

$payload = @{
    session_id = $sessionId
    transcript = $lines
} | ConvertTo-Json -Depth 50 -Compress

$headers = @{
    "Authorization" = "Bearer {{token}}"
    "Content-Type"  = "application/json"
}

try {
    $fileSize = (Get-Item $transcriptPath).Length
    Add-Content -Path $logFile -Value "[$(Get-Date -Format o)] Uploading transcript for session $sessionId ($fileSize bytes)" -ErrorAction SilentlyContinue
    Invoke-RestMethod -Uri "{{platform_url}}/api/public/hooks/transcript?plugin_id={{plugin_id}}" -Method Post -Headers $headers -Body $payload -TimeoutSec 30 -ErrorAction SilentlyContinue | Out-Null
} catch {
    Add-Content -Path $logFile -Value "[$(Get-Date -Format o)] Error: $_" -ErrorAction SilentlyContinue
}
exit 0
