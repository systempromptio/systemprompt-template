{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            id as \"id!\",\n            trace_id as \"trace_id!\",\n            timestamp as \"timestamp!\",\n            level as \"level!\",\n            module as \"module!\",\n            message as \"message!\",\n            metadata\n        FROM logs\n        WHERE message ILIKE $1\n          AND ($2::timestamptz IS NULL OR timestamp >= $2)\n          AND ($3::text IS NULL OR UPPER(level) = $3)\n        ORDER BY timestamp DESC\n        LIMIT $4\n        ",
