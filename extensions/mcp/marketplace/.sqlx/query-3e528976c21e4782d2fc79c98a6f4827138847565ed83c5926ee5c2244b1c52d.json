  "query": "SELECT id, session_id, event_type, tool_name,\n                  COALESCE(metadata, '{}'::jsonb) AS \"metadata!\", created_at\n           FROM plugin_usage_events\n           WHERE metadata->>'agent_id' = $1\n              OR metadata->>'agent' = $1\n              OR tool_name LIKE $2\n           ORDER BY created_at DESC\n           LIMIT 100",
