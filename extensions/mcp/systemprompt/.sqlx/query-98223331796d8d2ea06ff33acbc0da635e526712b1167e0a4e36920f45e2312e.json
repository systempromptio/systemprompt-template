  "query": "\n            SELECT status as \"status!\", COUNT(*)::bigint as \"status_count!\"\n            FROM mcp_tool_executions\n            WHERE tool_name ILIKE $1 AND created_at >= $2 AND created_at < $3\n            GROUP BY status\n            ORDER BY 2 DESC\n            ",
