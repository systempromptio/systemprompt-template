  "query": "\n            SELECT session_id, user_id as \"user_id: UserId\", ip_address, user_agent, device_type,\n                   started_at, last_activity_at, ended_at\n            FROM user_sessions\n            WHERE user_id = $1 AND ended_at IS NULL\n            ORDER BY last_activity_at DESC\n            ",
