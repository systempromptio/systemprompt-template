  "db_name": "PostgreSQL",
  "query": "\n            SELECT ip_address, country, COUNT(*) as session_count\n            FROM user_sessions\n            WHERE started_at >= NOW() - INTERVAL '24 hours'\n              AND ip_address IS NOT NULL\n              AND country IS NOT NULL\n            GROUP BY ip_address, country\n            HAVING COUNT(*) >= $1\n            ",
