# Web Build Environment Variables
# Copy to .env.local and customize for your deployment
# These variables enable the web platform to be fully extensible without snowflake overrides

# ============================================================================
# Theme Configuration
# ============================================================================

# Path to web theme configuration (web.yaml)
# If not set, defaults to: ../../../crates/services/web/web.yaml
# Example: SYSTEMPROMPT_WEB_CONFIG_PATH=/var/www/my-brand/web.yaml
# SYSTEMPROMPT_WEB_CONFIG_PATH=/path/to/web.yaml

# ============================================================================
# Assets (Fonts, Logos, Images)
# ============================================================================

# Path to web implementation assets directory
# If not set, defaults to: ../../../crates/services/web/assets
# Example: SYSTEMPROMPT_WEB_ASSETS_PATH=/var/www/my-brand/assets
# SYSTEMPROMPT_WEB_ASSETS_PATH=/path/to/assets

# ============================================================================
# Content and Implementation Layer
# ============================================================================

# Path to web implementation root directory
# Used by the implementation-overlay plugin for content/component overrides
# If not set, defaults to: ../../../crates/services/web
# Example: SYSTEMPROMPT_WEB_IMPL_PATH=/var/www/my-brand
# SYSTEMPROMPT_WEB_IMPL_PATH=/path/to/web/implementation

# Path to web content (markdown pages and documentation)
# Used by sitemap generation to discover pages
# If not set, defaults to: ../../../crates/services/web/content
# Note: Checked first before falling back to core content
# Example: SYSTEMPROMPT_WEB_CONTENT_PATH=/var/www/my-brand/content
# SYSTEMPROMPT_WEB_CONTENT_PATH=/path/to/content

# ============================================================================
# Site Configuration
# ============================================================================

# Hostname for sitemap generation
# If not set, defaults to: https://systemprompt.dev
# Example: SYSTEMPROMPT_WEB_HOSTNAME=https://my-brand.com
# SYSTEMPROMPT_WEB_HOSTNAME=https://example.com

# ============================================================================
# Complete Example for Custom Deployment
# ============================================================================
# SYSTEMPROMPT_WEB_CONFIG_PATH=/var/www/my-brand/web.yaml
# SYSTEMPROMPT_WEB_ASSETS_PATH=/var/www/my-brand/assets
# SYSTEMPROMPT_WEB_IMPL_PATH=/var/www/my-brand
# SYSTEMPROMPT_WEB_CONTENT_PATH=/var/www/my-brand/content
# SYSTEMPROMPT_WEB_HOSTNAME=https://my-brand.com
