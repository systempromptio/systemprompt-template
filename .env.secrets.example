# SystemPrompt Template - Secrets Configuration
# Copy this file to .env.secrets and fill in your values
# NEVER commit .env.secrets to version control!

# ============================================================================
# DATABASE (Required - provisioned by setup script)
# ============================================================================
# This will be automatically set by `just setup` when provisioning via systemprompt-db
# Format: postgresql://USER:PASSWORD@localhost:6432/DATABASE
DATABASE_URL=
DATABASE_TYPE=postgres

# ============================================================================
# AUTHENTICATION (Required)
# ============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# Admin dashboard password
ADMIN_PASSWORD=admin123

# ============================================================================
# AI PROVIDERS (Optional - enable what you need)
# ============================================================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ============================================================================
# GITHUB (Optional - for GitHub integrations)
# ============================================================================
GITHUB_TOKEN=
